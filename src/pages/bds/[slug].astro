---
/**
 * Property Detail Page
 * Dynamic route for individual property listings
 * URL: /bat-dong-san/{slug}
 */
import ListingWithSidebarLayout from '@/layouts/listing-with-sidebar-layout.astro';
import ImageGalleryCarousel from '@/components/property/property-detail-image-gallery-carousel.astro';
import PropertyInfoSection from '@/components/property/property-info-section.astro';
import ContactCard from '@/components/shared/contact-card.astro';
import PriceRangeFilterCard from '@/components/listing/sidebar/price-range-filter-card.astro';
import AreaRangeFilterCard from '@/components/listing/sidebar/area-range-filter-card.astro';
import SideBlockFiltersCard from '@/components/listing/sidebar/side-block-filters-card.astro';
import FeaturedProjectBanner from '@/components/listing/sidebar/featured-project-banner.astro';
import PropertyCard from '@/components/cards/property-card.astro';
import { getFeaturedProjects } from '@/services/featured-project-service';
import PriceHistoryChart from '@/components/property/price-history-chart.astro';
import { postgresPropertyService } from '@/services/postgres-property-service';
import type { Property } from '@/types/property';
import { db } from '@/db';
import { locations, propertyType } from '@/db/schema';
import { eq } from 'drizzle-orm';

// Get slug from URL params
const { slug } = Astro.params;

// Fetch property from PostgreSQL by slug
const property = await postgresPropertyService.getPropertyBySlug(slug || '');

// Return 404 if property not found
if (!property) {
  return Astro.redirect('/404');
}

// Get property_type_id for related query (map back from type string)
const PROPERTY_TYPE_ID_MAP: Record<string, number> = {
  apartment: 1, villa: 2, office: 3, shophouse: 4,
  warehouse: 5, house: 14, land: 46,
};
const propertyTypeId = PROPERTY_TYPE_ID_MAP[property.type] || 14;

// Fetch related properties from PostgreSQL
const displayRelated = await postgresPropertyService.getRelatedProperties(
  property.id,
  propertyTypeId,
  4
);

// Generate mock images array from thumbnail (for demo)
const propertyImages = property.images.length > 1
  ? property.images
  : [
      property.thumbnail,
      property.thumbnail,
      property.thumbnail,
      property.thumbnail,
    ];

// SEO
const pageTitle = `${property.title} | TongkhoBDS`;
const pageDescription = property.description.slice(0, 160);

// Build listing page base path for sidebar filters
// Get location slug from property (priority: ward > district > city)
let locationSlug = 'toan-quoc'; // fallback

if (property.wardId) {
  const ward = await db.select({ slug: locations.nSlugV1 })
    .from(locations)
    .where(eq(locations.nId, property.wardId))
    .limit(1);
  if (ward.length > 0 && ward[0].slug) {
    locationSlug = ward[0].slug;
  }
} else if (property.districtId) {
  const district = await db.select({ slug: locations.nSlugV1 })
    .from(locations)
    .where(eq(locations.nId, property.districtId))
    .limit(1);
  if (district.length > 0 && district[0].slug) {
    locationSlug = district[0].slug;
  }
} else if (property.cityId) {
  const city = await db.select({ slug: locations.nSlugV1 })
    .from(locations)
    .where(eq(locations.nId, property.cityId))
    .limit(1);
  if (city.length > 0 && city[0].slug) {
    locationSlug = city[0].slug;
  }
}

// Get property type slug for URL (prefer property type slug over transaction slug)
// Use propertyTypeId from database (property.propertyTypeId) or mapped value
const actualPropertyTypeId = property.propertyTypeId || propertyTypeId;

let propertyTypeSlug: string | null = null;
if (actualPropertyTypeId) {
  const propertyTypeData = await db
    .select({ slug: propertyType.slug })
    .from(propertyType)
    .where(eq(propertyType.id, actualPropertyTypeId))
    .limit(1);
  propertyTypeSlug = propertyTypeData[0]?.slug || null;
}

// Build listing base path with property type slug (if available) or transaction slug
const baseSlug = propertyTypeSlug || (property.transactionType === 'sale' ? 'mua-ban' : 'cho-thue');
const listingBasePath = `/${baseSlug}/${locationSlug}`;

// Fetch featured projects for sidebar
const featuredProjects = await getFeaturedProjects(5);
---

<ListingWithSidebarLayout
  title={pageTitle}
  description={pageDescription}
  image={property.thumbnail}
>
  <!-- Main Content Slot -->
  <div class="space-y-6">
    <!-- Breadcrumb -->
    <nav class="text-sm text-secondary-500">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/" class="hover:text-primary-500 transition-colors">Trang chủ</a></li>
        <li class="text-secondary-300">&gt;</li>
        <li>
          <a href={property.transactionType === 'sale' ? '/mua-ban' : '/cho-thue'} class="hover:text-primary-500 transition-colors">
            {property.transactionType === 'sale' ? 'Mua bán' : 'Cho thuê'}
          </a>
        </li>
        <li class="text-secondary-300">&gt;</li>
        <li class="text-secondary-700 font-medium line-clamp-1">{property.title}</li>
      </ol>
    </nav>

    <!-- Image Gallery -->
    <ImageGalleryCarousel images={propertyImages} />

    <!-- Property Info Section -->
    <PropertyInfoSection property={property} />

    <!-- Price History Chart -->
    <PriceHistoryChart currentPrice={property.price} priceUnit={property.priceUnit} />

    <!-- Related Properties Section -->
    {displayRelated.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-bold text-secondary-800 mb-6">Bất động sản khác</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {displayRelated.map((relatedProperty) => (
            <PropertyCard property={relatedProperty} />
          ))}
        </div>
      </section>
    )}
  </div>

  <!-- Sidebar Slot -->
  <div slot="sidebar" class="space-y-4">
    <!-- Quick Contact -->
    <ContactCard />

    <!-- Price Range Filter -->
    <PriceRangeFilterCard currentMin={undefined} currentMax={undefined} basePath={listingBasePath} />

    <!-- Area Range Filter -->
    <AreaRangeFilterCard currentMin={undefined} currentMax={undefined} basePath={listingBasePath} />

    <!-- Side Block Filters (Related Filters) -->
    <SideBlockFiltersCard propertyId={property.id} />

    <!-- Featured Projects -->
    <FeaturedProjectBanner projects={featuredProjects} />
  </div>
</ListingWithSidebarLayout>
