---
/**
 * Dynamic Listing Route
 * Handles: /mua-ban, /cho-thue, /du-an with filters
 * URL pattern: /{transaction}/{location}/{price}?filters
 */
import ListingWithSidebarLayout from '@/layouts/listing-with-sidebar-layout.astro';
import ListingBreadcrumb from '@/components/listing/listing-breadcrumb.astro';
import HorizontalSearchBar from '@/components/listing/horizontal-search-bar.astro';
import ListingGrid from '@/components/listing/listing-grid.astro';
import ListingPagination from '@/components/listing/listing-pagination.astro';
import SidebarWrapper from '@/components/listing/sidebar/sidebar-wrapper.astro';
import { searchProperties } from '@/services/elasticsearch/property-search-service';
import { resolveLocationSlugs, getAllProvincesWithCount, getDistrictsByProvinceNId } from '@/services/location/location-service';
import { fetchPropertyTypesByTransaction } from '@/services/menu-service';
import { getFeaturedProjects } from '@/services/featured-project-service';
import { getSideBlock } from '@/services/get-side-block-service';
import { parseListingUrl, getPageTitle, getPageDescription } from '@/utils/listing-url-parser';
import type { PropertySearchFilters } from '@/services/elasticsearch/types';

// Valid transaction slugs
const VALID_TRANSACTIONS = ['mua-ban', 'cho-thue', 'du-an'];

// Get URL params
const { slug } = Astro.params;
const url = new URL(Astro.request.url);
const slugParts = slug?.split('/').filter(Boolean) || [];

// Exit early if no slug parts
if (slugParts.length === 0) {
  return Astro.redirect('/404');
}

// Check if first segment is a valid transaction type OR a property type slug (v1 format)
let isPropertyTypeUrl = false;
let propertyTypeFromFirstSegment: any = null;

if (!VALID_TRANSACTIONS.includes(slugParts[0])) {
  // First segment is NOT a transaction type, check if it's a property type slug
  // We need to check all property types from all transactions
  const allPropertyTypes = await Promise.all([
    fetchPropertyTypesByTransaction(1), // mua-ban
    fetchPropertyTypesByTransaction(2), // cho-thue
    fetchPropertyTypesByTransaction(3), // du-an
  ]);

  // Flatten and search
  const flatPropertyTypes = allPropertyTypes.flat();
  propertyTypeFromFirstSegment = flatPropertyTypes.find(pt => pt.slug === slugParts[0]);

  if (propertyTypeFromFirstSegment) {
    // This is a v1-style property type URL (e.g., /ban-can-ho-chung-cu)
    isPropertyTypeUrl = true;
    // Inject transaction type at the beginning for parser
    slugParts.unshift(
      propertyTypeFromFirstSegment.transactionType === 1 ? 'mua-ban' :
      propertyTypeFromFirstSegment.transactionType === 2 ? 'cho-thue' : 'du-an'
    );
  } else {
    // Not a valid transaction type OR property type slug
    return Astro.redirect('/404');
  }
}

// Parse URL to filters (slugParts now guaranteed to have valid transaction type at index 0)
const filters: PropertySearchFilters = parseListingUrl(slugParts, url.searchParams);

// Get property types for resolving slug
const propertyTypes = await fetchPropertyTypesByTransaction(filters.transactionType);

// Check if segment 1 is a property type slug instead of location (for /mua-ban/ban-can-ho URLs)
const segment1 = slugParts.length > 1 ? slugParts[1] : null;
let propertyTypeFromSlug: typeof propertyTypes[0] | undefined;

if (isPropertyTypeUrl && propertyTypeFromFirstSegment) {
  // Already identified property type from first segment
  propertyTypeFromSlug = propertyTypeFromFirstSegment;
  filters.propertyTypes = [propertyTypeFromFirstSegment.id];
} else if (segment1) {
  // Try to find property type by slug in segment 1
  propertyTypeFromSlug = propertyTypes.find(pt => pt.slug === segment1);

  if (propertyTypeFromSlug) {
    // Segment 1 is property type, not location
    filters.propertyTypes = [propertyTypeFromSlug.id];

    // Clear location slug from parser (it was misidentified)
    // @ts-expect-error - temp storage cleanup
    if (filters._locationSlugs?.includes(segment1)) {
      // @ts-expect-error
      filters._locationSlugs = filters._locationSlugs.filter((s: string) => s !== segment1);
    }
  }
}

// Resolve location slugs - primary from path + additional from addresses query param (v1 compatible)
// @ts-expect-error - temp storage from parser
const locationSlugs = filters._locationSlugs || [];
// @ts-expect-error - temp storage from parser
const additionalLocationSlugs = filters._additionalLocationSlugs || [];

// Merge all location slugs for batch resolution
const allLocationSlugs = [...locationSlugs, ...additionalLocationSlugs];

const resolvedLocations = allLocationSlugs.length > 0
  ? await resolveLocationSlugs(allLocationSlugs)
  : [];


// Primary location is the first one (from URL path)
const selectedLocation = resolvedLocations[0] || null;

// Resolve district slugs from query param (multi-select support)
// @ts-expect-error - temp storage from parser
const districtSlugs = filters._districtSlugs || [];
const resolvedDistricts = districtSlugs.length > 0
  ? await resolveLocationSlugs(districtSlugs)
  : [];

// Set district filter (always use district_id for ES compatibility)
// Priority: explicit district slugs > resolved locations (multi-location support)
if (resolvedDistricts.length > 0) {
  // Explicit district selection via query param (multi-select)
  filters.districtIds = resolvedDistricts.map(d => d.nId).filter(Boolean) as string[];
} else if (resolvedLocations.length > 0) {
  // Collect districts from resolved locations (v1 compatible multi-location logic)
  const districtNIds = new Set<string>();
  const hasDistrictsInLocations = resolvedLocations.some(l => l.type === 'district');

  for (const location of resolvedLocations) {
    if (location.type === 'district') {
      // Add district directly
      districtNIds.add(location.nId);
    } else if (location.type === 'province' && !hasDistrictsInLocations) {
      // ONLY expand province to all districts if NO specific districts are provided
      // (i.e., only province in path, no addresses param with districts)
      const districts = await getDistrictsByProvinceNId(location.nId);
      districts.forEach(d => {
        if (d.nId) districtNIds.add(d.nId);
      });
    }
  }

  filters.districtIds = Array.from(districtNIds);
}

// Extract center coordinates for radius search (from primary location)
if (filters.radius && selectedLocation?.lat && selectedLocation?.lon) {
  filters.centerLat = selectedLocation.lat;
  filters.centerLon = selectedLocation.lon;
}

// Store selected location for UI display (single location only)
const selectedLocations = selectedLocation ? [selectedLocation] : [];

// Store selected districts for UI display (multi-select support)
const selectedDistrictsList = resolvedDistricts.length > 0 ? resolvedDistricts : [];

// @ts-expect-error - cleanup temp storage
delete filters._locationSlugs;
// @ts-expect-error - cleanup temp storage
delete filters._additionalLocationSlugs;
// @ts-expect-error - cleanup temp storage
delete filters._districtSlugs;

// Get provinces with property counts and images (V1-compatible)
// Default to old addresses (useNew=false) to match v1 behavior
const provinces = await getAllProvincesWithCount(undefined, false);

// Extract province and district slugs from selected locations
let currentProvinceSlug = '';
let currentDistrictSlugs: string[] = [];

if (resolvedDistricts.length > 0) {
  // Multi-district selection from query param
  currentDistrictSlugs = resolvedDistricts.map(d => d.slug);
  // Get province from first district
  if (resolvedDistricts[0].provinceId) {
    const parentProvince = provinces.find(p => p.nId === resolvedDistricts[0].provinceId);
    currentProvinceSlug = parentProvince?.slug || '';
  }
} else if (selectedLocation) {
  if (selectedLocation.type === 'province') {
    // User selected province directly
    currentProvinceSlug = selectedLocation.slug;
  } else if (selectedLocation.type === 'district') {
    // User selected single district from URL path
    currentDistrictSlugs = [selectedLocation.slug];
    if (selectedLocation.provinceId) {
      // Find province by nId to get slug
      const parentProvince = provinces.find(p => p.nId === selectedLocation.provinceId);
      currentProvinceSlug = parentProvince?.slug || '';
    }
  }
}

// Resolve property type name for breadcrumb (prioritize slug-based detection)
const propertyTypeName = propertyTypeFromSlug?.title || (
  filters.propertyTypes?.length === 1
    ? propertyTypes.find(pt => pt.id === filters.propertyTypes![0])?.title || ''
    : ''
);

// Build pattern for sidebar location filter (same logic as LocationFilterCard)
let sideBlockPattern: string | null = null;
const isTransactionUrl = VALID_TRANSACTIONS.includes(slug?.split('/')[0] || '');
const shouldHideForTransactionOnly = isTransactionUrl && !selectedLocation;

if (!shouldHideForTransactionOnly) {
  // Build pattern from property type and location
  const propertyTypeSlug = propertyTypeFromSlug?.slug || slugParts[0];
  const locationSlug = selectedLocation?.slug;

  if (locationSlug) {
    sideBlockPattern = `${propertyTypeSlug}/${locationSlug}`;
  } else {
    sideBlockPattern = propertyTypeSlug || 'mua-ban';
  }
}


// Parallel queries - fetch properties, featured projects, and sidebar data simultaneously (SSG optimization)
const [searchResult, featuredProjects, sideBlocks] = await Promise.all([
  searchProperties(filters),
  getFeaturedProjects(5),
  sideBlockPattern ? getSideBlock({ pattern: sideBlockPattern }).catch(err => {
    console.error('[Page] Failed to load side blocks:', err);
    return [];
  }) : Promise.resolve([]),
]);
const { hits: properties, total, took } = searchResult;


// Build metadata
const title = getPageTitle(filters);
const description = getPageDescription(filters, total);

// Pagination info
const currentPage = filters.page || 1;
const pageSize = filters.pageSize || 24;
const totalPages = Math.ceil(total / pageSize);

// Helper: Build sort URL preserving current filters
function buildSortUrl(sortOption: string): string {
  const params = new URLSearchParams(url.searchParams);
  params.set('sort', sortOption);
  params.delete('page'); // Reset to page 1 when changing sort
  const query = params.toString();
  return query ? `${url.pathname}?${query}` : url.pathname;
}
---

<ListingWithSidebarLayout title={title} description={description}>
  <!-- Horizontal Search Bar -->
  <HorizontalSearchBar
    transactionType={filters.transactionType}
    propertyTypes={propertyTypes.map(pt => ({
      id: pt.id,
      title: pt.vietnamese || pt.title || '',
      slug: pt.slug || '',
      vietnamese: pt.vietnamese
    }))}
    provinces={provinces}
    currentProvince={currentProvinceSlug}
    currentDistricts={currentDistrictSlugs}
    currentFilters={{
      propertyTypes: filters.propertyTypes,
      minPrice: filters.minPrice?.toString(),
      maxPrice: filters.maxPrice?.toString(),
      keyword: filters.keyword,
      minArea: filters.minArea?.toString(),
      maxArea: filters.maxArea?.toString(),
      radius: filters.radius?.toString(),
      bedrooms: filters.bedrooms?.toString(),
      bathrooms: filters.bathrooms?.toString(),
    }}
    currentPath={url.pathname}
  />

  <!-- Breadcrumb -->
  <ListingBreadcrumb
    filters={filters}
    selectedLocations={selectedLocations}
    propertyTypeName={propertyTypeName}
  />

  <!-- Results Header -->
  <div class="py-4 mb-4">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-xl font-semibold text-slate-900">
          {title.replace(' - Tongkho BĐS', '')}
        </h1>
        <p class="text-sm text-slate-500 mt-1">
          Tìm thấy <span class="font-medium text-slate-700">{total.toLocaleString('vi-VN')}</span> kết quả
          <span class="text-slate-400">({took}ms)</span>
        </p>
      </div>

      <!-- Sort Dropdown -->
      <div class="flex items-center gap-2">
        <label for="sort" class="text-sm text-slate-600">Sắp xếp:</label>
        <select
          id="sort"
          class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500"
          onchange="if (window.location.pathname + window.location.search !== this.value) window.location.href = this.value"
        >
          <option value={buildSortUrl('newest')} selected={filters.sort === 'newest'}>Mới nhất</option>
          <option value={buildSortUrl('oldest')} selected={filters.sort === 'oldest'}>Cũ nhất</option>
          <option value={buildSortUrl('price_asc')} selected={filters.sort === 'price_asc'}>Giá thấp đến cao</option>
          <option value={buildSortUrl('price_desc')} selected={filters.sort === 'price_desc'}>Giá cao đến thấp</option>
          <option value={buildSortUrl('area_asc')} selected={filters.sort === 'area_asc'}>Diện tích nhỏ đến lớn</option>
          <option value={buildSortUrl('area_desc')} selected={filters.sort === 'area_desc'}>Diện tích lớn đến nhỏ</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Property Grid -->
  <ListingGrid properties={properties} />

  <!-- Pagination -->
  {totalPages > 1 && (
    <ListingPagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl={url.pathname}
      totalResults={total}
      pageSize={pageSize}
    />
  )}

  <!-- Sidebar -->
  <Fragment slot="sidebar">
    <SidebarWrapper filters={filters} featuredProjects={featuredProjects} sideBlocks={sideBlocks} />
  </Fragment>
</ListingWithSidebarLayout>
