---
/**
 * Dynamic Listing Route
 * Handles: /mua-ban, /cho-thue, /du-an with filters
 * URL pattern: /{transaction}/{location}/{price}?filters
 */
import ListingWithSidebarLayout from '@/layouts/listing-with-sidebar-layout.astro';
import ListingBreadcrumb from '@/components/listing/listing-breadcrumb.astro';
import ListingFilter from '@/components/listing/listing-filter.astro';
import ListingGrid from '@/components/listing/listing-grid.astro';
import ListingPagination from '@/components/listing/listing-pagination.astro';
import SidebarWrapper from '@/components/listing/sidebar/sidebar-wrapper.astro';
import { searchProperties } from '@/services/elasticsearch/property-search-service';
import { resolveLocationSlugs, getAllProvinces } from '@/services/location/location-service';
import { fetchPropertyTypesByTransaction } from '@/services/menu-service';
import { parseListingUrl, getPageTitle, getPageDescription } from '@/utils/listing-url-parser';
import type { PropertySearchFilters } from '@/services/elasticsearch/types';

// Valid transaction slugs
const VALID_TRANSACTIONS = ['mua-ban', 'cho-thue', 'du-an'];

// Get URL params
const { slug } = Astro.params;
const url = new URL(Astro.request.url);
const slugParts = slug?.split('/').filter(Boolean) || [];

// Validate first segment is a valid transaction type
if (slugParts.length === 0 || !VALID_TRANSACTIONS.includes(slugParts[0])) {
  return Astro.redirect('/404');
}

// Parse URL to filters
const filters: PropertySearchFilters = parseListingUrl(slugParts, url.searchParams);

// Get property types for resolving slug (v1 logic: segment 1 might be property type)
const propertyTypes = await fetchPropertyTypesByTransaction(filters.transactionType);

// Check if segment 1 is a property type slug instead of location
const segment1 = slugParts.length > 1 ? slugParts[1] : null;
let propertyTypeFromSlug: typeof propertyTypes[0] | undefined;

if (segment1) {
  // Try to find property type by slug
  propertyTypeFromSlug = propertyTypes.find(pt => pt.slug === segment1);

  if (propertyTypeFromSlug) {
    // Segment 1 is property type, not location
    filters.propertyTypes = [propertyTypeFromSlug.id];

    // Clear location slug from parser (it was misidentified)
    // @ts-expect-error - temp storage cleanup
    if (filters._locationSlugs?.includes(segment1)) {
      // @ts-expect-error
      filters._locationSlugs = filters._locationSlugs.filter((s: string) => s !== segment1);
    }
  }
}

// Batch resolve location slugs to nIds (multi-location support)
// @ts-expect-error - temp storage from parser
const locationSlugs = filters._locationSlugs || [];
const resolvedLocations = locationSlugs.length > 0
  ? await resolveLocationSlugs(locationSlugs)
  : [];

// Extract province and district nIds for ES query
const provinceNIds = resolvedLocations
  .filter(loc => loc.type === 'province')
  .map(loc => loc.nId);

const districtNIds = resolvedLocations
  .filter(loc => loc.type === 'district')
  .map(loc => loc.nId);

// Merge with existing filters (preserve direct IDs from query params)
if (provinceNIds.length > 0) {
  filters.provinceIds = [...(filters.provinceIds || []), ...provinceNIds];
}
if (districtNIds.length > 0) {
  filters.districtIds = [...(filters.districtIds || []), ...districtNIds];
}

// Store resolved locations for UI display (chips)
const selectedLocations = resolvedLocations.map(loc => ({
  nId: loc.nId,
  name: loc.name,
  slug: loc.slug,
  type: loc.type
}));

// @ts-expect-error - cleanup temp storage
delete filters._locationSlugs;

// Get provinces for filter
const provinces = await getAllProvinces(true);

// Extract first province slug from selected locations (for sidebar state)
const currentProvinceSlug = selectedLocations.find(loc => loc.type === 'province')?.slug || '';

// Resolve property type name for breadcrumb (prioritize slug-based detection)
const propertyTypeName = propertyTypeFromSlug?.title || (
  filters.propertyTypes?.length === 1
    ? propertyTypes.find(pt => pt.id === filters.propertyTypes![0])?.title || ''
    : ''
);

// Query ElasticSearch
const searchResult = await searchProperties(filters);
const { hits: properties, total, took } = searchResult;

// Build metadata
const title = getPageTitle(filters);
const description = getPageDescription(filters, total);

// Pagination info
const currentPage = filters.page || 1;
const pageSize = filters.pageSize || 20;
const totalPages = Math.ceil(total / pageSize);

// Helper: Build sort URL preserving current filters
function buildSortUrl(sortOption: string): string {
  const params = new URLSearchParams(url.searchParams);
  params.set('sort', sortOption);
  params.delete('page'); // Reset to page 1 when changing sort
  const query = params.toString();
  return query ? `${url.pathname}?${query}` : url.pathname;
}
---

<ListingWithSidebarLayout title={title} description={description}>
  <!-- Breadcrumb -->
  <ListingBreadcrumb
    filters={filters}
    selectedLocations={selectedLocations}
    propertyTypeName={propertyTypeName}
  />

  <!-- Filter Section -->
  <ListingFilter
    transactionType={filters.transactionType}
    propertyTypes={propertyTypes.map(pt => ({ id: pt.id, title: pt.title || '', slug: pt.slug || '' }))}
    provinces={provinces}
    currentProvince={currentProvinceSlug}
    currentFilters={{
      propertyTypes: filters.propertyTypes,
      minPrice: filters.minPrice?.toString(),
      maxPrice: filters.maxPrice?.toString(),
      minArea: filters.minArea?.toString(),
      maxArea: filters.maxArea?.toString(),
      bedrooms: filters.bedrooms?.toString(),
      bathrooms: filters.bathrooms?.toString(),
    }}
    currentPath={url.pathname}
    selectedLocations={selectedLocations}
  />

  <!-- Results Header -->
  <div class="bg-white rounded-lg shadow-sm p-4 mb-4">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-xl font-semibold text-slate-900">
          {title.replace(' - Tongkho BĐS', '')}
        </h1>
        <p class="text-sm text-slate-500 mt-1">
          Tìm thấy <span class="font-medium text-slate-700">{total.toLocaleString('vi-VN')}</span> kết quả
          <span class="text-slate-400">({took}ms)</span>
        </p>
      </div>

      <!-- Sort Dropdown -->
      <div class="flex items-center gap-2">
        <label for="sort" class="text-sm text-slate-600">Sắp xếp:</label>
        <select
          id="sort"
          class="border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500"
          onchange="if (window.location.pathname + window.location.search !== this.value) window.location.href = this.value"
        >
          <option value={buildSortUrl('newest')} selected={filters.sort === 'newest'}>Mới nhất</option>
          <option value={buildSortUrl('oldest')} selected={filters.sort === 'oldest'}>Cũ nhất</option>
          <option value={buildSortUrl('price_asc')} selected={filters.sort === 'price_asc'}>Giá thấp đến cao</option>
          <option value={buildSortUrl('price_desc')} selected={filters.sort === 'price_desc'}>Giá cao đến thấp</option>
          <option value={buildSortUrl('area_asc')} selected={filters.sort === 'area_asc'}>Diện tích nhỏ đến lớn</option>
          <option value={buildSortUrl('area_desc')} selected={filters.sort === 'area_desc'}>Diện tích lớn đến nhỏ</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Property Grid -->
  <ListingGrid properties={properties} />

  <!-- Pagination -->
  {totalPages > 1 && (
    <ListingPagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl={url.pathname}
    />
  )}

  <!-- Sidebar -->
  <Fragment slot="sidebar">
    <SidebarWrapper filters={filters} />
  </Fragment>
</ListingWithSidebarLayout>
