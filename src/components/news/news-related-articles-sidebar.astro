---
/**
 * Related Articles Sidebar Component
 * Shows related news articles based on category or recent posts
 * Now with dynamic folder sections from database
 */
import type { NewsArticle, NewsCategory } from '@/types/property';
import type { MenuFolder } from '@/types/menu';

interface Props {
  articles: NewsArticle[];
  currentSlug: string;
  category: NewsCategory;
  newsFolders: MenuFolder[];
  maxItems?: number;
}

const { articles, currentSlug, category, newsFolders, maxItems = 4 } = Astro.props;

// v1 parity: articles are already filtered by same folder in detail page
// Just exclude current article and limit to maxItems
const relatedArticles = articles
  .filter(article => article.slug !== currentSlug)
  .slice(0, maxItems);

// Filter folders: only show parent folders with sub-folders
// Empty state: If no folders match, sidebar shows only related articles section
const foldersWithSubs = newsFolders.filter(folder => folder.subFolders && folder.subFolders.length > 0);
---

<!-- Dynamic Folder Sections -->
{foldersWithSubs.map((folder) => (
  <div class="bg-white p-5 mb-6">
    <h3 class="text-base font-bold text-secondary-900 mb-3 pb-3 border-b border-secondary-200">
      {folder.label || folder.name}
    </h3>
    <ul class="space-y-1.5">
      {folder.subFolders?.filter(sf => sf.name).map((subFolder) => (
        <li>
          <a
            href={`/chuyenmuc/${subFolder.name}`}
            class="block text-sm text-secondary-700 hover:text-primary-600 transition-colors py-1"
          >
            {subFolder.label || subFolder.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
))}

<!-- Related Articles Section -->
<div class="bg-white p-5">
  <h3 class="text-base font-bold text-secondary-900 mb-3 pb-3 border-b border-secondary-200">
    Bài viết liên quan
  </h3>

  <ul class="space-y-2">
    {relatedArticles.map((article) => (
      <li>
        <a
          href={`/tin/${article.slug}`}
          class="block text-sm text-secondary-700 hover:text-primary-600 transition-colors py-1 line-clamp-2"
        >
          {article.title}
        </a>
      </li>
    ))}
  </ul>
</div>
