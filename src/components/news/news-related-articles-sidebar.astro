---
/**
 * Related Articles Sidebar Component
 * Shows related news articles based on category or recent posts
 * Now with dynamic folder sections from database
 */
import type { NewsArticle, NewsCategory } from '@/types/property';
import type { MenuFolder } from '@/types/menu';
import { formatRelativeTime } from '@/utils/format';

interface Props {
  articles: NewsArticle[];
  currentSlug: string;
  category: NewsCategory;
  newsFolders: MenuFolder[];
  maxItems?: number;
}

const { articles, currentSlug, category, newsFolders, maxItems = 4 } = Astro.props;

// v1 parity: articles are already filtered by same folder in detail page
// Just exclude current article and limit to maxItems
const relatedArticles = articles
  .filter(article => article.slug !== currentSlug)
  .slice(0, maxItems);

// Filter folders: only show parent folders with sub-folders
// Empty state: If no folders match, sidebar shows only related articles section
const foldersWithSubs = newsFolders.filter(folder => folder.subFolders && folder.subFolders.length > 0);
---

<!-- Dynamic Folder Sections -->
{foldersWithSubs.map((folder) => (
  <div class="bg-white rounded-lg shadow p-5 mb-6">
    <h3 class="text-lg font-semibold text-secondary-800 mb-4 pb-3 border-b border-secondary-200">
      {folder.label || folder.name}
    </h3>
    <ul class="space-y-2">
      {folder.subFolders?.filter(sf => sf.name).map((subFolder) => (
        <li>
          <a
            href={`/chuyenmuc/${subFolder.name}`}
            class="flex items-center gap-2 px-3 py-2 text-sm rounded-lg transition-colors text-secondary-600 hover:bg-secondary-50 hover:text-primary-500"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            {subFolder.label || subFolder.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
))}

<!-- Related Articles Section -->
<div class="bg-white rounded-lg shadow p-5">
  <h3 class="text-lg font-semibold text-secondary-800 mb-4 pb-3 border-b border-secondary-200">
    Bài viết liên quan
  </h3>

  <ul class="space-y-3">
    {relatedArticles.map((article) => (
      <li>
        <a
          href={`/tin/${article.slug}`}
          class="block group"
        >
          <h4 class="text-sm text-secondary-700 group-hover:text-primary-500 transition-colors leading-relaxed line-clamp-2">
            {article.title}
          </h4>
          <div class="flex items-center gap-2 mt-1 text-xs text-secondary-400">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {formatRelativeTime(article.publishedAt)}
          </div>
        </a>
      </li>
    ))}
  </ul>
</div>
