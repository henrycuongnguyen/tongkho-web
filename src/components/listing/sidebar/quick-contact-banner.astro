---
/**
 * Quick Contact Banner
 * Display contact info in sidebar - matches design with logo header and action buttons
 */

// Contact info from environment (fallback to defaults)
const PHONE = import.meta.env.PUBLIC_PHONE || '1900 98 89 98';
const EMAIL = import.meta.env.PUBLIC_EMAIL || 'cskh@tongkhobds.com';
const ZALO_URL = import.meta.env.PUBLIC_ZALO_URL || `https://zalo.me/${PHONE.replace(/\D/g, '')}`;
---

<div class="bg-white rounded-lg shadow-sm p-6 border border-slate-100">
  <!-- Header with logo and branding -->
  <div class="flex items-center gap-3 mb-6">
    <div class="w-14 h-14 bg-primary-500 rounded-full flex items-center justify-center flex-shrink-0">
      <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
    </div>
    <div>
      <h3 class="font-bold text-slate-800 text-lg">TongkhoBDS.com</h3>
    </div>
  </div>

  <!-- Contact info -->
  <div class="space-y-3 mb-6">
    <!-- Phone -->
    <div class="flex items-center gap-3 text-slate-700">
      <svg class="w-5 h-5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <span class="font-medium">{PHONE}</span>
    </div>

    <!-- Email -->
    <div class="flex items-center gap-3 text-slate-700">
      <svg class="w-5 h-5 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      <span class="font-medium text-sm">{EMAIL}</span>
    </div>
  </div>

  <!-- Action buttons -->
  <div class="flex gap-3">
    <!-- Call button -->
    <a
      href={`tel:${PHONE.replace(/\D/g, '')}`}
      class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-primary-500 hover:bg-primary-600 text-white rounded-lg font-medium transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <span>Gọi ngay</span>
    </a>

    <!-- Message button (Zalo) -->
    <a
      href={ZALO_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.48 2 2 6.48 2 12c0 1.54.36 3 .97 4.29L2 22l5.71-.97C9 21.64 10.46 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-1.4 0-2.74-.35-3.9-1.01l-.28-.16-2.91.62.62-2.91-.16-.28C4.35 14.74 4 13.4 4 12c0-4.41 3.59-8 8-8s8 3.59 8 8-3.59 8-8 8z"/>
      </svg>
      <span>Nhắn tin</span>
    </a>
  </div>
</div>
