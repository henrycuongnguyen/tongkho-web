---
/**
 * Quick Contact Banner
 * Display contact info in sidebar
 */

// Contact info from environment (fallback to defaults)
const PHONE = import.meta.env.PUBLIC_PHONE || '0123.456.789';
const EMAIL = import.meta.env.PUBLIC_EMAIL || 'contact@tongkhobds.com';
const ZALO_URL = import.meta.env.PUBLIC_ZALO_URL || `https://zalo.me/${PHONE.replace(/\D/g, '')}`;
---

<div class="bg-white rounded-lg shadow-sm p-4">
  <h3 class="font-semibold text-slate-800 mb-4">Liên hệ nhanh</h3>

  <!-- Phone -->
  <a
    href={`tel:${PHONE.replace(/\D/g, '')}`}
    class="flex items-center gap-3 p-3 bg-green-50 hover:bg-green-100 rounded-lg transition-colors mb-3"
  >
    <div class="w-10 h-10 flex items-center justify-center bg-green-500 rounded-full">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
    </div>
    <div>
      <span class="text-xs text-green-600 font-medium">Gọi ngay</span>
      <p class="font-semibold text-green-700">{PHONE}</p>
    </div>
  </a>

  <!-- Zalo -->
  <a
    href={ZALO_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-3 p-3 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors mb-3"
  >
    <div class="w-10 h-10 flex items-center justify-center bg-blue-500 rounded-full">
      <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.477 2 2 6.477 2 12c0 5.523 4.477 10 10 10s10-4.477 10-10c0-5.523-4.477-10-10-10zm3.5 14.5h-7v-1.5h7v1.5zm0-3h-7v-1.5h7v1.5zm0-3h-7v-1.5h7v1.5z"/>
      </svg>
    </div>
    <div>
      <span class="text-xs text-blue-600 font-medium">Nhắn tin qua Zalo</span>
      <p class="font-semibold text-blue-700">Chat ngay</p>
    </div>
  </a>

  <!-- Email -->
  <a
    href={`mailto:${EMAIL}`}
    class="flex items-center gap-3 p-3 bg-slate-50 hover:bg-slate-100 rounded-lg transition-colors"
  >
    <div class="w-10 h-10 flex items-center justify-center bg-slate-500 rounded-full">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </div>
    <div>
      <span class="text-xs text-slate-600 font-medium">Email</span>
      <p class="font-medium text-slate-700 text-sm truncate">{EMAIL}</p>
    </div>
  </a>
</div>
