---
/**
 * Location Filter Card (V1-Compatible SSR Component)
 * Uses Elasticsearch aggregations for accurate property counts
 * Hierarchical location filters: Provinces → Districts → Wards
 */
import { getSideBlock } from '@/services/get-side-block-service';
import type { SideBlock } from '@/services/get-side-block-service';

// Parse URL context
const url = Astro.url;
const pathSegments = url.pathname.split('/').filter(Boolean);

// Detect property_type and location from URL
// Patterns:
// - /mua-ban → transaction only
// - /mua-ban/ha-noi → transaction + location
// - /can-ho-chung-cu → property_type only
// - /can-ho-chung-cu/ha-noi → property_type + location
let propertyTypeSlug: string | null = null;
let locationSlug: string | null = null;

// Check if first segment is transaction type
const VALID_TRANSACTIONS = ['mua-ban', 'cho-thue', 'du-an'];
const isTransactionUrl = VALID_TRANSACTIONS.includes(pathSegments[0]);

if (isTransactionUrl) {
  // Transaction-based URL
  propertyTypeSlug = pathSegments[0];
  if (pathSegments.length > 1 && !pathSegments[1].startsWith('gia-') && pathSegments[1] !== 'toan-quoc') {
    locationSlug = pathSegments[1];
  }
} else if (pathSegments.length > 0) {
  // Property type-based URL (v1 format)
  propertyTypeSlug = pathSegments[0];
  if (pathSegments.length > 1 && !pathSegments[1].startsWith('gia-') && pathSegments[1] !== 'toan-quoc') {
    locationSlug = pathSegments[1];
  }
}

// V1 doesn't support transaction-only URLs (e.g., /mua-ban without property type)
// Hide card in this case
const shouldHideForTransactionOnly = isTransactionUrl && !locationSlug;

// Build pattern for getSideBlock
let pattern: string;
if (locationSlug) {
  pattern = `${propertyTypeSlug}/${locationSlug}`;
} else {
  pattern = propertyTypeSlug || 'mua-ban';
}

console.log('[LocationFilterCard] Pattern:', pattern);

// Get side block data (with Elasticsearch aggregations)
let sideBlocks: SideBlock[] = [];
let hasError = false;

// Skip API call if transaction-only URL (not supported by v1)
if (!shouldHideForTransactionOnly) {
  try {
    sideBlocks = await getSideBlock({ pattern });
    console.log('[LocationFilterCard] Side blocks loaded:', {
      blocksCount: sideBlocks.length,
      firstBlock: sideBlocks[0] ? {
        title: sideBlocks[0].title,
        filtersCount: sideBlocks[0].filters.length
      } : null
    });
  } catch (error: any) {
    console.error('[LocationFilterCard] Failed to load side block:', error);

    // Only show error for unexpected failures (not "pattern missing detail")
    if (!error.message?.includes('Pattern missing') && !error.message?.includes('Property type not found')) {
      hasError = true;
    }
  }
}

// Extract first block (we only show one block in this card)
const block = sideBlocks.length > 0 ? sideBlocks[0] : null;

// Hide card if:
// - Transaction-only URL (not supported by v1)
// - No block and no error
const shouldHideCard = shouldHideForTransactionOnly || (!hasError && !block);

// Helper: Check if item is active
function isActive(itemUrl: string): boolean {
  return url.pathname === itemUrl || url.pathname === itemUrl + '/';
}

// Helper: Preserve query params when building URL
function buildItemUrl(baseUrl: string): string {
  const searchParams = url.searchParams.toString();
  return searchParams ? `${baseUrl}?${searchParams}` : baseUrl;
}

const maxItems = 10;
const hasMoreItems = block ? block.filters.length > maxItems : false;
---

{!shouldHideCard && (
<div
  class="bg-white rounded-lg shadow-sm border border-secondary-100 p-4"
  data-location-filter-card
>
  {/* Block Title */}
  {block && (
    <h3 class="font-semibold text-secondary-900 mb-4 text-base text-center">
      {block.title}
    </h3>
  )}

  {/* Error state */}
  {hasError && (
    <div class="text-sm text-secondary-500 text-center py-4">
      Không thể tải danh sách khu vực
    </div>
  )}

  {/* Location list */}
  {!hasError && block && block.filters.length > 0 && (
    <div class="space-y-1">
      {block.filters.map((filter, idx) => (
      <div
        class:list={[
          'location-item',
          idx >= maxItems && 'hidden'
        ]}
      >
        <a
          href={buildItemUrl(filter.url)}
          class:list={[
            'flex items-center justify-between px-3 py-2 text-sm rounded-lg transition-all',
            isActive(filter.url)
              ? 'bg-primary-50 text-primary-600 font-medium border-l-2 border-primary-500'
              : 'text-secondary-800 hover:bg-secondary-50 hover:text-primary-600'
          ]}
        >
          <span class="truncate">{filter.title}</span>
        </a>
      </div>
      ))}
    </div>
  )}

  {/* Show More / Show Less */}
  {hasMoreItems && block && (
    <div class="mt-3 pt-3 border-t border-secondary-100">
      <button
        type="button"
        class="text-sm text-primary-600 hover:text-primary-700 flex items-center justify-center gap-1 font-medium w-full"
        data-location-show-more
      >
        <span>Xem thêm ({block.filters.length - maxItems})</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <button
        type="button"
        class="hidden text-sm text-primary-600 hover:text-primary-700 flex items-center justify-center gap-1 font-medium w-full"
        data-location-show-less
      >
        <span>Thu gọn</span>
        <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>
  )}

</div>
)}

<script>
  // Expand/collapse logic (client-side)
  function initLocationFilterCard() {
    const card = document.querySelector('[data-location-filter-card]');
    if (!card) return;

    const showMoreBtn = card.querySelector('[data-location-show-more]');
    const showLessBtn = card.querySelector('[data-location-show-less]');
    const items = card.querySelectorAll('.location-item');

    const maxItems = 10;

    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', () => {
        items.forEach(item => item.classList.remove('hidden'));
        showMoreBtn.classList.add('hidden');
        showLessBtn?.classList.remove('hidden');
      });
    }

    if (showLessBtn) {
      showLessBtn.addEventListener('click', () => {
        items.forEach((item, idx) => {
          if (idx >= maxItems) item.classList.add('hidden');
        });
        showLessBtn.classList.add('hidden');
        showMoreBtn?.classList.remove('hidden');

        // Smooth scroll to card top
        card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    }
  }

  // Initialize on load and View Transition
  initLocationFilterCard();
  document.addEventListener('astro:after-swap', initLocationFilterCard);
</script>
