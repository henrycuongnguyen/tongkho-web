---
/**
 * Province Selector Modal
 * Beautiful modal with featured provinces (with images) and full province list
 */
import type { Province } from '@/services/location/types';
import { getCityImageUrl } from '@/utils/s3-url-helper';

interface Props {
  /** List of all provinces */
  provinces: Province[];
  /** Featured provinces (top 5 with images) */
  featuredProvinces?: Province[];
  /** Base URL for navigation (e.g., /mua-ban) */
  baseUrl: string;
  /** Current selected province slug (optional) */
  currentProvince?: string;
}

const { provinces, featuredProvinces = [], baseUrl, currentProvince } = Astro.props;

// If no featured provinces provided, use first 5 provinces
const featured = featuredProvinces.length > 0 ? featuredProvinces : provinces.slice(0, 5);
---

<!-- Dropdown Panel -->
<div
  class="province-dropdown-panel absolute top-full left-0 mt-2 bg-white rounded-2xl shadow-2xl border border-secondary-100 w-full min-w-[970px] max-w-[970px] max-h-[600px] overflow-hidden hidden z-[99999] flex-col"
  data-province-dropdown-panel
  data-base-url={baseUrl}
  style="width: 970px; max-width: calc(100vw - 2rem);"
>
    <!-- Content (scrollable) -->
    <div class="overflow-y-auto flex-1 px-6 py-5">
      <!-- Header Row -->
      <div class="flex items-center justify-between mb-4">
        <h4 class="text-xl font-bold text-secondary-800">Top tỉnh thành nổi bật</h4>
        <div class="flex items-center gap-4">
          <!-- Checkbox for new addresses -->
          <label class="flex items-center gap-2 text-sm text-secondary-600 cursor-pointer">
            <input
              type="checkbox"
              class="w-4 h-4 rounded border-secondary-300 text-primary-600 focus:ring-primary-500"
              data-new-address-toggle
            />
            <span>Sử dụng địa chỉ hành chính mới</span>
          </label>
          <!-- Clear selection button -->
          <button
            type="button"
            class="text-sm text-primary-600 hover:text-primary-700 font-medium"
            data-clear-selection
          >
            Xóa lựa chọn
          </button>
        </div>
      </div>

      <!-- Featured Provinces -->
      <div class="mb-6">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
          {featured.map((province) => (
            <button
              type="button"
              class:list={[
                'featured-province-card group relative rounded-xl overflow-hidden cursor-pointer transition-all duration-300',
                'hover:shadow-lg hover:-translate-y-1',
                province.slug === currentProvince
                  ? 'ring-2 ring-primary-500'
                  : 'ring-1 ring-secondary-200 hover:ring-primary-300'
              ]}
              data-province-slug={province.slug}
              data-province-nid={province.nId}
              data-province-name={province.name}
            >
              <!-- Image -->
              <div class="aspect-[4/3] bg-secondary-100 relative overflow-hidden">
                <img
                  src={getCityImageUrl(province.cityImageWeb, province.cityImage)}
                  alt={province.name}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                  onerror="this.src='https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=400&h=300&fit=crop'"
                />
                <!-- Gradient overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
              </div>

              <!-- Name -->
              <div class="absolute bottom-0 left-0 right-0 p-3">
                <h5 class="font-semibold text-white text-sm line-clamp-2 group-hover:text-primary-200 transition-colors">
                  {province.name}
                </h5>
                {province.districtCount > 0 && (
                  <p class="text-white/80 text-xs mt-1">
                    {province.districtCount} quận/huyện
                  </p>
                )}
              </div>
            </button>
          ))}
        </div>
      </div>

      <!-- All Provinces -->
      <div>
        <h4 class="text-xl font-bold text-secondary-800 mb-4">Tất cả tỉnh thành</h4>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-2">
          {provinces.map((province) => (
            <button
              type="button"
              class:list={[
                'province-item text-left text-sm py-2 px-3 rounded-lg transition-all duration-150',
                province.slug === currentProvince
                  ? 'bg-primary-50 text-primary-600 font-semibold'
                  : 'text-secondary-700 hover:bg-secondary-50 hover:text-primary-600'
              ]}
              data-province-slug={province.slug}
              data-province-nid={province.nId}
              data-province-name={province.name}
            >
              {province.name}
              {province.districtCount > 0 && (
                <span class="text-secondary-400 text-xs ml-1">({province.districtCount})</span>
              )}
            </button>
          ))}
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  /**
   * Province Dropdown Panel Logic
   */
  function initProvinceDropdown() {
    const panel = document.querySelector('[data-province-dropdown-panel]') as HTMLDivElement;
    if (!panel) {
      console.error('[province-modal] Panel not found!');
      return;
    }

    const clearBtn = panel.querySelector('[data-clear-selection]') as HTMLButtonElement;
    const provinceButtons = panel.querySelectorAll('[data-province-slug]') as NodeListOf<HTMLButtonElement>;

    // Unique ID for this dropdown
    const dropdownId = 'province-selector-modal';

    // Close dropdown function
    function closeDropdown() {
      panel.classList.add('hidden');
      panel.classList.remove('flex');

      // Notify dropdown manager
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(dropdownId);
      }
    }

    // Open dropdown function
    function openDropdown() {
      // Notify dropdown manager to close other dropdowns
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.open(dropdownId);
      }

      panel.classList.remove('hidden');
      panel.classList.add('flex');
    }

    // Register with dropdown manager
    if (typeof (window as any).dropdownManager !== 'undefined') {
      (window as any).dropdownManager.register(dropdownId, closeDropdown);
    }

    // Export functions to global scope
    (window as any).openProvinceDropdown = openDropdown;
    (window as any).closeProvinceDropdown = closeDropdown;

    // Close on outside click
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const trigger = document.querySelector('[data-location-trigger]');

      if (!panel.contains(target) && !trigger?.contains(target)) {
        closeDropdown();
      }
    });

    // ESC key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) {
        closeDropdown();
      }
    });

    // Province selection - save state and close modal
    provinceButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const provinceSlug = btn.dataset.provinceSlug || '';
        const provinceName = btn.dataset.provinceName || '';
        const provinceNId = btn.dataset.provinceNid || '';

        if (provinceSlug && provinceNId) {
          // Save to sessionStorage for current tab
          sessionStorage.setItem('selected-province', JSON.stringify({
            slug: provinceSlug,
            name: provinceName,
            nId: provinceNId
          }));

          // Dispatch event to notify location-selector
          const event = new CustomEvent('province-selected', {
            detail: { slug: provinceSlug, name: provinceName, nId: provinceNId }
          });
          document.dispatchEvent(event);

          // Update province display in button
          const provinceDisplay = document.querySelector('[data-province-display]');
          if (provinceDisplay) {
            provinceDisplay.textContent = provinceName;
          }

          // Close modal
          closeDropdown();
        } else {
          console.error('[province-modal] Missing province data - slug:', provinceSlug, 'nId:', provinceNId);
        }
      });
    });

    // Clear selection
    clearBtn?.addEventListener('click', () => {
      const baseUrl = panel.getAttribute('data-base-url') || '/mua-ban';
      closeDropdown();
      window.location.href = baseUrl;
    });

    // New address toggle (future enhancement)
    const newAddressToggle = panel.querySelector('[data-new-address-toggle]') as HTMLInputElement;
    newAddressToggle?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      // TODO: Implement new address filtering
    });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProvinceDropdown);
  } else {
    initProvinceDropdown();
  }

  // Run on Astro View Transitions
  document.addEventListener('astro:page-load', initProvinceDropdown);
</script>

<style>
  /* Smooth scrollbar */
  .province-dropdown-panel {
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--color-secondary-300)) transparent;
  }

  .province-dropdown-panel::-webkit-scrollbar {
    width: 6px;
  }

  .province-dropdown-panel::-webkit-scrollbar-track {
    background: transparent;
  }

  .province-dropdown-panel::-webkit-scrollbar-thumb {
    background-color: rgb(var(--color-secondary-300));
    border-radius: 3px;
  }
</style>
