---
/**
 * Location Selector Component
 * Two-column: Province dropdown (left) + District list (right)
 * Plus search autocomplete below
 */
import LocationAutocomplete from '../location-autocomplete.astro';
import type { Province } from '@/services/location/types';

interface Props {
  /** List of all provinces */
  provinces: Province[];
  /** Base URL for navigation (e.g., /mua-ban) */
  baseUrl: string;
  /** Current selected province slug (optional) */
  currentProvince?: string;
  /** Selected locations for multi-select (optional) */
  selectedLocations?: Array<{ nId: string; name: string; slug: string; type: string }>;
}

const { provinces, baseUrl, currentProvince, selectedLocations = [] } = Astro.props;

// Find current province nId for fetching districts
const selectedProvince = currentProvince
  ? provinces.find(p => p.slug === currentProvince)
  : null;
---

<div class="location-selector" data-location-selector data-base-url={baseUrl}>
  <!-- Province Dropdown + District Panel -->
  <div class="grid grid-cols-2 gap-2 mb-3">
    <!-- Province Dropdown -->
    <div class="relative">
      <button
        type="button"
        class="w-full px-3 py-2.5 border border-secondary-200 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-1 hover:border-secondary-300 transition-colors"
        data-province-trigger
      >
        <span class="truncate text-secondary-700" data-province-display>
          {selectedProvince ? selectedProvince.name : 'Chọn tỉnh'}
        </span>
        <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-province-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <!-- Province Panel -->
      <div
        class="absolute top-full left-0 mt-1 w-full bg-white rounded-lg shadow-xl border border-secondary-100 z-50 hidden max-h-64 overflow-y-auto"
        data-province-panel
      >
        <button
          type="button"
          class="province-item w-full text-left px-3 py-2 text-sm text-primary-600 font-medium hover:bg-primary-50 border-b border-secondary-100"
          data-province-nid=""
          data-province-slug=""
          data-province-name="Tất cả tỉnh thành"
        >
          Tất cả tỉnh thành
        </button>
        {provinces.map((province) => (
          <button
            type="button"
            class:list={[
              'province-item w-full text-left px-3 py-2 text-sm hover:bg-secondary-50 transition-colors',
              province.slug === currentProvince
                ? 'bg-primary-50 text-primary-600 font-medium'
                : 'text-secondary-700'
            ]}
            data-province-nid={province.nId}
            data-province-slug={province.slug}
            data-province-name={province.name}
          >
            {province.name}
            {province.districtCount > 0 && (
              <span class="text-secondary-400 text-xs ml-1">({province.districtCount})</span>
            )}
          </button>
        ))}
      </div>
    </div>

    <!-- District Panel (loads via HTMX) -->
    <div class="relative">
      <div
        class="w-full h-full min-h-[42px] px-3 py-2.5 border border-secondary-200 rounded-lg bg-secondary-50 text-sm text-secondary-500 overflow-y-auto max-h-40"
        data-district-panel
        hx-get={selectedProvince ? `/api/location/districts?province=${selectedProvince.nId}&base=${baseUrl}` : undefined}
        hx-trigger={selectedProvince ? 'load once' : undefined}
        hx-swap="innerHTML"
      >
        {selectedProvince ? (
          <div class="flex items-center justify-center h-full">
            <svg class="w-4 h-4 animate-spin text-secondary-400" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </div>
        ) : (
          <span class="flex items-center justify-center h-full text-center">Chọn tỉnh để xem quận/huyện</span>
        )}
      </div>
    </div>
  </div>

  <!-- Search Autocomplete -->
  <LocationAutocomplete
    placeholder="Hoặc tìm kiếm địa điểm..."
    baseUrl={baseUrl}
    selectedLocations={selectedLocations}
  />
</div>

<script>
  document.querySelectorAll('[data-location-selector]').forEach((container) => {
    const baseUrl = container.getAttribute('data-base-url') || '/mua-ban';

    const provinceTrigger = container.querySelector('[data-province-trigger]') as HTMLButtonElement;
    const provincePanel = container.querySelector('[data-province-panel]') as HTMLDivElement;
    const provinceArrow = container.querySelector('[data-province-arrow]') as SVGElement;
    const provinceDisplay = container.querySelector('[data-province-display]') as HTMLSpanElement;
    const districtPanel = container.querySelector('[data-district-panel]') as HTMLDivElement;
    const provinceItems = container.querySelectorAll('.province-item') as NodeListOf<HTMLButtonElement>;

    let isOpen = false;

    // Toggle province dropdown
    provinceTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isOpen = !isOpen;
      provincePanel.classList.toggle('hidden', !isOpen);
      provinceArrow.classList.toggle('rotate-180', isOpen);
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!container.contains(e.target as Node)) {
        isOpen = false;
        provincePanel.classList.add('hidden');
        provinceArrow.classList.remove('rotate-180');
      }
    });

    // Province selection
    provinceItems.forEach((item) => {
      item.addEventListener('click', () => {
        const nId = item.dataset.provinceNid || '';
        const name = item.dataset.provinceName || 'Chọn tỉnh';

        // Update display
        provinceDisplay.textContent = name;

        // Close dropdown
        isOpen = false;
        provincePanel.classList.add('hidden');
        provinceArrow.classList.remove('rotate-180');

        // Update all items styling
        provinceItems.forEach(p => {
          p.classList.remove('bg-primary-50', 'text-primary-600', 'font-medium');
          p.classList.add('text-secondary-700');
        });
        item.classList.add('bg-primary-50', 'text-primary-600', 'font-medium');
        item.classList.remove('text-secondary-700');

        if (nId) {
          // Get province slug for navigation
          const provinceSlug = item.dataset.provinceSlug || '';

          if (provinceSlug) {
            // Navigate to province-filtered URL
            const targetUrl = `${baseUrl}/${provinceSlug}`;
            const currentUrl = window.location.pathname;

            // Check if already on this province to avoid unnecessary reload
            if (currentUrl !== targetUrl) {
              // Navigate to province page - districts will auto-load via hx-trigger="load once"
              window.location.href = targetUrl;
            } else {
              // Already on this province page - just refresh districts
              districtPanel.innerHTML = `
                <div class="flex items-center justify-center h-full">
                  <svg class="w-4 h-4 animate-spin text-secondary-400" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                </div>
              `;

              // Use HTMX to fetch districts
              // @ts-ignore - htmx is loaded globally
              if (window.htmx) {
                // @ts-ignore
                window.htmx.ajax('GET', `/api/location/districts?province=${nId}&base=${baseUrl}`, {
                  target: districtPanel,
                  swap: 'innerHTML'
                });
              } else {
                // Fallback: fetch manually
                fetch(`/api/location/districts?province=${nId}&base=${baseUrl}`)
                  .then(res => res.text())
                  .then(html => {
                    districtPanel.innerHTML = html;
                  });
              }
            }
          } else {
            // No slug - just load districts without navigation
            districtPanel.innerHTML = `
              <div class="flex items-center justify-center h-full">
                <svg class="w-4 h-4 animate-spin text-secondary-400" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
              </div>
            `;

            // @ts-ignore
            if (window.htmx) {
              // @ts-ignore
              window.htmx.ajax('GET', `/api/location/districts?province=${nId}&base=${baseUrl}`, {
                target: districtPanel,
                swap: 'innerHTML'
              });
            } else {
              fetch(`/api/location/districts?province=${nId}&base=${baseUrl}`)
                .then(res => res.text())
                .then(html => {
                  districtPanel.innerHTML = html;
                });
            }
          }
        } else {
          // Reset - navigate to base URL
          districtPanel.innerHTML = `<span class="flex items-center justify-center h-full text-center text-secondary-500">Chọn tỉnh để xem quận/huyện</span>`;
          // Check if already on base URL to prevent unnecessary reload
          const currentUrl = window.location.pathname + window.location.search;
          if (currentUrl !== baseUrl) {
            window.location.href = baseUrl;
          }
        }
      });
    });
  });
</script>

<style>
  [data-district-panel] {
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--color-secondary-300)) transparent;
  }
</style>
