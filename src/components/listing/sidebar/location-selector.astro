---
/**
 * Location Selector Component
 * Two-column: Province dropdown (left) + District list (right)
 * Plus search autocomplete below
 * Now with beautiful modal for province selection!
 */
import LocationAutocomplete from '../location-autocomplete.astro';
import ProvinceModal from './province-selector-modal.astro';
import type { Province } from '@/services/location/types';

interface Props {
  /** List of all provinces */
  provinces: Province[];
  /** Base URL for navigation (e.g., /mua-ban) */
  baseUrl: string;
  /** Current selected province slug (optional) */
  currentProvince?: string;
  /** Current selected district slugs (optional, supports multi-select) */
  currentDistricts?: string[];
  /** Selected locations (supports multi-location) */
  selectedLocations?: Array<{ nId: string; name: string; slug: string; type: string }>;
}

const { provinces, baseUrl, currentProvince, currentDistricts = [], selectedLocations = [] } = Astro.props;

// Find current province nId for fetching districts
const selectedProvince = currentProvince
  ? provinces.find(p => p.slug === currentProvince)
  : null;

// Get featured provinces (top 5 with images, ordered by display_order)
const featuredProvinces = provinces.filter(p => p.cityImageWeb || p.cityImage).slice(0, 5);
---

<div
  class="location-selector"
  data-location-selector
  data-base-url={baseUrl}
  data-current-province={currentProvince || ''}
  data-current-province-nid={selectedProvince?.nId || ''}
  data-current-province-name={selectedProvince?.name || ''}
>
  <!-- Province Button -->
  <div class="relative mb-3">
    <button
      type="button"
      class="w-full px-3 py-2.5 border border-secondary-200 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-1 hover:border-primary-300 hover:border-2 transition-all"
      data-province-modal-trigger
    >
      <span class="truncate text-secondary-700" data-province-display>
        {selectedProvince ? selectedProvince.name : 'Chọn tỉnh'}
      </span>
      <svg class="w-4 h-4 text-secondary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </button>

    <!-- Province Modal -->
    <ProvinceModal
      provinces={provinces}
      featuredProvinces={featuredProvinces}
      baseUrl={baseUrl}
      currentProvince={currentProvince}
    />
  </div>

  <!-- Selected Districts (Tags) -->
  <div class="mb-3 hidden" data-selected-districts-container>
    <div class="flex items-center justify-between mb-2">
      <span class="text-sm font-medium text-secondary-700">Địa điểm đã chọn</span>
      <button
        type="button"
        class="text-xs text-primary-600 hover:text-primary-700 font-medium"
        data-clear-all-districts
      >
        Xóa lựa chọn
      </button>
    </div>
    <div class="flex flex-wrap gap-2" data-selected-districts-tags>
      <!-- Tags will be inserted here by JavaScript -->
    </div>
  </div>

  <!-- Search Input with District Dropdown -->
  <div class="relative">
    <input
      type="text"
      placeholder="Tìm kiếm quận/huyện..."
      class="w-full px-4 py-2.5 pr-10 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent"
      data-district-search-input
      autocomplete="off"
    />

    <!-- Search Icon -->
    <div class="absolute right-3 top-1/2 -translate-y-1/2">
      <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </div>

    <!-- District Dropdown (shown on focus) -->
    <div
      id="district-dropdown"
      class="absolute z-50 w-full mt-1 bg-white border border-slate-200 rounded-lg shadow-lg max-h-80 overflow-auto hidden"
      data-district-dropdown
    >
      <!-- Header -->
      <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
        <div class="flex items-center justify-between">
          <h5 class="font-semibold text-sm text-slate-800">
            Quận/Huyện tại <span data-province-name-display>{selectedProvince?.name || 'chọn tỉnh'}</span>
          </h5>
          <button
            type="button"
            class="text-xs text-primary-600 hover:text-primary-700 font-medium"
            data-search-all-province
          >
            <span data-search-button-text>Tìm toàn tỉnh</span>
          </button>
        </div>
      </div>

      <!-- District List -->
      <div
        class="p-2"
        data-district-list-container
        hx-get={selectedProvince ? `/api/location/districts?province=${selectedProvince.nId}&base=${baseUrl}&mode=checkboxes&selected=${currentDistricts.join(',')}` : undefined}
        hx-trigger="load once, loadDistricts"
        hx-swap="innerHTML"
      >
        {selectedProvince ? (
          <div class="p-4 text-center text-slate-500 text-sm">
            <svg class="w-5 h-5 animate-spin mx-auto mb-2 text-primary-500" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            Đang tải...
          </div>
        ) : (
          <div class="p-4 text-center text-slate-500 text-sm">
            Vui lòng chọn tỉnh trước
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<script>
  /**
   * Initialize location selector - runs on page load and after View Transitions
   * Now uses modal instead of dropdown for province selection
   */
  function initLocationSelectors() {
    document.querySelectorAll('[data-location-selector]').forEach(initContainer);
  }

  function initContainer(container: Element) {
    // Skip if already initialized (prevent duplicate listeners)
    if (container.getAttribute('data-initialized')) return;
    container.setAttribute('data-initialized', 'true');

    const baseUrl = container.getAttribute('data-base-url') || '/mua-ban';
    let currentProvinceNId = container.getAttribute('data-current-province-nid') || '';
    let currentProvinceName = container.getAttribute('data-current-province-name') || '';

    // Multi-select state: { slug: string, name: string }[]
    const selectedDistricts: Array<{ slug: string; name: string }> = [];

    const provinceModalTrigger = container.querySelector('[data-province-modal-trigger]') as HTMLButtonElement;
    const districtSearchInput = container.querySelector('[data-district-search-input]') as HTMLInputElement;
    const districtDropdown = container.querySelector('[data-district-dropdown]') as HTMLDivElement;
    const districtListContainer = container.querySelector('[data-district-list-container]') as HTMLDivElement;
    const provinceDisplay = container.querySelector('[data-province-display]') as HTMLSpanElement;
    const provinceNameDisplay = container.querySelector('[data-province-name-display]') as HTMLSpanElement;
    const searchAllProvinceBtn = container.querySelector('[data-search-all-province]') as HTMLButtonElement;
    const selectedDistrictsContainer = container.querySelector('[data-selected-districts-container]') as HTMLDivElement;
    const selectedDistrictsTags = container.querySelector('[data-selected-districts-tags]') as HTMLDivElement;
    const clearAllDistrictsBtn = container.querySelector('[data-clear-all-districts]') as HTMLButtonElement;
    const searchButtonText = container.querySelector('[data-search-button-text]') as HTMLSpanElement;

    // Early return if required elements missing
    if (!provinceModalTrigger) {
      console.warn('[location-selector] Missing province modal trigger');
      return;
    }

    // Update search button text based on selection
    function updateSearchButtonText() {
      if (!searchButtonText) return;

      if (selectedDistricts.length > 0) {
        searchButtonText.textContent = 'Tìm kiếm';
      } else {
        searchButtonText.textContent = 'Tìm toàn tỉnh';
      }
    }

    // Render selected districts tags
    function renderSelectedDistrictsTags() {
      if (!selectedDistrictsTags || !selectedDistrictsContainer) return;

      if (selectedDistricts.length === 0) {
        selectedDistrictsContainer.classList.add('hidden');
        updateSearchButtonText();
        return;
      }

      selectedDistrictsContainer.classList.remove('hidden');
      updateSearchButtonText();
      selectedDistrictsTags.innerHTML = selectedDistricts.map(d => `
        <div class="flex items-center gap-1.5 px-3 py-1.5 bg-primary-50 text-primary-700 rounded-lg text-sm border border-primary-200">
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="font-medium">${d.name}</span>
          <button
            type="button"
            class="ml-1 hover:bg-primary-100 rounded p-0.5 transition-colors"
            data-remove-district="${d.slug}"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      `).join('');

      // Attach remove handlers
      selectedDistrictsTags.querySelectorAll('[data-remove-district]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const slug = (btn as HTMLElement).dataset.removeDistrict || '';
          const index = selectedDistricts.findIndex(d => d.slug === slug);
          if (index > -1) {
            selectedDistricts.splice(index, 1);
            renderSelectedDistrictsTags();
            updateCheckboxesState();
          }
        });
      });
    }

    // Update checkboxes state to match selectedDistricts
    function updateCheckboxesState() {
      const checkboxes = districtListContainer?.querySelectorAll('input[type="checkbox"]') as NodeListOf<HTMLInputElement>;
      checkboxes.forEach(checkbox => {
        const isSelected = selectedDistricts.some(d => d.slug === checkbox.value);
        checkbox.checked = isSelected;
      });
    }

    // Attach checkbox handlers after initial HTMX load
    function attachCheckboxHandlers() {
      const checkboxes = districtListContainer.querySelectorAll('input[type="checkbox"]') as NodeListOf<HTMLInputElement>;
      checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', () => {
          const slug = checkbox.value;
          const name = checkbox.dataset.name || slug;
          const isChecked = checkbox.checked;

          if (isChecked) {
            if (!selectedDistricts.some(d => d.slug === slug)) {
              selectedDistricts.push({ slug, name });
            }
          } else {
            const index = selectedDistricts.findIndex(d => d.slug === slug);
            if (index > -1) {
              selectedDistricts.splice(index, 1);
            }
          }

          renderSelectedDistrictsTags();
        });
      });
    }

    // If province already selected on page load, attach handlers after HTMX loads districts
    if (currentProvinceNId && districtListContainer) {
      districtListContainer.addEventListener('htmx:afterSwap', () => {
        attachCheckboxHandlers();
      }, { once: true });
    }

    // Toggle province modal on click
    provinceModalTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const panel = document.querySelector('[data-province-dropdown-panel]');
      if (!panel) {
        console.error('[location-selector] Province panel not found');
        return;
      }

      const isHidden = panel.classList.contains('hidden');

      if (isHidden) {
        if (typeof (window as any).openProvinceDropdown === 'function') {
          (window as any).openProvinceDropdown();
        } else {
          console.error('[location-selector] openProvinceDropdown function not found');
        }
      } else {
        if (typeof (window as any).closeProvinceDropdown === 'function') {
          (window as any).closeProvinceDropdown();
        } else {
          console.error('[location-selector] closeProvinceDropdown function not found');
        }
      }
    });

    // Show district dropdown on focus
    districtSearchInput?.addEventListener('focus', () => {
      if (currentProvinceNId) {
        districtDropdown?.classList.remove('hidden');
      } else {
        console.warn('[location-selector] No province selected, cannot show districts');
      }
    });

    // Search districts on input (now works with checkbox labels)
    districtSearchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();
      const districtLabels = districtListContainer?.querySelectorAll('label');

      districtLabels?.forEach(label => {
        const text = label.textContent?.toLowerCase() || '';
        if (text.includes(query)) {
          label.classList.remove('hidden');
        } else {
          label.classList.add('hidden');
        }
      });
    });

    // "Tìm toàn tỉnh" button - includes all selected districts (v1 compatible)
    searchAllProvinceBtn?.addEventListener('click', () => {
      const provinceSlug = container.getAttribute('data-current-province') || '';
      if (!provinceSlug) return;

      // Get current URL params to preserve other filters
      const currentParams = new URLSearchParams(window.location.search);

      // Extract price slug from current URL path (arg3)
      const pathParts = window.location.pathname.split('/').filter(Boolean);
      let priceSlug = '';
      // Price slug is arg3 (index 2): /[transaction]/[location]/[price-slug]
      if (pathParts.length >= 3 && pathParts[2].startsWith('gia-')) {
        priceSlug = pathParts[2];
      }

      // Build URL path: /[transaction]/[province]/[price-slug?]
      const urlParts: string[] = [baseUrl.replace(/^\//, '')];
      urlParts.push(provinceSlug);
      if (priceSlug) {
        urlParts.push(priceSlug);
      }

      let targetUrl = '/' + urlParts.join('/');

      // Build query string manually to avoid encoding commas (v1 compatible)
      const queryParts: string[] = [];

      // Add addresses param if districts selected (v1 uses plain commas)
      if (selectedDistricts.length > 0) {
        const districtSlugs = selectedDistricts.map(d => d.slug).join(',');
        queryParts.push(`addresses=${districtSlugs}`);
      }

      // Add property_types WITHOUT encoding (v1 uses plain commas)
      const propertyTypesParam = currentParams.get('property_types');
      if (propertyTypesParam) {
        queryParts.push(`property_types=${propertyTypesParam}`);
      }

      // Preserve other current params (bedrooms, bathrooms, dtnn, dtcn, etc.)
      // Skip 'addresses' and 'property_types' as we're handling them above
      currentParams.forEach((value, key) => {
        if (key !== 'addresses' && key !== 'property_types') {
          queryParts.push(`${key}=${value}`);
        }
      });

      if (queryParts.length > 0) {
        targetUrl = `${targetUrl}?${queryParts.join('&')}`;
      }

      window.location.href = targetUrl;
    });

    // Clear all districts button
    clearAllDistrictsBtn?.addEventListener('click', () => {
      selectedDistricts.length = 0; // Clear array
      renderSelectedDistrictsTags();
      updateCheckboxesState();
    });

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!container.contains(target)) {
        districtDropdown?.classList.add('hidden');
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        districtDropdown?.classList.add('hidden');
      }
    });

    // Listen for province selection
    document.addEventListener('province-selected', ((e: CustomEvent) => {
      const { slug, name, nId } = e.detail;

      // Update state
      currentProvinceNId = nId;
      currentProvinceName = name;
      container.setAttribute('data-current-province', slug);
      container.setAttribute('data-current-province-nid', nId);
      container.setAttribute('data-current-province-name', name);


      // Update both province displays
      if (provinceDisplay) {
        provinceDisplay.textContent = name;
      }
      if (provinceNameDisplay) {
        provinceNameDisplay.textContent = name;
      }

      // Load districts (with checkbox mode)
      if (districtListContainer && nId) {
        const selectedSlugs = selectedDistricts.map(d => d.slug).join(',');
        const url = `/api/location/districts?province=${encodeURIComponent(nId)}&base=${encodeURIComponent(baseUrl)}&mode=checkboxes&selected=${encodeURIComponent(selectedSlugs)}`;
        districtListContainer.setAttribute('hx-get', url);

        // Listen for HTMX swap completion (one-time listener)
        const handleSwap = () => {
          attachCheckboxHandlers();

          // Show dropdown after districts are loaded
          districtDropdown?.classList.remove('hidden');

          // Focus input
          if (districtSearchInput) {
            districtSearchInput.value = '';
            setTimeout(() => districtSearchInput.focus(), 100);
          }
        };

        districtListContainer.addEventListener('htmx:afterSwap', handleSwap, { once: true });

        // Trigger custom HTMX event to load districts
        if (typeof (window as any).htmx !== 'undefined') {
          (window as any).htmx.process(districtListContainer);
          (window as any).htmx.trigger(districtListContainer, 'loadDistricts');
        }
      }
    }) as EventListener);

    // Cleanup on before-swap (View Transition about to happen)
    document.addEventListener('astro:before-swap', () => {
      container.removeAttribute('data-initialized');
    }, { once: true });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLocationSelectors);
  } else {
    initLocationSelectors();
  }

  // Run on Astro View Transitions
  document.addEventListener('astro:page-load', initLocationSelectors);
</script>

<style>
  [data-district-panel] {
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--color-secondary-300)) transparent;
  }
</style>
