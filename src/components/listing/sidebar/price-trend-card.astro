---
/**
 * Price Trend Card (Sidebar)
 * Shows price change percentage with scroll-to-chart button
 * Matches V1 price-trend-box pattern
 */
interface Props {
  changePercent?: string;
  trendDirection?: 'up' | 'down' | 'stable';
  propertyType?: string;
  location?: string;
}

const {
  changePercent,
  trendDirection = 'stable',
  propertyType = 'BĐS',
  location = 'khu vực này',
} = Astro.props;

const isUp = trendDirection === 'up';
const isDown = trendDirection === 'down';
---

<div
  class="bg-amber-50 border border-amber-400 rounded-lg p-4 mb-4"
  id="price-trend-card"
>
  <div class="flex items-center justify-between mb-3">
    <!-- Chart Icon -->
    <div class="flex-shrink-0">
      <svg
        class="w-12 h-12 text-amber-500"
        viewBox="0 0 48 48"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <rect x="8" y="20" width="6" height="20" rx="1" fill="currentColor" opacity="0.6" />
        <rect x="21" y="12" width="6" height="28" rx="1" fill="currentColor" opacity="0.8" />
        <rect x="34" y="4" width="6" height="36" rx="1" fill="currentColor" />
      </svg>
    </div>

    <!-- Percentage Display -->
    <div class="flex items-center gap-2">
      {isUp && (
        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-green-500 text-white">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <path d="M7 17L17 7M17 7H7M17 7V17" />
          </svg>
        </span>
      )}
      {isDown && (
        <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-red-500 text-white">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <path d="M7 7L17 17M17 17H7M17 17V7" />
          </svg>
        </span>
      )}
      <span
        class:list={[
          'text-lg font-bold',
          isUp ? 'text-green-600' : isDown ? 'text-red-600' : 'text-slate-600',
        ]}
        id="price-trend-percent"
      >
        {changePercent || '—'}
      </span>
    </div>
  </div>

  <!-- Description -->
  <p class="text-sm text-slate-700 mb-3">
    Giá {propertyType} tại <span class="font-medium">{location}</span> đã thay đổi trong 2 năm qua
  </p>

  <!-- Scroll Button -->
  <button
    type="button"
    class="inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-amber-600 border border-amber-400 rounded-md hover:bg-amber-100 transition-colors"
    id="scroll-to-price-history"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
      <rect x="4" y="10" width="3" height="10" rx="0.5" />
      <rect x="10.5" y="6" width="3" height="14" rx="0.5" />
      <rect x="17" y="2" width="3" height="18" rx="0.5" />
    </svg>
    Xem lịch sử giá
  </button>
</div>

<script is:inline>
(function() {
  var scrollBtn = document.getElementById('scroll-to-price-history');
  var priceSection = document.getElementById('price-history-section');

  if (scrollBtn && priceSection) {
    scrollBtn.addEventListener('click', function() {
      priceSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }
})();
</script>
