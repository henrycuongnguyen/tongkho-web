---
/**
 * Dynamic Sidebar Filters
 * Context-aware filter blocks based on current URL
 */
import type { SidebarFilterBlock } from '@/services/sidebar-filter-service';

interface Props {
  blocks: SidebarFilterBlock[];
}

const { blocks } = Astro.props;

const ITEMS_VISIBLE = 20;
---

{blocks.length > 0 && blocks.map((block) => (
  <div class="bg-white rounded-lg shadow-sm border border-secondary-100 p-4" data-filter-block={block.id}>
    <h3 class="font-semibold text-secondary-800 mb-3 text-base">{block.title}</h3>

    <ul class="space-y-1">
      {block.filters.map((filter, idx) => (
        <li
          class:list={[
            'filter-item',
            idx >= ITEMS_VISIBLE && 'hidden'
          ]}
        >
          <a
            href={filter.url}
            class="block px-3 py-2.5 text-sm text-secondary-700 hover:bg-secondary-50 hover:text-primary-600 rounded-lg transition-all"
          >
            {filter.title}
            {filter.count !== undefined && (
              <span class="text-secondary-400 ml-1">({filter.count})</span>
            )}
          </a>
        </li>
      ))}
    </ul>

    {/* Show More / Show Less buttons */}
    {block.filters.length > ITEMS_VISIBLE && (
      <div class="mt-3 pt-3 border-t border-secondary-100">
        <button
          type="button"
          class="show-more-btn text-sm text-primary-600 hover:text-primary-700 flex items-center gap-1 font-medium"
          data-target={block.id}
        >
          <span>Xem thêm ({block.filters.length - ITEMS_VISIBLE})</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <button
          type="button"
          class="show-less-btn hidden text-sm text-primary-600 hover:text-primary-700 flex items-center gap-1 font-medium"
          data-target={block.id}
        >
          <span>Thu gọn</span>
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>
    )}
  </div>
))}

<script>
  // Expand/collapse logic for filter blocks
  document.querySelectorAll('.show-more-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-target');
      const block = document.querySelector(`[data-filter-block="${target}"]`);
      if (!block) return;

      // Show all items
      block.querySelectorAll('.filter-item.hidden').forEach(item => {
        item.classList.remove('hidden');
      });

      // Toggle buttons
      btn.classList.add('hidden');
      block.querySelector('.show-less-btn')?.classList.remove('hidden');
    });
  });

  document.querySelectorAll('.show-less-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-target');
      const block = document.querySelector(`[data-filter-block="${target}"]`);
      if (!block) return;

      // Hide items after 20
      const items = block.querySelectorAll('.filter-item');
      items.forEach((item, idx) => {
        if (idx >= 20) {
          item.classList.add('hidden');
        }
      });

      // Toggle buttons
      btn.classList.add('hidden');
      block.querySelector('.show-more-btn')?.classList.remove('hidden');
    });
  });
</script>
