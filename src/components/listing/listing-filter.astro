---
/**
 * Listing Filter Component (Astro + HTMX)
 * SSG/SSR filter form with URL-based navigation
 */
import LocationAutocomplete from './location-autocomplete.astro';

interface PropertyType {
  id: number;
  title: string;
  slug: string;
}

interface Props {
  /** Current transaction type (1=sale, 2=rent, 3=project) */
  transactionType: number;
  /** Available property types for this transaction */
  propertyTypes: PropertyType[];
  /** Current filter values from URL */
  currentFilters: {
    propertyTypes?: number[];
    minPrice?: string;
    maxPrice?: string;
    minArea?: string;
    maxArea?: string;
    bedrooms?: string;
    bathrooms?: string;
  };
  /** Current URL path */
  currentPath: string;
}

const { transactionType, propertyTypes, currentFilters, currentPath } = Astro.props;

// Transaction type to base URL mapping
const TRANSACTION_BASE_URLS: Record<number, string> = {
  1: '/mua-ban',
  2: '/cho-thue',
  3: '/du-an',
};

const baseUrl = TRANSACTION_BASE_URLS[transactionType] || '/mua-ban';

// Price presets (in VND)
const PRICE_PRESETS = [
  { label: 'Tất cả mức giá', min: '', max: '', slug: '' },
  { label: 'Dưới 500 triệu', min: '', max: '500000000', slug: 'gia-duoi-500-trieu' },
  { label: '500 - 800 triệu', min: '500000000', max: '800000000', slug: 'gia-tu-500-den-800-trieu' },
  { label: '800 triệu - 1 tỷ', min: '800000000', max: '1000000000', slug: 'gia-tu-800-trieu-den-1-ty' },
  { label: '1 - 2 tỷ', min: '1000000000', max: '2000000000', slug: 'gia-tu-1-den-2-ty' },
  { label: '2 - 3 tỷ', min: '2000000000', max: '3000000000', slug: 'gia-tu-2-den-3-ty' },
  { label: '3 - 5 tỷ', min: '3000000000', max: '5000000000', slug: 'gia-tu-3-den-5-ty' },
  { label: '5 - 10 tỷ', min: '5000000000', max: '10000000000', slug: 'gia-tu-5-den-10-ty' },
  { label: 'Trên 10 tỷ', min: '10000000000', max: '', slug: 'gia-tren-10-ty' },
];

// Area presets (in m²)
const AREA_PRESETS = [
  { label: 'Tất cả diện tích', min: '', max: '', slug: '' },
  { label: 'Dưới 30 m²', min: '', max: '30', slug: 'dien-tich-duoi-30m2' },
  { label: '30 - 50 m²', min: '30', max: '50', slug: 'dien-tich-30-50m2' },
  { label: '50 - 80 m²', min: '50', max: '80', slug: 'dien-tich-50-80m2' },
  { label: '80 - 100 m²', min: '80', max: '100', slug: 'dien-tich-80-100m2' },
  { label: '100 - 150 m²', min: '100', max: '150', slug: 'dien-tich-100-150m2' },
  { label: '150 - 300 m²', min: '150', max: '300', slug: 'dien-tich-150-300m2' },
  { label: 'Trên 300 m²', min: '300', max: '', slug: 'dien-tich-tren-300m2' },
];

// Room options
const ROOM_OPTIONS = ['1', '2', '3', '4', '5+'];

// Check if preset is active
const isPriceActive = (preset: typeof PRICE_PRESETS[0]) =>
  currentFilters.minPrice === preset.min && currentFilters.maxPrice === preset.max;

const isAreaActive = (preset: typeof AREA_PRESETS[0]) =>
  currentFilters.minArea === preset.min && currentFilters.maxArea === preset.max;

const isPropertyTypeActive = (id: number) =>
  currentFilters.propertyTypes?.includes(id) ?? false;

// Build URL with filters
function buildFilterUrl(params: Record<string, string | undefined>): string {
  const searchParams = new URLSearchParams();
  for (const [key, value] of Object.entries(params)) {
    if (value) searchParams.set(key, value);
  }
  const query = searchParams.toString();
  return query ? `${currentPath}?${query}` : currentPath;
}
---

<div class="bg-white rounded-lg shadow-sm p-4 mb-4">
  <div class="space-y-4">
    <!-- Location Search -->
    <div>
      <h3 class="text-sm font-medium text-slate-700 mb-2">Địa điểm</h3>
      <LocationAutocomplete
        placeholder="Tìm tỉnh, quận, phường, dự án..."
        baseUrl={baseUrl}
      />
    </div>

    <!-- Property Types -->
    <div>
      <h3 class="text-sm font-medium text-slate-700 mb-2">Loại hình</h3>
      <div class="flex flex-wrap gap-2">
        {propertyTypes.map((type) => {
          const isActive = isPropertyTypeActive(type.id);
          const href = isActive
            ? buildFilterUrl({})
            : buildFilterUrl({ property_types: String(type.id) });
          return (
            <a
              href={href}
              class:list={[
                'px-3 py-1.5 text-sm rounded-full border transition-colors',
                isActive
                  ? 'bg-orange-500 text-white border-orange-500'
                  : 'bg-white text-slate-600 border-slate-200 hover:border-orange-300',
              ]}
            >
              {type.title}
            </a>
          );
        })}
      </div>
    </div>

    <!-- Price Range -->
    <div>
      <h3 class="text-sm font-medium text-slate-700 mb-2">Mức giá</h3>
      <div class="flex flex-wrap gap-2">
        {PRICE_PRESETS.map((preset) => {
          const isActive = isPriceActive(preset);
          const href = preset.slug
            ? buildFilterUrl({ gtn: preset.min || undefined, gcn: preset.max || undefined })
            : currentPath;
          return (
            <a
              href={href}
              class:list={[
                'px-3 py-1.5 text-sm rounded-full border transition-colors',
                isActive
                  ? 'bg-orange-500 text-white border-orange-500'
                  : 'bg-white text-slate-600 border-slate-200 hover:border-orange-300',
              ]}
            >
              {preset.label}
            </a>
          );
        })}
      </div>
    </div>

    <!-- Area Range -->
    <div>
      <h3 class="text-sm font-medium text-slate-700 mb-2">Diện tích</h3>
      <div class="flex flex-wrap gap-2">
        {AREA_PRESETS.map((preset) => {
          const isActive = isAreaActive(preset);
          const href = preset.slug
            ? buildFilterUrl({ dtnn: preset.min || undefined, dtcn: preset.max || undefined })
            : currentPath;
          return (
            <a
              href={href}
              class:list={[
                'px-3 py-1.5 text-sm rounded-full border transition-colors',
                isActive
                  ? 'bg-orange-500 text-white border-orange-500'
                  : 'bg-white text-slate-600 border-slate-200 hover:border-orange-300',
              ]}
            >
              {preset.label}
            </a>
          );
        })}
      </div>
    </div>

    <!-- Advanced Filters (collapsible) -->
    <details class="group">
      <summary class="text-sm text-orange-500 hover:text-orange-600 cursor-pointer flex items-center gap-1">
        <span>Bộ lọc nâng cao</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>

      <div class="grid grid-cols-2 gap-4 pt-4 mt-2 border-t border-slate-100">
        <!-- Bedrooms -->
        <div>
          <h3 class="text-sm font-medium text-slate-700 mb-2">Số phòng ngủ</h3>
          <div class="flex flex-wrap gap-1">
            {ROOM_OPTIONS.map((option) => {
              const isActive = currentFilters.bedrooms === option;
              const href = buildFilterUrl({ bedrooms: option });
              return (
                <a
                  href={href}
                  class:list={[
                    'px-3 py-1 text-sm rounded border transition-colors',
                    isActive
                      ? 'bg-orange-500 text-white border-orange-500'
                      : 'bg-white text-slate-600 border-slate-200 hover:border-orange-300',
                  ]}
                >
                  {option}
                </a>
              );
            })}
          </div>
        </div>

        <!-- Bathrooms -->
        <div>
          <h3 class="text-sm font-medium text-slate-700 mb-2">Số phòng tắm</h3>
          <div class="flex flex-wrap gap-1">
            {ROOM_OPTIONS.map((option) => {
              const isActive = currentFilters.bathrooms === option;
              const href = buildFilterUrl({ bathrooms: option });
              return (
                <a
                  href={href}
                  class:list={[
                    'px-3 py-1 text-sm rounded border transition-colors',
                    isActive
                      ? 'bg-orange-500 text-white border-orange-500'
                      : 'bg-white text-slate-600 border-slate-200 hover:border-orange-300',
                  ]}
                >
                  {option}
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </details>

    <!-- Clear Filters -->
    {(currentFilters.propertyTypes?.length || currentFilters.minPrice || currentFilters.maxPrice ||
      currentFilters.minArea || currentFilters.maxArea || currentFilters.bedrooms || currentFilters.bathrooms) && (
      <div class="pt-3 border-t border-slate-100">
        <a
          href={currentPath}
          class="inline-flex items-center gap-2 px-4 py-2 text-slate-600 hover:text-slate-800 border border-slate-200 rounded-lg transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Xóa bộ lọc
        </a>
      </div>
    )}
  </div>
</div>
