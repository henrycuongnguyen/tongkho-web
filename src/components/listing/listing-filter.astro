---
/**
 * Listing Filter Component (Astro + Client JS)
 * Filter form with location selector, range sliders
 */
import LocationSelector from './sidebar/location-selector.astro';
import RangeSliderDropdown from "@components/ui/range-slider-dropdown.astro";
import type { Province } from '@/services/location/types';

interface PropertyType {
  id: number;
  title: string;
  slug: string;
}

interface Props {
  /** Current transaction type (1=sale, 2=rent, 3=project) */
  transactionType: number;
  /** Available property types for this transaction */
  propertyTypes: PropertyType[];
  /** List of all provinces */
  provinces?: Province[];
  /** Current province slug from URL */
  currentProvince?: string;
  /** Current filter values from URL */
  currentFilters: {
    propertyTypes?: number[];
    minPrice?: string;
    maxPrice?: string;
    minArea?: string;
    maxArea?: string;
    bedrooms?: string;
    bathrooms?: string;
  };
  /** Current URL path */
  currentPath: string;
  /** Selected locations for multi-select (optional) */
  selectedLocations?: Array<{ nId: string; name: string; slug: string; type: string }>;
}

const { transactionType, propertyTypes, provinces = [], currentProvince, currentFilters, currentPath, selectedLocations = [] } = Astro.props;

// Transaction type to base URL mapping
const TRANSACTION_BASE_URLS: Record<number, string> = {
  1: '/mua-ban',
  2: '/cho-thue',
  3: '/du-an',
};

const baseUrl = TRANSACTION_BASE_URLS[transactionType] || '/mua-ban';

// Room options
const ROOM_OPTIONS = ['1', '2', '3', '4', '5+'];

const isPropertyTypeActive = (id: number) =>
  currentFilters.propertyTypes?.includes(id) ?? false;
---

<div class="bg-white rounded-xl shadow-lg p-4 mb-4" data-listing-filter data-base-url={baseUrl} data-current-path={currentPath}>
  <div class="space-y-4">
    <!-- Location Selector: Province dropdown + Districts + Autocomplete -->
    <div>
      <h3 class="text-sm font-semibold text-secondary-800 mb-2">Địa điểm</h3>
      <LocationSelector
        provinces={provinces}
        baseUrl={baseUrl}
        currentProvince={currentProvince}
        selectedLocations={selectedLocations}
      />
    </div>

    <!-- Property Types (multi-select pills) -->
    <div>
      <h3 class="text-sm font-semibold text-secondary-800 mb-2">Loại hình</h3>
      <div class="flex flex-wrap gap-2">
        {propertyTypes.map((type) => {
          const isActive = isPropertyTypeActive(type.id);
          return (
            <button
              type="button"
              class:list={[
                'property-type-btn px-3 py-1.5 text-sm rounded-full border transition-colors cursor-pointer',
                isActive
                  ? 'bg-primary-500 text-white border-primary-500'
                  : 'bg-white text-secondary-600 border-secondary-200 hover:border-primary-300',
              ]}
              data-type-id={type.id}
              data-active={isActive ? 'true' : 'false'}
            >
              {type.title}
            </button>
          );
        })}
      </div>
    </div>

    <!-- Price Range Slider -->
    <div>
      <h3 class="text-sm font-semibold text-secondary-800 mb-2">Mức giá</h3>
      <RangeSliderDropdown type="price" name="price" />
    </div>

    <!-- Area Range Slider -->
    <div>
      <h3 class="text-sm font-semibold text-secondary-800 mb-2">Diện tích</h3>
      <RangeSliderDropdown type="area" name="area" />
    </div>

    <!-- Advanced Filters (collapsible) -->
    <details class="group">
      <summary class="text-sm text-primary-500 hover:text-primary-600 cursor-pointer flex items-center gap-1">
        <span>Bộ lọc nâng cao</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>

      <div class="grid grid-cols-2 gap-4 pt-4 mt-2 border-t border-secondary-100">
        <!-- Bedrooms -->
        <div>
          <h3 class="text-sm font-medium text-secondary-700 mb-2">Số phòng ngủ</h3>
          <div class="flex flex-wrap gap-1">
            {ROOM_OPTIONS.map((option) => {
              const isActive = currentFilters.bedrooms === option;
              return (
                <button
                  type="button"
                  class:list={[
                    'room-btn px-3 py-1 text-sm rounded border transition-colors cursor-pointer',
                    isActive
                      ? 'bg-primary-500 text-white border-primary-500'
                      : 'bg-white text-secondary-600 border-secondary-200 hover:border-primary-300',
                  ]}
                  data-room-type="bedrooms"
                  data-value={option}
                  data-active={isActive ? 'true' : 'false'}
                >
                  {option}
                </button>
              );
            })}
          </div>
        </div>

        <!-- Bathrooms -->
        <div>
          <h3 class="text-sm font-medium text-secondary-700 mb-2">Số phòng tắm</h3>
          <div class="flex flex-wrap gap-1">
            {ROOM_OPTIONS.map((option) => {
              const isActive = currentFilters.bathrooms === option;
              return (
                <button
                  type="button"
                  class:list={[
                    'room-btn px-3 py-1 text-sm rounded border transition-colors cursor-pointer',
                    isActive
                      ? 'bg-primary-500 text-white border-primary-500'
                      : 'bg-white text-secondary-600 border-secondary-200 hover:border-primary-300',
                  ]}
                  data-room-type="bathrooms"
                  data-value={option}
                  data-active={isActive ? 'true' : 'false'}
                >
                  {option}
                </button>
              );
            })}
          </div>
        </div>
      </div>
    </details>

    <!-- Apply Filters Button -->
    <div class="pt-3 border-t border-secondary-100">
      <button
        type="button"
        class="w-full py-2.5 bg-primary-500 text-white text-sm font-medium rounded-lg hover:bg-primary-600 transition-colors flex items-center justify-center gap-2"
        data-apply-filters
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        Áp dụng bộ lọc
      </button>

      <!-- Clear Filters -->
      {(currentFilters.propertyTypes?.length || currentFilters.minPrice || currentFilters.maxPrice ||
        currentFilters.minArea || currentFilters.maxArea || currentFilters.bedrooms || currentFilters.bathrooms) && (
        <button
          type="button"
          class="w-full mt-2 py-2 text-secondary-600 hover:text-secondary-800 text-sm border border-secondary-200 rounded-lg transition-colors flex items-center justify-center gap-2"
          data-clear-filters
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
          Xóa bộ lọc
        </button>
      )}
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('[data-listing-filter]').forEach((container) => {
    const baseUrl = container.getAttribute('data-base-url') || '/mua-ban';
    const currentPath = container.getAttribute('data-current-path') || baseUrl;

    // Track selected values
    let selectedPropertyTypes: string[] = [];
    let selectedPrice = '';
    let selectedArea = '';
    let selectedBedrooms = '';
    let selectedBathrooms = '';

    // Property type buttons
    const propertyTypeBtns = container.querySelectorAll('.property-type-btn') as NodeListOf<HTMLButtonElement>;
    propertyTypeBtns.forEach((btn) => {
      if (btn.dataset.active === 'true') {
        selectedPropertyTypes.push(btn.dataset.typeId || '');
      }

      btn.addEventListener('click', () => {
        const typeId = btn.dataset.typeId || '';
        const isActive = btn.dataset.active === 'true';

        if (isActive) {
          selectedPropertyTypes = selectedPropertyTypes.filter(id => id !== typeId);
          btn.dataset.active = 'false';
          btn.classList.remove('bg-primary-500', 'text-white', 'border-primary-500');
          btn.classList.add('bg-white', 'text-secondary-600', 'border-secondary-200');
        } else {
          selectedPropertyTypes.push(typeId);
          btn.dataset.active = 'true';
          btn.classList.add('bg-primary-500', 'text-white', 'border-primary-500');
          btn.classList.remove('bg-white', 'text-secondary-600', 'border-secondary-200');
        }
      });
    });

    // Room buttons
    const roomBtns = container.querySelectorAll('.room-btn') as NodeListOf<HTMLButtonElement>;
    roomBtns.forEach((btn) => {
      const roomType = btn.dataset.roomType;
      const value = btn.dataset.value || '';

      if (btn.dataset.active === 'true') {
        if (roomType === 'bedrooms') selectedBedrooms = value;
        if (roomType === 'bathrooms') selectedBathrooms = value;
      }

      btn.addEventListener('click', () => {
        const isActive = btn.dataset.active === 'true';

        container.querySelectorAll(`.room-btn[data-room-type="${roomType}"]`).forEach((b) => {
          (b as HTMLButtonElement).dataset.active = 'false';
          b.classList.remove('bg-primary-500', 'text-white', 'border-primary-500');
          b.classList.add('bg-white', 'text-secondary-600', 'border-secondary-200');
        });

        if (!isActive) {
          btn.dataset.active = 'true';
          btn.classList.add('bg-primary-500', 'text-white', 'border-primary-500');
          btn.classList.remove('bg-white', 'text-secondary-600', 'border-secondary-200');

          if (roomType === 'bedrooms') selectedBedrooms = value;
          if (roomType === 'bathrooms') selectedBathrooms = value;
        } else {
          if (roomType === 'bedrooms') selectedBedrooms = '';
          if (roomType === 'bathrooms') selectedBathrooms = '';
        }
      });
    });

    // Apply filters button
    const applyBtn = container.querySelector('[data-apply-filters]');
    applyBtn?.addEventListener('click', () => {
      const priceInput = container.querySelector('[name="price"]') as HTMLInputElement;
      const areaInput = container.querySelector('[name="area"]') as HTMLInputElement;

      selectedPrice = priceInput?.value || '';
      selectedArea = areaInput?.value || '';

      // Extract location slug from current path (e.g., /mua-ban/ha-noi → ha-noi)
      const pathParts = currentPath.split('/').filter(Boolean);
      let locationSlug = pathParts.length > 1 ? pathParts[1] : null;

      // Build URL parts: [transaction]/[location]/[price-slug]
      const urlParts: string[] = [baseUrl.replace(/^\//, '')];

      // Calculate price slug first to determine if we need location
      let priceSlug = '';
      if (selectedPrice) {
        const [minP, maxP] = selectedPrice.split('-');
        const minPriceTrieu = minP ? parseFloat(minP) : 0;
        const maxPriceTrieu = maxP ? parseFloat(maxP) : 0;

        if (minPriceTrieu || maxPriceTrieu) {
          priceSlug = buildPriceSlug(minPriceTrieu, maxPriceTrieu);
        }
      }

      // Add location (required if price slug exists, per v1 format)
      // If no specific location but has price filter, use "toan-quoc"
      if (locationSlug && locationSlug !== 'toan-quoc') {
        urlParts.push(locationSlug);
      } else if (priceSlug) {
        // Price slug requires location arg, use "toan-quoc" for nationwide
        urlParts.push('toan-quoc');
      }

      // Add price slug (arg3 position in v1 format)
      if (priceSlug) {
        urlParts.push(priceSlug);
      }

      // Build base URL path
      let targetUrl = '/' + urlParts.join('/');

      // Add query params for other filters
      const params = new URLSearchParams();

      if (selectedPropertyTypes.length) {
        params.set('property_types', selectedPropertyTypes.join(','));
      }

      if (selectedArea) {
        const [minA, maxA] = selectedArea.split('-');
        if (minA) params.set('dtnn', minA);
        if (maxA) params.set('dtcn', maxA);
      }

      if (selectedBedrooms) params.set('bedrooms', selectedBedrooms);
      if (selectedBathrooms) params.set('bathrooms', selectedBathrooms);

      const query = params.toString();
      if (query) {
        targetUrl += '?' + query;
      }

      window.location.href = targetUrl;
    });

    // Helper: Build price slug (v1 format)
    // Input values are in "triệu" units (e.g., 1000 = 1 tỷ, 500 = 500 triệu)
    function buildPriceSlug(minTrieu: number, maxTrieu: number): string {
      if (minTrieu === 0 && maxTrieu === 0) return 'gia-thuong-luong';

      if (!minTrieu && maxTrieu) {
        return `gia-duoi-${convertTrieuToPriceSlug(maxTrieu)}`;
      }

      if (minTrieu && (!maxTrieu || maxTrieu >= 60000)) {
        return `gia-tren-${convertTrieuToPriceSlug(minTrieu)}`;
      }

      if (minTrieu && maxTrieu && minTrieu < maxTrieu) {
        return `gia-tu-${convertTrieuToPriceSlug(minTrieu)}-den-${convertTrieuToPriceSlug(maxTrieu)}`;
      }

      return '';
    }

    // Helper: Convert triệu value to price slug part
    // Input: 1000 (triệu) → Output: "1-ty"
    // Input: 500 (triệu) → Output: "500-trieu"
    function convertTrieuToPriceSlug(trieu: number): string {
      if (trieu >= 1000) {
        const ty = trieu / 1000;
        const formatted = ty % 1 === 0 ? ty.toString() : ty.toFixed(1);
        return `${formatted}-ty`;
      }
      return `${trieu.toFixed(0)}-trieu`;
    }

    // Clear filters button
    const clearBtn = container.querySelector('[data-clear-filters]');
    clearBtn?.addEventListener('click', () => {
      // Check if already on target URL to prevent infinite reload
      const currentUrl = window.location.pathname + window.location.search;
      const targetUrl = currentPath;

      if (currentUrl !== targetUrl) {
        // Navigate to base URL without filters
        window.location.href = targetUrl;
      } else {
        // Already on base URL - just reset UI state without navigation
        selectedPropertyTypes = [];
        selectedBedrooms = '';
        selectedBathrooms = '';

        // Reset property type buttons
        propertyTypeBtns.forEach(btn => {
          btn.dataset.active = 'false';
          btn.classList.remove('bg-primary-500', 'text-white', 'border-primary-500');
          btn.classList.add('bg-white', 'text-secondary-600', 'border-secondary-200');
        });

        // Reset room buttons
        roomBtns.forEach(btn => {
          btn.dataset.active = 'false';
          btn.classList.remove('bg-primary-500', 'text-white', 'border-primary-500');
          btn.classList.add('bg-white', 'text-secondary-600', 'border-secondary-200');
        });

        // Reset range inputs
        const priceInput = container.querySelector('[name="price"]') as HTMLInputElement;
        const areaInput = container.querySelector('[name="area"]') as HTMLInputElement;
        if (priceInput) priceInput.value = '';
        if (areaInput) areaInput.value = '';
      }
    });
  });
</script>
