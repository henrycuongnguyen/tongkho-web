    // Load districts when input is focused or clicked
    function loadDistrictsOnDemand() {

      if (!currentProvinceNId) {
        return; // No province selected, nothing to show
      }

      // Notify dropdown manager to close other dropdowns before showing district dropdown
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.open(districtDropdownId);
      }

      // If districts already loaded, just show dropdown
      if (districtsLoaded) {
        districtDropdown?.classList.remove('hidden');
        return;
      }

      // First focus with province but districts not loaded yet - load them
      districtLoading?.classList.remove('hidden');
      districtEmpty?.classList.add('hidden');
      districtListContainer.innerHTML = '';
      districtDropdown?.classList.remove('hidden');

      const selectedSlugs = selectedDistricts.map(d => d.slug).join(',');
      const url = `/api/location/districts?province=${currentProvinceNId}&base=${baseUrl}&mode=checkboxes&selected=${encodeURIComponent(selectedSlugs)}`;
      console.log('[HorizontalSearchBar] Loading districts on focus with selected:', selectedSlugs);
      fetch(url)
        .then(response => response.text())
        .then(html => {
          districtLoading?.classList.add('hidden');
          districtListContainer.innerHTML = html;
          districtsLoaded = true;

          // Use grid layout for district buttons (3 columns like screenshot)
          districtListContainer.classList.remove('flex', 'flex-col', 'gap-y-1');
          districtListContainer.classList.add('grid', 'grid-cols-3', 'gap-2');

          // Sync selectedDistricts with selected buttons (populate names)
          const buttons = districtListContainer.querySelectorAll('[data-district-toggle]') as NodeListOf<HTMLButtonElement>;
          buttons.forEach(button => {
            const isSelected = button.dataset.selected === 'true';
            if (isSelected) {
              const slug = button.dataset.slug || '';
              const name = button.dataset.name || slug;
              if (!selectedDistricts.some(d => d.slug === slug)) {
                selectedDistricts.push({ slug, name });
              } else {
                const existing = selectedDistricts.find(d => d.slug === slug);
                if (existing && existing.name === slug) {
                  existing.name = name;
                }
              }
            }
          });

          // Attach button handlers
          attachDistrictButtonHandlers(districtListContainer);

          // Re-render tags with proper names
          renderSelectedDistrictsTags();

          // Check if any districts were loaded
          const districtCheckboxes = districtListContainer?.querySelectorAll('input[type="checkbox"]');
          if (!districtCheckboxes || districtCheckboxes.length === 0) {
            districtEmpty?.classList.remove('hidden');
          }
        })
        .catch(error => {
          console.error('[HorizontalSearchBar] Failed to load districts on focus:', error);
          districtLoading?.classList.add('hidden');
          districtEmpty?.classList.remove('hidden');
          if (districtEmpty) {
            districtEmpty.textContent = 'Lỗi khi tải quận/huyện';
          }
        });
    }

    // Attach both focus and click events to ensure dropdown shows
    districtSearchInput?.addEventListener('focus', loadDistrictsOnDemand);
    districtSearchInput?.addEventListener('click', loadDistrictsOnDemand);

    // District search/filter functionality with Elasticsearch integration
    let searchTimeout: number | null = null;

    districtSearchInput?.addEventListener('input', () => {
      const query = districtSearchInput.value.trim();

      // Clear existing timeout
      if (searchTimeout) {
        clearTimeout(searchTimeout);
      }

      // If empty query, restore districts view
      if (!query) {
        districtEmpty?.classList.add('hidden');

        // Restore header for province mode
        if (currentProvinceName && searchBar) {
          const dropdownHeader = searchBar.parentElement?.querySelector('[data-district-dropdown] > div:first-child h5') as HTMLElement;
          if (dropdownHeader) {
            dropdownHeader.innerHTML = `Quận/Huyện tại <span data-province-name-display>${currentProvinceName}</span>`;
          }
        }

        // If province selected, reload and show districts
        if (currentProvinceNId) {
          // Reload districts from API
          districtLoading?.classList.remove('hidden');
          districtListContainer.innerHTML = '';

          const selectedSlugs = selectedDistricts.map(d => d.slug).join(',');
          const url = `/api/location/districts?province=${currentProvinceNId}&base=${baseUrl}&mode=checkboxes&selected=${encodeURIComponent(selectedSlugs)}`;
          console.log('[HorizontalSearchBar] Reloading districts after empty search with selected:', selectedSlugs);
          fetch(url)
            .then(response => response.text())
            .then(html => {
              districtLoading?.classList.add('hidden');
              districtListContainer.innerHTML = html;
              districtsLoaded = true;

              // Use grid layout for district buttons (3 columns like screenshot)
              districtListContainer.classList.remove('flex', 'flex-col', 'gap-y-1');
              districtListContainer.classList.add('grid', 'grid-cols-3', 'gap-2');

              // Sync selectedDistricts with selected buttons (populate names)
              const buttons = districtListContainer.querySelectorAll('[data-district-toggle]') as NodeListOf<HTMLButtonElement>;
              buttons.forEach(button => {
                const isSelected = button.dataset.selected === 'true';
                if (isSelected) {
                  const slug = button.dataset.slug || '';
                  const name = button.dataset.name || slug;
                  if (!selectedDistricts.some(d => d.slug === slug)) {
                    selectedDistricts.push({ slug, name });
                  } else {
                    const existing = selectedDistricts.find(d => d.slug === slug);
                    if (existing && existing.name === slug) {
                      existing.name = name;
                    }
                  }
                }
              });

              // Attach button handlers
              attachDistrictButtonHandlers(districtListContainer);

              // Re-render tags with proper names
              renderSelectedDistrictsTags();

              districtDropdown?.classList.remove('hidden');

              // Check if any districts were loaded
              const districtButtons = districtListContainer?.querySelectorAll('[data-district-toggle]');
              if (!districtButtons || districtButtons.length === 0) {
                districtEmpty?.classList.remove('hidden');
              }
            })
            .catch(error => {
              console.error('[HorizontalSearchBar] Failed to reload districts:', error);
              districtLoading?.classList.add('hidden');
              districtDropdown?.classList.add('hidden');
            });
        } else {
          districtDropdown?.classList.add('hidden');
        }
        return;
      }

      // Debounce search - wait 300ms after user stops typing
      searchTimeout = window.setTimeout(() => {
        performLocationSearch(query);
      }, 300);
    });

    // Perform location search via Elasticsearch
    function performLocationSearch(query: string) {
      if (!query) return;

      // Update header for search mode
      if (searchBar) {
        const dropdownHeader = searchBar.parentElement?.querySelector('[data-district-dropdown] > div:first-child h5') as HTMLElement;
        if (dropdownHeader) {
          dropdownHeader.innerHTML = `Kết quả tìm kiếm "<span class="text-primary-600">${query}</span>"`;
        }
      }

      // Show loading
      districtLoading?.classList.remove('hidden');
      districtEmpty?.classList.add('hidden');
      districtListContainer.innerHTML = '';
      districtDropdown?.classList.remove('hidden');

      // Call location search API with province context
      const provinceNId = searchBar?.getAttribute('data-current-province-nid') || '';
      const provinceSlug = searchBar?.getAttribute('data-current-province-slug') || '';


      let searchUrl = `/api/location/search?q=${encodeURIComponent(query)}&base=${baseUrl}`;
      if (provinceNId && provinceSlug) {
        searchUrl += `&city_id=${encodeURIComponent(provinceNId)}&city_slug=${encodeURIComponent(provinceSlug)}`;
      } else {
      }

      fetch(searchUrl)
        .then(response => response.text())
        .then(html => {
          districtLoading?.classList.add('hidden');

          // Replace district list with search results
          districtListContainer.innerHTML = html;

          // Use flex column layout for search results
          districtListContainer.classList.remove('grid', 'grid-cols-3', 'gap-x-6', 'gap-y-2');
          districtListContainer.classList.add('flex', 'flex-col');

          // Check if any results
          const resultButtons = districtListContainer?.querySelectorAll('button, a');
          if (!resultButtons || resultButtons.length === 0) {
            districtEmpty?.classList.remove('hidden');
            districtEmpty.textContent = `Không tìm thấy "${query}"`;
          } else {
            districtEmpty?.classList.add('hidden');

            // Add click handlers for search result buttons
            resultButtons.forEach(btn => {
              btn.addEventListener('click', (e) => {
                const href = btn.getAttribute('data-href') || btn.getAttribute('href');
                if (href) {
                  e.preventDefault();
                  window.location.href = href;
                }
              });
            });
          }
        })
        .catch(error => {
          console.error('[HorizontalSearchBar] Location search failed:', error);
          districtLoading?.classList.add('hidden');
          districtEmpty?.classList.remove('hidden');
          districtEmpty.textContent = 'Lỗi khi tìm kiếm địa điểm';
        });
    }

    // Close district dropdown
    closeDistrictDropdownBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      districtDropdown?.classList.add('hidden');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(districtDropdownId);
      }
    });

    // Close dropdown on Escape key
    districtSearchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        districtDropdown?.classList.add('hidden');
        districtSearchInput.blur();
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(districtDropdownId);
        }
      }
    });

    // Search submit
    const searchSubmit = searchBar.querySelector('[data-search-submit]') as HTMLButtonElement;

    searchSubmit?.addEventListener('click', () => {
      // Read property types directly from checkboxes (don't rely on "Áp dụng" button)
      selectedPropertyTypeIds = Array.from(propertyTypeCheckboxes)
        .filter(cb => cb.checked)
        .map(cb => cb.value);

      console.log('[HorizontalSearchBar] Search clicked, property types:', selectedPropertyTypeIds);

      // Build search URL with filters (v1 compatible format)
      const params = new URLSearchParams();

      const keyword = districtSearchInput?.value.trim();
      if (keyword) params.set('keyword', keyword);

      // Get area values from RangeSliderDropdown hidden input
      const areaInput = container?.querySelector('[name="area"]') as HTMLInputElement;
      if (areaInput?.value) {
        const [minArea, maxArea] = areaInput.value.split('-');
        if (minArea) params.set('dtnn', minArea);
        if (maxArea) params.set('dtcn', maxArea);
      }

      // Add other advanced filters
      if (selectedRadius) params.set('radius', selectedRadius);
      if (selectedBathrooms) params.set('bathrooms', selectedBathrooms);
      if (selectedBedrooms) params.set('bedrooms', selectedBedrooms);

      // Build URL: /[transaction]/[province]/[price-slug]?[other-params]
      const urlParts: string[] = [baseUrl.replace(/^\//, '')];

      // Get price values first
      const prices = getPriceValues();

      // Add province slug if selected
      const provinceSlug = searchBar?.getAttribute('data-current-province-slug');
      if (provinceSlug && provinceSlug.trim()) {
        urlParts.push(provinceSlug);
      } else if (prices.min || prices.max) {
        // If no province but has price, add "toan-quoc"
        urlParts.push('toan-quoc');
      }

      // Convert price to slug (v1 compatible)
      if (prices.min || prices.max) {
        const minTrieu = prices.min ? Number(prices.min) : 0;
        const maxTrieu = prices.max ? Number(prices.max) : 0;
        const priceSlug = buildPriceSlug(minTrieu, maxTrieu);
        if (priceSlug) {
          urlParts.push(priceSlug);
        }
      }

      let targetUrl = '/' + urlParts.join('/');

      // Build query string manually to avoid encoding commas (v1 compatible)
      const queryParts: string[] = [];

      // Add property_types WITHOUT encoding (v1 uses plain commas)
      if (selectedPropertyTypeIds.length > 0) {
        queryParts.push(`property_types=${selectedPropertyTypeIds.join(',')}`);
      }

      // Add addresses param WITHOUT encoding (v1 uses plain commas)
      // Only add if districts are actually selected in UI
      if (selectedDistricts.length > 0) {
        const districtSlugs = selectedDistricts.map(d => d.slug).join(',');
        queryParts.push(`addresses=${districtSlugs}`);
      }

      // Add URLSearchParams parts (other params can be encoded normally)
      const standardParams = params.toString();
      if (standardParams) {
        queryParts.push(standardParams);
      }

      if (queryParts.length > 0) {
        targetUrl = `${targetUrl}?${queryParts.join('&')}`;
      }

      window.location.href = targetUrl;
    });

    // Helper: Build price slug from min/max in millions
    function buildPriceSlug(minTrieu: number, maxTrieu: number): string {
      if (minTrieu === 0 && maxTrieu === 0) return '';

      if (!minTrieu && maxTrieu) {
        return `gia-duoi-${convertTrieuToPriceSlug(maxTrieu)}`;
      }

      if (minTrieu && (!maxTrieu || maxTrieu >= 60000)) {
        return `gia-tren-${convertTrieuToPriceSlug(minTrieu)}`;
      }

      if (minTrieu && maxTrieu && minTrieu < maxTrieu) {
        return `gia-tu-${convertTrieuToPriceSlug(minTrieu)}-den-${convertTrieuToPriceSlug(maxTrieu)}`;
      }

      return '';
    }

    // Helper: Convert millions to price slug part
    function convertTrieuToPriceSlug(trieu: number): string {
      if (trieu >= 1000) {
        const ty = trieu / 1000;
        const formatted = ty % 1 === 0 ? ty.toString() : ty.toFixed(1);
        return `${formatted}-ty`;
      }
      return `${trieu.toFixed(0)}-trieu`;
    }

    // Enter key to search
    districtSearchInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        searchSubmit?.click();
      }
    });

    // Auto-search when preset buttons clicked (price/area)
    // Wait for dropdowns to initialize, then attach listeners
    setTimeout(() => {
      // Price preset buttons
      const pricePresetButtons = container?.querySelectorAll('[data-preset-button]') as NodeListOf<HTMLButtonElement>;
      pricePresetButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          console.log('[HorizontalSearchBar] Price preset clicked, auto-triggering search');
          // Small delay to let slider update first
          setTimeout(() => {
            searchSubmit?.click();
          }, 100);
        });
      });

      // Area preset buttons (quick picks in area dropdown)
      const areaDropdown = container?.querySelector('[data-type="area"]');
      const areaPresetButtons = areaDropdown?.querySelectorAll('.quick-pick') as NodeListOf<HTMLButtonElement>;
      areaPresetButtons?.forEach(btn => {
        btn.addEventListener('click', () => {
          console.log('[HorizontalSearchBar] Area preset clicked, auto-triggering search');
          setTimeout(() => {
            searchSubmit?.click();
          }, 100);
        });
      });
    }, 500);
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHorizontalSearchBar);
  } else {
    initHorizontalSearchBar();
  }

  // Run on Astro View Transitions
  document.addEventListener('astro:page-load', initHorizontalSearchBar);
</script>

<style>
  .horizontal-search-bar {
    backdrop-filter: blur(10px);
    /* Ensure dropdowns can escape container */
    isolation: auto;
  }

  /* Ensure dropdown panels are above all content */
  .horizontal-search-bar [data-district-dropdown],
  .horizontal-search-bar [data-property-type-panel],
  .horizontal-search-bar [data-radius-panel],
  .horizontal-search-bar [data-bathrooms-panel],
  .horizontal-search-bar [data-bedrooms-panel],
  .province-dropdown-panel {
    position: absolute;
    z-index: 99999 !important;
  }

  [data-advanced-filter-panel]:not(.hidden) {
    animation: slideDownFadeIn 0.2s ease-out;
  }

  @keyframes slideDownFadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .horizontal-search-bar .flex-wrap {
      gap: 0.5rem;
    }
  }
</style>
