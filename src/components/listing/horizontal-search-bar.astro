---
/**
 * Horizontal Search Bar Component
 * Replaces sidebar filter with clean horizontal layout
 * Layout: Location | Search | Property Type | Price | Filter Icon | Search Button
 */
import ProvinceModal from './sidebar/province-selector-modal.astro';
import PriceRangeSliderDropdown from '@/components/ui/price-range-slider-dropdown.astro';
import RangeSliderDropdown from '@/components/ui/range-slider-dropdown.astro';
import type { Province } from '@/services/location/types';

interface PropertyType {
  id: number;
  title: string;
  slug: string;
  vietnamese?: string | null;
}

interface Props {
  /** Current transaction type (1=sale, 2=rent, 3=project) */
  transactionType: number;
  /** Available property types for this transaction */
  propertyTypes: PropertyType[];
  /** List of all provinces */
  provinces?: Province[];
  /** Current province slug from URL */
  currentProvince?: string;
  /** Current district slugs from URL (multi-select support) */
  currentDistricts?: string[];
  /** Current filter values from URL */
  currentFilters: {
    propertyTypes?: number[];
    minPrice?: string;
    maxPrice?: string;
    keyword?: string;
    minArea?: string;
    maxArea?: string;
    radius?: string;
    bedrooms?: string;
    bathrooms?: string;
  };
  /** Current URL path */
  currentPath: string;
}

const {
  transactionType,
  propertyTypes,
  provinces = [],
  currentProvince,
  currentDistricts = [],
  currentFilters,
  currentPath,
} = Astro.props;

// Transaction type to base URL mapping
const TRANSACTION_BASE_URLS: Record<number, string> = {
  1: '/mua-ban',
  2: '/cho-thue',
  3: '/du-an',
};

const TRANSACTION_LABELS: Record<number, string> = {
  1: 'Mua bán',
  2: 'Cho thuê',
  3: 'Dự án',
};

// Determine baseUrl: use property type slug if present, else transaction URL
// Example: /ban-nha-biet-thu-lien-ke → baseUrl = '/ban-nha-biet-thu-lien-ke'
// Example: /mua-ban/ha-noi → baseUrl = '/mua-ban'
const pathSegments = currentPath.split('/').filter(Boolean);
const firstSegment = pathSegments[0] || '';
const isPropertyTypeSlug = firstSegment && !['mua-ban', 'cho-thue', 'du-an'].includes(firstSegment);
const baseUrl = isPropertyTypeSlug ? `/${firstSegment}` : (TRANSACTION_BASE_URLS[transactionType] || '/mua-ban');
const transactionLabel = TRANSACTION_LABELS[transactionType] || 'Loại BĐS';

// Find selected province - default to Hà Nội if no province in URL
const selectedProvince = currentProvince
  ? provinces.find(p => p.slug === currentProvince)
  : provinces.find(p => p.name === 'Hà Nội' || p.slug === 'ha-noi') || null;

// Debug: Log province selection

// Get featured provinces (top 5 with images)
const featuredProvinces = provinces.filter(p => p.cityImageWeb || p.cityImage).slice(0, 5);

// Convert price filters from VND to millions for display
const currentMinPrice = currentFilters.minPrice
  ? (Number(currentFilters.minPrice) / 1_000_000).toString()
  : undefined;
const currentMaxPrice = currentFilters.maxPrice
  ? (Number(currentFilters.maxPrice) / 1_000_000).toString()
  : undefined;
---

<div class="horizontal-search-bar relative py-2 top-0 z-[60]">
  <div class="">
    <div class="flex items-center gap-0 flex-wrap lg:flex-nowrap relative z-10" data-search-bar data-base-url={baseUrl} data-current-province-nid={selectedProvince?.nId || ''} data-current-province-slug={selectedProvince?.slug || ''}>
      <!-- Unified Search Container: Province Selector + Search Input -->
      <div class="flex items-stretch flex-[4] min-w-[450px] border border-secondary-300 rounded-lg bg-white hover:border-primary-400 transition-all focus-within:border-primary-400">
        <!-- Location Dropdown -->
        <div class="relative">
          <button
            type="button"
            class="h-full px-4 py-2.5 bg-white text-sm text-left flex items-center justify-between gap-2 transition-colors focus:outline-none border-r border-secondary-200 rounded-l-lg hover:bg-secondary-50"
            data-location-trigger
          >
            <div class="flex items-center gap-2 whitespace-nowrap">
              <svg class="w-4 h-4 text-secondary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-secondary-700 font-medium" data-location-display>
                {selectedProvince ? selectedProvince.name : 'Hà Nội'}
              </span>
            </div>
            <svg class="w-4 h-4 text-secondary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Province Dropdown Panel -->
          <ProvinceModal
            provinces={provinces}
            featuredProvinces={featuredProvinces}
            baseUrl={baseUrl}
            currentProvince={currentProvince}
          />
        </div>

        <!-- Keyword Search with District Dropdown -->
        <div class="flex-1 relative">
          <input
            type="text"
            placeholder="Tìm kiếm theo quận/huyện hoặc từ khóa"
            class="w-full h-full px-4 py-2.5 pl-10 bg-transparent text-sm focus:outline-none rounded-r-lg"
            data-keyword-input
            data-district-search-input
            value={currentFilters.keyword || ''}
            autocomplete="off"
          />
          <svg class="w-5 h-5 text-secondary-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>

        </div>
      </div>

      <!-- District/Search Results Dropdown (outside unified container) -->
      <div
        class="absolute top-full left-0 w-[900px] mt-2 bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden max-h-[420px] overflow-y-auto"
        data-district-dropdown
      >
        <!-- Selected Districts (Tags) -->
        <div class="px-5 pt-3 pb-2" data-selected-districts-container style="display: none;">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-medium text-secondary-600">Địa điểm đã chọn</span>
            <button
              type="button"
              class="text-xs text-primary-600 hover:text-primary-700 font-medium"
              data-clear-all-districts
            >
              Xóa tất cả
            </button>
          </div>
          <div class="flex flex-wrap gap-2" data-selected-districts-tags>
            <!-- Tags will be inserted here by JavaScript -->
          </div>
        </div>

        <!-- Section Title -->
        <div class="px-5 py-2 border-b border-secondary-100">
          <h6 class="text-xs font-semibold text-secondary-600 uppercase tracking-wide">Tìm kiếm phổ biến</h6>
        </div>

        <!-- District List Container (populated via HTMX) - Layout switches between grid/list -->
        <div
          data-district-list-container
          hx-swap="innerHTML"
          class="px-5 py-4"
        >
          <!-- Districts (grid) or search results (list) will be loaded here -->
        </div>

        <!-- Loading State -->
        <div class="px-5 py-6 text-sm text-secondary-500 text-center hidden" data-district-loading>
          <div class="inline-block animate-spin rounded-full h-5 w-5 border-b-2 border-primary-500"></div>
          <span class="ml-2">Đang tải quận/huyện...</span>
        </div>

        <!-- Empty State -->
        <div class="px-5 py-6 text-sm text-secondary-500 text-center hidden" data-district-empty>
          Không tìm thấy quận/huyện
        </div>
      </div>

      <!-- Property Type Dropdown -->
      <div class="relative w-[200px] ml-3">
        <button
          type="button"
          class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:border-primary-400"
          data-property-type-trigger
        >
          <span class="truncate text-secondary-700 font-medium" data-property-type-display>
            {(currentFilters.propertyTypes?.length ?? 0) > 0
              ? `Đã chọn ${currentFilters.propertyTypes?.length} loại`
              : transactionLabel}
          </span>
          <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-property-type-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Property Type Dropdown Panel -->
        <div
          class="absolute top-full left-0 mt-2 w-full min-w-[320px] bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden overflow-hidden"
          data-property-type-panel
        >
          <!-- Header -->
          <div class="px-4 py-3 border-b border-secondary-100 flex items-center justify-between">
            <h5 class="text-sm font-semibold text-secondary-800">Loại mua bán</h5>
            <button
              type="button"
              class="text-sm text-primary-600 hover:text-primary-700 font-medium"
              data-reset-property-types
            >
              Đặt lại
            </button>
          </div>

          <!-- Scrollable Content -->
          <div class="overflow-y-auto max-h-[280px] px-4 py-2">
            {propertyTypes.map((type) => {
              const isChecked = currentFilters.propertyTypes?.includes(type.id) ?? false;
              return (
                <label class="flex items-center justify-between gap-3 py-2.5 px-2 rounded-md hover:bg-secondary-50 cursor-pointer transition-colors group">
                  <div class="flex items-center gap-3 flex-1">
                    <span class="text-sm text-secondary-700 group-hover:text-secondary-900">
                      {type.title}
                    </span>
                  </div>
                  <input
                    type="checkbox"
                    class="w-4 h-4 rounded border-secondary-300 text-primary-600 focus:ring-primary-500"
                    value={type.id}
                    checked={isChecked}
                    data-property-type-checkbox
                  />
                </label>
              );
            })}
          </div>

          <!-- Actions -->
          <div class="px-4 py-3 border-t border-secondary-100 bg-secondary-50">
            <button
              type="button"
              class="w-full px-4 py-2 bg-primary-600 text-white text-sm font-medium rounded-lg hover:bg-primary-700 transition-colors"
              data-apply-property-types
            >
              Áp dụng
            </button>
          </div>
        </div>
      </div>

      <!-- Price Range Dropdown with Slider -->
      <div class="w-[200px] ml-3">
        <PriceRangeSliderDropdown
          transactionType={transactionType}
          currentMin={currentMinPrice}
          currentMax={currentMaxPrice}
        />
      </div>

      <!-- Advanced Filters Toggle Button -->
      <button
        type="button"
        class="px-3 py-2.5 border border-secondary-300 rounded-lg bg-white hover:bg-secondary-50 transition-colors shrink-0 ml-3"
        title="Bộ lọc nâng cao"
        data-advanced-filter-toggle
      >
        <svg class="w-5 h-5 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
      </button>

      <!-- Search Button -->
      <button
        type="button"
        class="px-6 py-2.5 bg-primary-500 hover:bg-primary-600 text-white font-medium rounded-lg transition-colors flex items-center gap-2 shrink-0 ml-3"
        data-search-submit
      >
        <span>Tìm kiếm</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
    </div>

    <!-- Advanced Filters Row (hidden by default) -->
    <div class="hidden pt-3 border-t border-secondary-100 mt-3" data-advanced-filters-row>
      <div class="flex items-center gap-3 flex-wrap">
        <!-- Area Filter with Slider -->
        <div class="w-[200px]">
          <RangeSliderDropdown
            type="area"
            name="area"
            currentMin={currentFilters.minArea ? Number(currentFilters.minArea) : undefined}
            currentMax={currentFilters.maxArea ? Number(currentFilters.maxArea) : undefined}
          />
        </div>

        <!-- Radius Filter with Dropdown Panel -->
        <div class="flex-1 min-w-[150px] relative" data-filter-group="radius">
          <button
            type="button"
            class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:border-primary-400"
            data-radius-trigger
          >
            <span class="text-secondary-700 font-medium" data-radius-display>Bán kính</span>
            <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-radius-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Radius Dropdown Panel -->
          <div
            class="absolute top-full left-0 mt-2 w-full min-w-[180px] bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden overflow-hidden"
            data-radius-panel
          >
            <!-- Options -->
            <div class="py-2">
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-radius-option
                data-value="5"
              >
                5km
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-radius-option
                data-value="10"
              >
                10km
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-radius-option
                data-value="50"
              >
                50km
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-radius-option
                data-value="100"
              >
                100km
              </button>
            </div>

            <!-- Reset Button -->
            <div class="px-3 py-3 border-t border-secondary-100">
              <button
                type="button"
                class="w-full px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors"
                data-reset-radius
              >
                Đặt lại
              </button>
            </div>
          </div>
        </div>

        <!-- Bathrooms Filter with Dropdown Panel -->
        <div class="flex-1 min-w-[150px] relative" data-filter-group="bathrooms">
          <button
            type="button"
            class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:border-primary-400"
            data-bathrooms-trigger
          >
            <span class="text-secondary-700 font-medium" data-bathrooms-display>Phòng tắm</span>
            <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-bathrooms-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Bathrooms Dropdown Panel -->
          <div
            class="absolute top-full left-0 mt-2 w-full min-w-[180px] bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden overflow-hidden"
            data-bathrooms-panel
          >
            <!-- Options -->
            <div class="py-2">
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="1"
              >
                1 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="2"
              >
                2 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="3"
              >
                3 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="4"
              >
                4 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="5"
              >
                5+ phòng
              </button>
            </div>

            <!-- Reset Button -->
            <div class="px-3 py-3 border-t border-secondary-100">
              <button
                type="button"
                class="w-full px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors"
                data-reset-bathrooms
              >
                Đặt lại
              </button>
            </div>
          </div>
        </div>

        <!-- Bedrooms Filter with Dropdown Panel -->
        <div class="flex-1 min-w-[150px] relative" data-filter-group="bedrooms">
          <button
            type="button"
            class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:border-primary-400"
            data-bedrooms-trigger
          >
            <span class="text-secondary-700 font-medium" data-bedrooms-display>Phòng ngủ</span>
            <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-bedrooms-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Bedrooms Dropdown Panel -->
          <div
            class="absolute top-full left-0 mt-2 w-full min-w-[180px] bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden overflow-hidden"
            data-bedrooms-panel
          >
            <!-- Options -->
            <div class="py-2">
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="1"
              >
                1 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="2"
              >
                2 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="3"
              >
                3 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="4"
              >
                4 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="5"
              >
                5+ phòng
              </button>
            </div>

            <!-- Reset Button -->
            <div class="px-3 py-3 border-t border-secondary-100">
              <button
                type="button"
                class="w-full px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors"
                data-reset-bedrooms
              >
                Đặt lại
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  /**
   * Horizontal Search Bar Logic
   */
  function initHorizontalSearchBar() {
    const searchBar = document.querySelector('[data-search-bar]');
    if (!searchBar) {
      console.warn('[HorizontalSearchBar] Search bar element not found');
      return;
    }

    const baseUrl = searchBar.getAttribute('data-base-url') || '/mua-ban';

    // Location dropdown
    const locationTrigger = searchBar.querySelector('[data-location-trigger]') as HTMLButtonElement;
    const locationDisplay = searchBar.querySelector('[data-location-display]') as HTMLSpanElement;

    locationTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (typeof (window as any).openProvinceDropdown === 'function') {
        (window as any).openProvinceDropdown();
      }
    });

    // District dropdown elements
    const districtSearchInput = searchBar.querySelector('[data-district-search-input]') as HTMLInputElement;
    const districtDropdown = searchBar.querySelector('[data-district-dropdown]') as HTMLDivElement;
    const districtListContainer = searchBar.querySelector('[data-district-list-container]') as HTMLDivElement;
    const provinceNameDisplay = searchBar.querySelector('[data-province-name-display]') as HTMLSpanElement;
    const closeDistrictDropdownBtn = searchBar.querySelector('[data-close-district-dropdown]') as HTMLButtonElement;
    const districtLoading = searchBar.querySelector('[data-district-loading]') as HTMLDivElement;
    const districtEmpty = searchBar.querySelector('[data-district-empty]') as HTMLDivElement;
    const selectedDistrictsContainer = searchBar.querySelector('[data-selected-districts-container]') as HTMLDivElement;
    const selectedDistrictsTags = searchBar.querySelector('[data-selected-districts-tags]') as HTMLDivElement;
    const clearAllDistrictsBtn = searchBar.querySelector('[data-clear-all-districts]') as HTMLButtonElement;

    // District dropdown - close function for dropdown manager
    const districtDropdownId = `district-${Math.random().toString(36).substr(2, 9)}`;

    function closeDistrictDropdown() {
      districtDropdown?.classList.add('hidden');
    }

    // Register with dropdown manager
    if (typeof (window as any).dropdownManager !== 'undefined') {
      (window as any).dropdownManager.register(districtDropdownId, closeDistrictDropdown);
    }

    // Track current province selection - initialize from data attributes (for page with province in URL)
    const initialProvinceNId = searchBar?.getAttribute('data-current-province-nid');
    let currentProvinceNId: string | null = (initialProvinceNId && initialProvinceNId.trim()) ? initialProvinceNId : null;

    // Multi-select districts state - initialize from URL addresses param
    const urlParams = new URLSearchParams(window.location.search);
    const addressesParam = urlParams.get('addresses');
    const selectedDistricts: Array<{ slug: string; name: string }> = addressesParam
      ? addressesParam.split(',').map(slug => ({ slug: slug.trim(), name: slug.trim() }))
      : [];

    console.log('[HorizontalSearchBar] Init selectedDistricts from URL:', selectedDistricts);

    // Render selected districts tags on page load (if any)
    // Note: Names will be slugs initially, will be updated when districts are loaded
    if (selectedDistricts.length > 0) {
      // Delay to ensure DOM is ready
      setTimeout(() => {
        renderSelectedDistrictsTags();
      }, 100);
    }

    // Attach checkbox handlers for multi-select
    function attachDistrictButtonHandlers(container: HTMLElement) {
      const buttons = container.querySelectorAll('[data-district-toggle]') as NodeListOf<HTMLButtonElement>;
      buttons.forEach(button => {
        button.addEventListener('click', () => {
          const slug = button.dataset.slug || '';
          const name = button.dataset.name || slug;
          const isCurrentlySelected = button.dataset.selected === 'true';

          if (isCurrentlySelected) {
            // Deselect: remove from array
            const index = selectedDistricts.findIndex(d => d.slug === slug);
            if (index > -1) {
