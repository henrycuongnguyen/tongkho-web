---
/**
 * Horizontal Search Bar Component
 * Replaces sidebar filter with clean horizontal layout
 * Layout: Location | Search | Property Type | Price | Filter Icon | Search Button
 */
import ProvinceModal from './sidebar/province-selector-modal.astro';
import PriceRangeSliderDropdown from '@/components/ui/price-range-slider-dropdown.astro';
import RangeSliderDropdown from '@/components/ui/range-slider-dropdown.astro';
import type { Province } from '@/services/location/types';

interface PropertyType {
  id: number;
  title: string;
  slug: string;
  vietnamese?: string | null;
}

interface Props {
  /** Current transaction type (1=sale, 2=rent, 3=project) */
  transactionType: number;
  /** Available property types for this transaction */
  propertyTypes: PropertyType[];
  /** List of all provinces */
  provinces?: Province[];
  /** Current province slug from URL */
  currentProvince?: string;
  /** Current district slugs from URL (multi-select support) */
  currentDistricts?: string[];
  /** Current filter values from URL */
  currentFilters: {
    propertyTypes?: number[];
    minPrice?: string;
    maxPrice?: string;
    keyword?: string;
    minArea?: string;
    maxArea?: string;
    radius?: string;
    bedrooms?: string;
    bathrooms?: string;
  };
  /** Current URL path */
  currentPath: string;
}

const {
  transactionType,
  propertyTypes,
  provinces = [],
  currentProvince,
  currentDistricts = [],
  currentFilters,
  currentPath,
} = Astro.props;

// Transaction type to base URL mapping
const TRANSACTION_BASE_URLS: Record<number, string> = {
  1: '/mua-ban',
  2: '/cho-thue',
  3: '/du-an',
};

const TRANSACTION_LABELS: Record<number, string> = {
  1: 'Mua bán',
  2: 'Cho thuê',
  3: 'Dự án',
};

// Determine baseUrl: use property type slug if present, else transaction URL
// Example: /ban-nha-biet-thu-lien-ke → baseUrl = '/ban-nha-biet-thu-lien-ke'
// Example: /mua-ban/ha-noi → baseUrl = '/mua-ban'
const pathSegments = currentPath.split('/').filter(Boolean);
const firstSegment = pathSegments[0] || '';
const isPropertyTypeSlug = firstSegment && !['mua-ban', 'cho-thue', 'du-an'].includes(firstSegment);
const baseUrl = isPropertyTypeSlug ? `/${firstSegment}` : (TRANSACTION_BASE_URLS[transactionType] || '/mua-ban');
const transactionLabel = TRANSACTION_LABELS[transactionType] || 'Loại BĐS';

// Find selected province - default to null (Toàn quốc) if no province in URL
// Client-side JavaScript will check localStorage and restore saved province
const selectedProvince = currentProvince
  ? provinces.find(p => p.slug === currentProvince)
  : null;

// Debug: Log province selection

// Get featured provinces (top 5 with images)
const featuredProvinces = provinces.filter(p => p.cityImageWeb || p.cityImage).slice(0, 5);

// Convert price filters from VND to millions for display
const currentMinPrice = currentFilters.minPrice
  ? (Number(currentFilters.minPrice) / 1_000_000).toString()
  : undefined;
const currentMaxPrice = currentFilters.maxPrice
  ? (Number(currentFilters.maxPrice) / 1_000_000).toString()
  : undefined;

// Helper function to strip province prefixes
const stripProvincePrefix = (name: string): string => {
  return name
    .replace(/^Tỉnh\s+/i, '')
    .replace(/^Thành phố\s+/i, '')
    .replace(/^TP\.\s+/i, '')
    .replace(/^TP\s+/i, '');
};
---

<div class="horizontal-search-bar relative py-2 top-0 z-[60]">
  <div class="">
    <div class="flex items-center gap-0 flex-wrap lg:flex-nowrap relative z-10" data-search-bar data-base-url={baseUrl} data-current-province-nid={selectedProvince?.nId || ''} data-current-province-slug={selectedProvince?.slug || ''} data-current-districts={JSON.stringify(currentDistricts)}>
