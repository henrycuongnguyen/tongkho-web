</div>

<script>
  /**
   * Horizontal Search Bar Logic
   * Uses static JSON files for districts via location-fetcher
   */

  import { getDistricts, getVersion } from '@/lib/location-fetcher';
  import type { DistrictItem } from '@/lib/location-types';
  import {
    buildSearchUrl,
    buildPropertyTypeSlugMap
  } from '@/services/url/search-url-builder';

  // Store handler reference for cleanup (prevent duplicate listeners on re-init)
  let provinceSelectedHandler: ((event: CustomEvent) => void) | null = null;

  /**
   * Escape HTML to prevent XSS attacks
   */
  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  /**
   * Escape HTML attribute value
   */
  function escapeAttr(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  /**
   * Render district buttons from JSON data
   */
  function renderDistrictsHtml(
    districts: DistrictItem[],
    selectedSlugs: Set<string>,
    baseUrl: string
  ): string {
    console.log('[renderDistrictsHtml] Rendering districts:', {
      districtCount: districts.length,
      selectedSlugs: Array.from(selectedSlugs),
      firstDistrictSlug: districts[0]?.slug
    });

    if (districts.length === 0) {
      return '<div class="text-sm text-secondary-500 text-center py-4">Không có quận/huyện</div>';
    }

    return districts.map(d => {
      const isSelected = selectedSlugs.has(d.slug);
      console.log('[renderDistrictsHtml] District:', d.slug, 'selected:', isSelected);
      const btnClass = isSelected
        ? 'flex items-center gap-2 py-2.5 px-3 rounded-lg bg-primary-50 border border-primary-200 cursor-pointer transition-all group'
        : 'flex items-center gap-2 py-2.5 px-3 rounded-lg hover:bg-secondary-50 border border-transparent cursor-pointer transition-all group';
      const iconClass = isSelected
        ? 'w-4 h-4 shrink-0 text-primary-600'
        : 'w-4 h-4 shrink-0 text-secondary-400 group-hover:text-primary-500';
      const textClass = isSelected
        ? 'text-sm text-primary-700 font-medium truncate'
        : 'text-sm text-secondary-700 group-hover:text-secondary-900 truncate';

      // Escape all user-controlled data to prevent XSS
      const safeSlug = escapeAttr(d.slug);
      const safeNId = escapeAttr(d.nId);
      const safeName = escapeAttr(d.name);
      const safeDisplayName = escapeHtml(d.name);

      return `
        <button
          type="button"
          class="${btnClass}"
          data-district-toggle
          data-slug="${safeSlug}"
          data-nid="${safeNId}"
          data-name="${safeName}"
          data-selected="${isSelected}"
        >
          <svg class="${iconClass}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="${textClass}">${safeDisplayName}</span>
        </button>
      `;
    }).join('');
  }

  function initHorizontalSearchBar() {
    const searchBar = document.querySelector('[data-search-bar]');
    if (!searchBar) {
      console.warn('[HorizontalSearchBar] Search bar element not found');
      return;
    }

    const baseUrl = searchBar.getAttribute('data-base-url') || '/mua-ban';

    // LocalStorage key for selected province
    const PROVINCE_STORAGE_KEY = 'tongkho_selected_province';

    // Helper function to strip province prefixes
    function stripProvincePrefix(name: string): string {
      return name
        .replace(/^Tỉnh\s+/i, '')
        .replace(/^Thành phố\s+/i, '')
        .replace(/^TP\.\s+/i, '')
        .replace(/^TP\s+/i, '');
    }

    // Save selected province to localStorage
    function saveProvinceToStorage(provinceData: { nId: string; slug: string; name: string }) {
      try {
        localStorage.setItem(PROVINCE_STORAGE_KEY, JSON.stringify(provinceData));
        console.log('[HorizontalSearchBar] Province saved to localStorage:', provinceData);
      } catch (error) {
        console.error('[HorizontalSearchBar] Failed to save province to localStorage:', error);
      }
    }

    // Load selected province from localStorage
    function loadProvinceFromStorage(): { nId: string; slug: string; name: string } | null {
      try {
        const saved = localStorage.getItem(PROVINCE_STORAGE_KEY);
        if (saved) {
          const provinceData = JSON.parse(saved);
          console.log('[HorizontalSearchBar] Province loaded from localStorage:', provinceData);
          return provinceData;
        }
      } catch (error) {
        console.error('[HorizontalSearchBar] Failed to load province from localStorage:', error);
      }
      return null;
    }

    // Clear saved province from localStorage
    function clearProvinceFromStorage() {
      try {
        localStorage.removeItem(PROVINCE_STORAGE_KEY);
        console.log('[HorizontalSearchBar] Province cleared from localStorage');
      } catch (error) {
        console.error('[HorizontalSearchBar] Failed to clear province from localStorage:', error);
      }
    }

    // Location dropdown
    const locationTrigger = searchBar.querySelector('[data-location-trigger]') as HTMLButtonElement;
    const locationDisplay = searchBar.querySelector('[data-location-display]') as HTMLSpanElement;

    locationTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (typeof (window as any).openProvinceDropdown === 'function') {
        (window as any).openProvinceDropdown();
      }
    });

    // District dropdown elements
    const districtSearchInput = searchBar.querySelector('[data-district-search-input]') as HTMLInputElement;
    const districtDropdown = searchBar.querySelector('[data-district-dropdown]') as HTMLDivElement;
    const districtListContainer = searchBar.querySelector('[data-district-list-container]') as HTMLDivElement;
    const provinceNameDisplay = searchBar.querySelector('[data-province-name-display]') as HTMLSpanElement;
    const closeDistrictDropdownBtn = searchBar.querySelector('[data-close-district-dropdown]') as HTMLButtonElement;
    const districtLoading = searchBar.querySelector('[data-district-loading]') as HTMLDivElement;
    const districtEmpty = searchBar.querySelector('[data-district-empty]') as HTMLDivElement;
    const selectedDistrictsContainer = searchBar.querySelector('[data-selected-districts-container]') as HTMLDivElement;
    const selectedDistrictsTags = searchBar.querySelector('[data-selected-districts-tags]') as HTMLDivElement;
    const clearAllDistrictsBtn = searchBar.querySelector('[data-clear-all-districts]') as HTMLButtonElement;
    const topDistrictsContainer = searchBar.parentElement?.querySelector('[data-top-districts]') as HTMLDivElement;

    // District dropdown - close function for dropdown manager
    const districtDropdownId = `district-${Math.random().toString(36).substr(2, 9)}`;

    function closeDistrictDropdown() {
      districtDropdown?.classList.add('hidden');
    }

    // Register with dropdown manager
    if (typeof (window as any).dropdownManager !== 'undefined') {
      (window as any).dropdownManager.register(districtDropdownId, closeDistrictDropdown);
    }

    // Track current province selection - initialize from data attributes (for page with province in URL)
    const initialProvinceNId = searchBar?.getAttribute('data-current-province-nid');
    let currentProvinceNId: string | null = (initialProvinceNId && initialProvinceNId.trim()) ? initialProvinceNId : null;

    // Restore province from localStorage if no URL province
    if (!currentProvinceNId) {
      const savedProvince = loadProvinceFromStorage();
      if (savedProvince && locationDisplay) {
        // Update display with saved province
        locationDisplay.textContent = stripProvincePrefix(savedProvince.name);
        currentProvinceNId = savedProvince.nId;

        // Update search bar data attributes
        searchBar.setAttribute('data-current-province-nid', savedProvince.nId);
        searchBar.setAttribute('data-current-province-slug', savedProvince.slug);

        console.log('[HorizontalSearchBar] Restored province from localStorage:', savedProvince);
      }
    }

    // Multi-select districts state - initialize from currentDistricts data attribute (includes districts from both path and query param)
    const selectedDistricts: Array<{ slug: string; name: string }> = [];

    // Read from data attribute
    const currentDistrictsData = searchBar?.getAttribute('data-current-districts');
    if (currentDistrictsData) {
      try {
        const districtSlugs: string[] = JSON.parse(currentDistrictsData);
        districtSlugs.forEach(slug => {
          if (slug && slug.trim()) {
            selectedDistricts.push({ slug: slug.trim(), name: slug.trim() });
          }
        });
      } catch (e) {
        console.error('[HorizontalSearchBar] Failed to parse currentDistricts:', e);
      }
    }

    console.log('[HorizontalSearchBar] Init selectedDistricts from data attr:', selectedDistricts);

    // Function to update district button states based on selectedDistricts array
    function updateDistrictButtonStates() {
      const buttons = districtListContainer?.querySelectorAll('[data-district-toggle]') as NodeListOf<HTMLButtonElement>;
      buttons?.forEach(button => {
        const slug = button.dataset.slug || '';
        const isSelected = selectedDistricts.some(d => d.slug === slug);

        if (isSelected) {
          button.dataset.selected = 'true';
          button.className = 'flex items-center gap-2 py-2.5 px-3 rounded-lg bg-primary-50 border border-primary-200 cursor-pointer transition-all group';
          const icon = button.querySelector('svg');
          const text = button.querySelector('span');
          if (icon) icon.setAttribute('class', 'w-4 h-4 shrink-0 text-primary-600');
          if (text) text.className = 'text-sm text-primary-700 font-medium truncate';
        } else {
          button.dataset.selected = 'false';
          button.className = 'flex items-center gap-2 py-2.5 px-3 rounded-lg hover:bg-secondary-50 border border-transparent cursor-pointer transition-all group';
          const icon = button.querySelector('svg');
          const text = button.querySelector('span');
          if (icon) icon.setAttribute('class', 'w-4 h-4 shrink-0 text-secondary-400 group-hover:text-primary-500');
          if (text) text.className = 'text-sm text-secondary-700 group-hover:text-secondary-900 truncate';
        }
      });
    }

    // Render selected districts tags on page load (if any)
    // Note: Names will be slugs initially, will be updated when districts are loaded
    if (selectedDistricts.length > 0) {
      // Delay to ensure DOM is ready
      setTimeout(() => {
        renderSelectedDistrictsTags();
        updateDistrictButtonStates();
      }, 100);
    }

    // Attach checkbox handlers for multi-select
    function attachDistrictButtonHandlers(container: HTMLElement) {
      const buttons = container.querySelectorAll('[data-district-toggle]') as NodeListOf<HTMLButtonElement>;
      buttons.forEach(button => {
        button.addEventListener('click', () => {
          const slug = button.dataset.slug || '';
          const name = button.dataset.name || slug;
          const isCurrentlySelected = button.dataset.selected === 'true';

          if (isCurrentlySelected) {
            // Deselect: remove from array
            const index = selectedDistricts.findIndex(d => d.slug === slug);
            if (index > -1) {
              selectedDistricts.splice(index, 1);
            }
            button.dataset.selected = 'false';
            // Update styles to unselected state
            button.className = 'flex items-center gap-2 py-2.5 px-3 rounded-lg hover:bg-secondary-50 border border-transparent cursor-pointer transition-all group';
            const icon = button.querySelector('svg');
            const text = button.querySelector('span');
            if (icon) icon.setAttribute('class', 'w-4 h-4 shrink-0 text-secondary-400 group-hover:text-primary-500');
            if (text) text.className = 'text-sm text-secondary-700 group-hover:text-secondary-900 truncate';
          } else {
            // Select: add to array
            if (!selectedDistricts.some(d => d.slug === slug)) {
              selectedDistricts.push({ slug, name });
            }
            button.dataset.selected = 'true';
            // Update styles to selected state
            button.className = 'flex items-center gap-2 py-2.5 px-3 rounded-lg bg-primary-50 border border-primary-200 cursor-pointer transition-all group';
            const icon = button.querySelector('svg');
            const text = button.querySelector('span');
            if (icon) icon.setAttribute('class', 'w-4 h-4 shrink-0 text-primary-600');
            if (text) text.className = 'text-sm text-primary-700 font-medium truncate';
          }

          console.log('[HorizontalSearchBar] Selected districts before render:', selectedDistricts);
          renderSelectedDistrictsTags();

          // Auto-submit search after district selection
          console.log('[HorizontalSearchBar] Triggering auto-submit with districts:', selectedDistricts.map(d => d.slug));
          const searchSubmit = searchBar?.querySelector('[data-search-submit]') as HTMLButtonElement;
          searchSubmit?.click();
        });
      });
    }

    // Render selected districts tags (like screenshot UI)
    function renderSelectedDistrictsTags() {
      console.log('[HorizontalSearchBar] renderSelectedDistrictsTags called', {
        hasContainer: !!selectedDistrictsContainer,
        hasTags: !!selectedDistrictsTags,
        selectedDistricts
      });

      if (!selectedDistrictsTags || !selectedDistrictsContainer) {
        console.warn('[HorizontalSearchBar] Missing container or tags element');
        return;
      }

      if (selectedDistricts.length === 0) {
        selectedDistrictsContainer.style.display = 'none';
        return;
      }

      console.log('[HorizontalSearchBar] Showing selectedDistricts container');
      selectedDistrictsContainer.style.display = 'block';
      selectedDistrictsTags.innerHTML = selectedDistricts.map(d => `
        <div class="flex items-center gap-1.5 px-2.5 py-1.5 bg-white text-secondary-700 rounded-lg text-sm border border-secondary-300 hover:border-secondary-400 transition-colors">
          <svg class="w-3.5 h-3.5 shrink-0 text-secondary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>${d.name}</span>
          <button
            type="button"
            class="ml-1 hover:bg-secondary-100 rounded p-0.5 transition-colors"
            data-remove-district="${d.slug}"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      `).join('');

      // Attach remove handlers
      selectedDistrictsTags.querySelectorAll('[data-remove-district]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const slug = (btn as HTMLElement).dataset.removeDistrict || '';
          const index = selectedDistricts.findIndex(d => d.slug === slug);
          if (index > -1) {
            selectedDistricts.splice(index, 1);
            renderSelectedDistrictsTags();
            // Update button state
            const button = districtListContainer?.querySelector(`[data-slug="${slug}"]`) as HTMLButtonElement;
            if (button) {
              button.dataset.selected = 'false';
              button.className = 'flex items-center gap-2 py-2.5 px-3 rounded-lg hover:bg-secondary-50 border border-transparent cursor-pointer transition-all group';
              const icon = button.querySelector('svg');
              const text = button.querySelector('span');
              if (icon) icon.setAttribute('class', 'w-4 h-4 shrink-0 text-secondary-400 group-hover:text-primary-500');
              if (text) text.className = 'text-sm text-secondary-700 group-hover:text-secondary-900 truncate';
            }

            // Auto-submit search after removing district
            const searchSubmit = searchBar?.querySelector('[data-search-submit]') as HTMLButtonElement;
            searchSubmit?.click();
          }
        });
      });
    }

    // Clear all districts button
    clearAllDistrictsBtn?.addEventListener('click', () => {
      selectedDistricts.length = 0;
      renderSelectedDistrictsTags();
      // Update all button states
      const buttons = districtListContainer?.querySelectorAll('[data-district-toggle]') as NodeListOf<HTMLButtonElement>;
      buttons?.forEach(button => {
        button.dataset.selected = 'false';
        button.className = 'flex items-center gap-2 py-2.5 px-3 rounded-lg hover:bg-secondary-50 border border-transparent cursor-pointer transition-all group';
        const icon = button.querySelector('svg');
        const text = button.querySelector('span');
        if (icon) icon.setAttribute('class', 'w-4 h-4 shrink-0 text-secondary-400 group-hover:text-primary-500');
        if (text) text.className = 'text-sm text-secondary-700 group-hover:text-secondary-900 truncate';
      });

      // Auto-submit search after clearing all districts
      const searchSubmit = searchBar?.querySelector('[data-search-submit]') as HTMLButtonElement;
      searchSubmit?.click();
    });

    // Render top 5 most searched districts (v1 compatible)
    // NOW DYNAMIC: Fetches data from API based on current province
    function renderTopDistricts() {
      if (!topDistrictsContainer) return;

      // If no province selected, show placeholder
      if (!currentProvinceNId) {
        topDistrictsContainer.innerHTML = `
          <div class="text-sm text-secondary-500 text-center py-4">
            Chọn tỉnh để xem
          </div>`;
        return;
      }

      // Show loading state
      topDistrictsContainer.innerHTML = `
        <div class="text-sm text-secondary-500 text-center py-4">
          <svg class="w-5 h-5 animate-spin mx-auto text-primary-500" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </div>`;

      // Fetch top districts from API (use format=dropdown for button format)
      const apiUrl = `/api/location/top-searched?province=${encodeURIComponent(currentProvinceNId)}&limit=5&base=${encodeURIComponent(baseUrl)}&format=dropdown`;
      console.log('[HorizontalSearchBar] Fetching top districts from:', apiUrl);

      fetch(apiUrl)
        .then(response => response.text())
        .then(html => {
          console.log('[HorizontalSearchBar] Top districts HTML received');
          topDistrictsContainer.innerHTML = html;

          // Attach click handlers to top district items
          const topDistrictItems = topDistrictsContainer.querySelectorAll('[data-top-district-item]') as NodeListOf<HTMLButtonElement>;
          console.log('[HorizontalSearchBar] Found top district items:', topDistrictItems.length);

          topDistrictItems.forEach(item => {
            item.addEventListener('click', () => {
              const slug = item.dataset.slug || '';
              const name = item.dataset.name || '';

              console.log('[HorizontalSearchBar] Top district clicked:', { slug, name });

              // Add to selectedDistricts if not already selected
              if (!selectedDistricts.some(d => d.slug === slug)) {
                selectedDistricts.push({ slug, name });
                renderSelectedDistrictsTags();

                // Update button state in main grid if visible
                const mainButton = districtListContainer?.querySelector(`[data-district-toggle][data-slug="${slug}"]`) as HTMLButtonElement;
                if (mainButton) {
                  mainButton.dataset.selected = 'true';
                  mainButton.className = 'flex items-center gap-2 py-2.5 px-3 rounded-lg bg-primary-50 border border-primary-200 cursor-pointer transition-all group';
                  const icon = mainButton.querySelector('svg');
                  const text = mainButton.querySelector('span');
                  if (icon) icon.setAttribute('class', 'w-4 h-4 shrink-0 text-primary-600');
                  if (text) text.className = 'text-sm text-primary-700 font-medium truncate';
                }

                // Auto-submit search after district selection
                const searchSubmit = searchBar?.querySelector('[data-search-submit]') as HTMLButtonElement;
                searchSubmit?.click();
              }
            });
          });
        })
        .catch(error => {
          console.error('[HorizontalSearchBar] Failed to fetch top districts:', error);
          topDistrictsContainer.innerHTML = `
            <div class="text-sm text-red-500 text-center py-4">
              Lỗi tải dữ liệu
            </div>`;
        });
    }

    let currentProvinceName: string | null = null;
    let districtsLoaded = false;

    // Remove old listener if exists (prevent duplicates on re-init)
    if (provinceSelectedHandler) {
      console.log('[HorizontalSearchBar] Removing old province-selected listener');
      document.removeEventListener('province-selected', provinceSelectedHandler as EventListener);
    }

    // Create new handler
    provinceSelectedHandler = ((e: CustomEvent) => {
      const { name, nId, slug } = e.detail;

      console.log('[HorizontalSearchBar] Received province-selected event:', { name, nId, slug });

      // Save province to localStorage for persistence across sessions
      saveProvinceToStorage({ nId, slug, name });

      // Update location display
      if (locationDisplay) {
        locationDisplay.textContent = stripProvincePrefix(name);
      }

      // Update province tracking
      currentProvinceNId = nId;
      currentProvinceName = name;
      districtsLoaded = false;

      // CRITICAL FIX: Update data attributes for location search
      if (searchBar) {
        searchBar.setAttribute('data-current-province-nid', nId || '');
        searchBar.setAttribute('data-current-province-slug', slug || '');
      }

      // Update dropdown header
      if (provinceNameDisplay) {
        provinceNameDisplay.textContent = name;
      }

      // Update header container for province mode
      if (searchBar) {
        const dropdownHeader = searchBar.parentElement?.querySelector('[data-district-dropdown] > div:first-child h5') as HTMLElement;
        if (dropdownHeader) {
          dropdownHeader.innerHTML = `Quận/Huyện tại <span data-province-name-display>${name}</span>`;
        }
      }

      // CRITICAL: Clear selected districts when province changes (don't carry over districts from old province)
      selectedDistricts.length = 0;
      console.log('[HorizontalSearchBar] Cleared selectedDistricts on province change');

      // Dispatch province-changed event for other components (e.g., most-searched-locations)
      console.log('[HorizontalSearchBar] Dispatching province-changed event:', { provinceNId: nId, provinceName: name, provinceSlug: slug, baseUrl });
      const provinceChangedEvent = new CustomEvent('province-changed', {
        detail: { provinceNId: nId, provinceName: name, provinceSlug: slug, baseUrl }
      });
      document.dispatchEvent(provinceChangedEvent);

      // Load districts via fetch
      if (districtListContainer && currentProvinceNId) {
        // Show loading state
        districtLoading?.classList.remove('hidden');
        districtEmpty?.classList.add('hidden');
        districtListContainer.innerHTML = '';

        // Fetch districts from static JSON via location-fetcher
        const selectedSlugsSet = new Set(selectedDistricts.map(d => d.slug));
        const currentVersion = getVersion();
        console.log('[HorizontalSearchBar] Loading districts from JSON for province:', currentProvinceNId, 'version:', currentVersion);

        getDistricts(currentProvinceNId, currentVersion)
          .then(districts => {
            console.log('[HorizontalSearchBar] Districts loaded from JSON:', districts.length);

            districtLoading?.classList.add('hidden');

            // Render districts using client-side rendering
            const html = renderDistrictsHtml(districts, selectedSlugsSet, baseUrl);
            districtListContainer.innerHTML = html;
            districtsLoaded = true;

            // Attach button handlers
            attachDistrictButtonHandlers(districtListContainer);

            // Update selectedDistricts names from loaded districts
            selectedDistricts.forEach(district => {
              const found = districts.find(d => d.slug === district.slug);
              if (found) {
                district.name = found.name;
              }
            });

            // Re-render tags with proper names
            renderSelectedDistrictsTags();

            // Render top 5 most searched districts
            renderTopDistricts();

            // Show dropdown and focus input
            districtDropdown?.classList.remove('hidden');
            districtSearchInput?.focus();

            // Check if we have districts
            if (districts.length === 0) {
              districtEmpty?.classList.remove('hidden');
            } else {
              districtEmpty?.classList.add('hidden');
            }
          })
          .catch(error => {
            console.error('[HorizontalSearchBar] Failed to load districts:', error);
            districtLoading?.classList.add('hidden');
            districtEmpty?.classList.remove('hidden');
            if (districtEmpty) {
              districtEmpty.textContent = 'Lỗi khi tải quận/huyện';
            }
          });
      }
    }) as (event: CustomEvent) => void;

    // Add listener
    console.log('[HorizontalSearchBar] Adding province-selected listener');
    document.addEventListener('province-selected', provinceSelectedHandler as EventListener);

    // Listen for version changes (old/new address toggle)
    document.addEventListener('version-changed', async (e: Event) => {
      const { version } = (e as CustomEvent).detail;
      console.log('[HorizontalSearchBar] Version changed:', version);

      // If province is selected, reload districts with new version
      if (currentProvinceNId) {
        const districts = await getDistricts(currentProvinceNId, version);
        const slugsSet = new Set(selectedDistricts.map(d => d.slug));
        districtListContainer.innerHTML = renderDistrictsHtml(districts, slugsSet, baseUrl);
        attachDistrictButtonHandlers(districtListContainer);
        console.log('[HorizontalSearchBar] Districts reloaded for version:', version, 'count:', districts.length);
      }
    });

    // Property Type dropdown
    const propertyTypeTrigger = searchBar.querySelector('[data-property-type-trigger]') as HTMLButtonElement;
    const propertyTypePanel = searchBar.querySelector('[data-property-type-panel]') as HTMLDivElement;
    const propertyTypeDisplay = searchBar.querySelector('[data-property-type-display]') as HTMLSpanElement;
    const propertyTypeArrow = searchBar.querySelector('[data-property-type-arrow]') as SVGElement;
    const propertyTypeCheckboxes = searchBar.querySelectorAll('[data-property-type-checkbox]') as NodeListOf<HTMLInputElement>;
    const resetPropertyTypesBtn = searchBar.querySelector('[data-reset-property-types]') as HTMLButtonElement;
    const applyPropertyTypesBtn = searchBar.querySelector('[data-apply-property-types]') as HTMLButtonElement;

    if (!propertyTypeTrigger || !propertyTypePanel) {
      console.warn('[HorizontalSearchBar] Property type elements not found');
    }

    // Property Type dropdown - close function for dropdown manager
    const propertyTypeDropdownId = `property-type-${Math.random().toString(36).substr(2, 9)}`;
    let isPropertyTypeOpen = false;

    function closePropertyTypeDropdown() {
      isPropertyTypeOpen = false;
      propertyTypePanel?.classList.add('hidden');
      propertyTypeArrow?.classList.remove('rotate-180');
    }

    // Register with dropdown manager
    if (typeof (window as any).dropdownManager !== 'undefined') {
      (window as any).dropdownManager.register(propertyTypeDropdownId, closePropertyTypeDropdown);
    }

    // Toggle dropdown
    propertyTypeTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isPropertyTypeOpen = !isPropertyTypeOpen;

      if (isPropertyTypeOpen) {
        // Notify dropdown manager to close other dropdowns
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.open(propertyTypeDropdownId);
        }
      } else {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(propertyTypeDropdownId);
        }
      }

      propertyTypePanel?.classList.toggle('hidden', !isPropertyTypeOpen);
      propertyTypeArrow?.classList.toggle('rotate-180', isPropertyTypeOpen);
    });

    // Update display count
    function updatePropertyTypeDisplay() {
      const checkedCount = Array.from(propertyTypeCheckboxes).filter(cb => cb.checked).length;
      if (propertyTypeDisplay) {
        propertyTypeDisplay.textContent = checkedCount > 0
          ? `Đã chọn ${checkedCount} loại`
          : 'Loại BĐS';
      }
    }

    // Update count on checkbox change
    propertyTypeCheckboxes.forEach(checkbox => {
      checkbox.addEventListener('change', updatePropertyTypeDisplay);
    });

    // Reset button
    resetPropertyTypesBtn?.addEventListener('click', () => {
      propertyTypeCheckboxes.forEach(cb => cb.checked = false);
      updatePropertyTypeDisplay();
    });

    // Apply button - close dropdown and update selected IDs
    let selectedPropertyTypeIds: string[] = [];
    applyPropertyTypesBtn?.addEventListener('click', () => {
      selectedPropertyTypeIds = Array.from(propertyTypeCheckboxes)
        .filter(cb => cb.checked)
        .map(cb => cb.value);

      // Auto-submit search after applying property types
      const searchSubmit = searchBar?.querySelector('[data-search-submit]') as HTMLButtonElement;
      searchSubmit?.click();

      // Close dropdown
      isPropertyTypeOpen = false;
      propertyTypePanel?.classList.add('hidden');
      propertyTypeArrow?.classList.remove('rotate-180');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(propertyTypeDropdownId);
      }
    });

    // Price selection - read from hidden inputs (new PriceRangeDropdown component)
    const getPriceValues = () => {
      const priceMinInput = searchBar.querySelector('[name="price-min"]') as HTMLInputElement;
      const priceMaxInput = searchBar.querySelector('[name="price-max"]') as HTMLInputElement;
      return {
        min: priceMinInput?.value || '',
        max: priceMaxInput?.value || ''
      };
    };

    // Advanced Filters Row Toggle
    const advancedFilterToggle = searchBar?.querySelector('[data-advanced-filter-toggle]') as HTMLButtonElement;
    // advancedFiltersRow is a sibling of searchBar, not a child, so query from parent or document
    const container = searchBar?.parentElement;
    const advancedFiltersRow = container?.querySelector('[data-advanced-filters-row]') as HTMLDivElement;

    // Track advanced filter values (area values come from RangeSliderDropdown hidden input)
    let selectedRadius = '';
    let selectedBathrooms = '';
    let selectedBedrooms = '';

    // Initialize from URL params
    const urlParams = new URLSearchParams(window.location.search);
    const bathroomsParam = urlParams.get('bathrooms');
    const bedroomsParam = urlParams.get('bedrooms');
    const radiusParam = urlParams.get('radius');

    // Set initial values
    if (radiusParam) {
      selectedRadius = radiusParam;
    }
    if (bathroomsParam) {
      selectedBathrooms = bathroomsParam;
    }
    if (bedroomsParam) {
      selectedBedrooms = bedroomsParam;
    }

    // Toggle advanced filters row

    let isAdvancedFiltersVisible = false;
    advancedFilterToggle?.addEventListener('click', (e) => {
      e.stopPropagation();

      // Close all other dropdowns when toggling advanced filters
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.closeAll();
      }

      isAdvancedFiltersVisible = !isAdvancedFiltersVisible;

      if (advancedFiltersRow) {
        if (isAdvancedFiltersVisible) {
          advancedFiltersRow.classList.remove('hidden');
        } else {
          advancedFiltersRow.classList.add('hidden');
        }
      }
    });

    // Radius dropdown
    const radiusTrigger = advancedFiltersRow?.querySelector('[data-radius-trigger]') as HTMLButtonElement;
    const radiusPanel = advancedFiltersRow?.querySelector('[data-radius-panel]') as HTMLDivElement;
    const radiusDisplay = advancedFiltersRow?.querySelector('[data-radius-display]') as HTMLSpanElement;
    const radiusArrow = advancedFiltersRow?.querySelector('[data-radius-arrow]') as SVGElement;
    const radiusOptions = advancedFiltersRow?.querySelectorAll('[data-radius-option]') as NodeListOf<HTMLButtonElement>;
    const resetRadiusBtn = advancedFiltersRow?.querySelector('[data-reset-radius]') as HTMLButtonElement;

    // Bathrooms dropdown
    const bathroomsTrigger = advancedFiltersRow?.querySelector('[data-bathrooms-trigger]') as HTMLButtonElement;
    const bathroomsPanel = advancedFiltersRow?.querySelector('[data-bathrooms-panel]') as HTMLDivElement;
    const bathroomsDisplay = advancedFiltersRow?.querySelector('[data-bathrooms-display]') as HTMLSpanElement;
    const bathroomsArrow = advancedFiltersRow?.querySelector('[data-bathrooms-arrow]') as SVGElement;
    const bathroomsOptions = advancedFiltersRow?.querySelectorAll('[data-bathrooms-option]') as NodeListOf<HTMLButtonElement>;
    const resetBathroomsBtn = advancedFiltersRow?.querySelector('[data-reset-bathrooms]') as HTMLButtonElement;

    // Bedrooms dropdown
    const bedroomsTrigger = advancedFiltersRow?.querySelector('[data-bedrooms-trigger]') as HTMLButtonElement;
    const bedroomsPanel = advancedFiltersRow?.querySelector('[data-bedrooms-panel]') as HTMLDivElement;
    const bedroomsDisplay = advancedFiltersRow?.querySelector('[data-bedrooms-display]') as HTMLSpanElement;
    const bedroomsArrow = advancedFiltersRow?.querySelector('[data-bedrooms-arrow]') as SVGElement;
    const bedroomsOptions = advancedFiltersRow?.querySelectorAll('[data-bedrooms-option]') as NodeListOf<HTMLButtonElement>;
    const resetBedroomsBtn = advancedFiltersRow?.querySelector('[data-reset-bedrooms]') as HTMLButtonElement;

    // Dropdown states
    let isRadiusOpen = false;
    let isBathroomsOpen = false;
    let isBedroomsOpen = false;

    // Register dropdowns with dropdown manager
    const radiusDropdownId = `radius-${Math.random().toString(36).substr(2, 9)}`;
    const bathroomsDropdownId = `bathrooms-${Math.random().toString(36).substr(2, 9)}`;
    const bedroomsDropdownId = `bedrooms-${Math.random().toString(36).substr(2, 9)}`;

    if (typeof (window as any).dropdownManager !== 'undefined') {
      (window as any).dropdownManager.register(radiusDropdownId, () => {
        isRadiusOpen = false;
        radiusPanel?.classList.add('hidden');
        radiusArrow?.classList.remove('rotate-180');
      });
      (window as any).dropdownManager.register(bathroomsDropdownId, () => {
        isBathroomsOpen = false;
        bathroomsPanel?.classList.add('hidden');
        bathroomsArrow?.classList.remove('rotate-180');
      });
      (window as any).dropdownManager.register(bedroomsDropdownId, () => {
        isBedroomsOpen = false;
        bedroomsPanel?.classList.add('hidden');
        bedroomsArrow?.classList.remove('rotate-180');
      });
    }

    // Helper to update display text
    function updateRadiusDisplay() {
      if (radiusDisplay) {
        radiusDisplay.textContent = selectedRadius ? `${selectedRadius} km` : 'Bán kính';
      }
    }
    function updateBathroomsDisplay() {
      if (bathroomsDisplay) {
        bathroomsDisplay.textContent = selectedBathrooms ? `${selectedBathrooms} phòng` : 'Phòng tắm';
      }
    }
    function updateBedroomsDisplay() {
      if (bedroomsDisplay) {
        bedroomsDisplay.textContent = selectedBedrooms ? `${selectedBedrooms} phòng` : 'Phòng ngủ';
      }
    }

    // Initialize display from URL params
    updateRadiusDisplay();
    updateBathroomsDisplay();
    updateBedroomsDisplay();

    // Radius dropdown toggle
    radiusTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isRadiusOpen = !isRadiusOpen;

      if (isRadiusOpen) {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.open(radiusDropdownId);
        }
      } else {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(radiusDropdownId);
        }
      }

      radiusPanel?.classList.toggle('hidden', !isRadiusOpen);
      radiusArrow?.classList.toggle('rotate-180', isRadiusOpen);
    });

    // Radius option selection
    radiusOptions?.forEach(option => {
      option.addEventListener('click', () => {
        selectedRadius = option.getAttribute('data-value') || '';
        updateRadiusDisplay();
        isRadiusOpen = false;
        radiusPanel?.classList.add('hidden');
        radiusArrow?.classList.remove('rotate-180');
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(radiusDropdownId);
        }
      });
    });

    // Radius reset
    resetRadiusBtn?.addEventListener('click', () => {
      selectedRadius = '';
      updateRadiusDisplay();
      isRadiusOpen = false;
      radiusPanel?.classList.add('hidden');
      radiusArrow?.classList.remove('rotate-180');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(radiusDropdownId);
      }
    });

    // Bathrooms dropdown toggle
    bathroomsTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isBathroomsOpen = !isBathroomsOpen;

      if (isBathroomsOpen) {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.open(bathroomsDropdownId);
        }
      } else {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(bathroomsDropdownId);
        }
      }

      bathroomsPanel?.classList.toggle('hidden', !isBathroomsOpen);
      bathroomsArrow?.classList.toggle('rotate-180', isBathroomsOpen);
    });

    // Bathrooms option selection
    bathroomsOptions?.forEach(option => {
      option.addEventListener('click', () => {
        selectedBathrooms = option.getAttribute('data-value') || '';
        updateBathroomsDisplay();
        isBathroomsOpen = false;
        bathroomsPanel?.classList.add('hidden');
        bathroomsArrow?.classList.remove('rotate-180');
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(bathroomsDropdownId);
        }
      });
    });

    // Bathrooms reset
    resetBathroomsBtn?.addEventListener('click', () => {
      selectedBathrooms = '';
      updateBathroomsDisplay();
      isBathroomsOpen = false;
      bathroomsPanel?.classList.add('hidden');
      bathroomsArrow?.classList.remove('rotate-180');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(bathroomsDropdownId);
      }
    });

    // Bedrooms dropdown toggle
    bedroomsTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isBedroomsOpen = !isBedroomsOpen;

      if (isBedroomsOpen) {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.open(bedroomsDropdownId);
        }
      } else {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(bedroomsDropdownId);
        }
      }

      bedroomsPanel?.classList.toggle('hidden', !isBedroomsOpen);
      bedroomsArrow?.classList.toggle('rotate-180', isBedroomsOpen);
    });

    // Bedrooms option selection
    bedroomsOptions?.forEach(option => {
      option.addEventListener('click', () => {
        selectedBedrooms = option.getAttribute('data-value') || '';
        updateBedroomsDisplay();
        isBedroomsOpen = false;
        bedroomsPanel?.classList.add('hidden');
        bedroomsArrow?.classList.remove('rotate-180');
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(bedroomsDropdownId);
        }
      });
    });

    // Bedrooms reset
    resetBedroomsBtn?.addEventListener('click', () => {
      selectedBedrooms = '';
      updateBedroomsDisplay();
      isBedroomsOpen = false;
      bedroomsPanel?.classList.add('hidden');
      bedroomsArrow?.classList.remove('rotate-180');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(bedroomsDropdownId);
      }
    });

    // Close dropdowns on outside click
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Close main search bar dropdowns if clicking outside
      if (!searchBar.contains(target)) {
        if (isPropertyTypeOpen) {
          propertyTypePanel?.classList.add('hidden');
          propertyTypeArrow?.classList.remove('rotate-180');
          isPropertyTypeOpen = false;
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(propertyTypeDropdownId);
          }
        }

        // Don't close district dropdown if clicking inside it
        if (!districtDropdown?.contains(target)) {
          districtDropdown?.classList.add('hidden');
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(districtDropdownId);
          }
        }
      }

      // Close advanced filter dropdowns if clicking outside the advanced filters row
      const advancedFiltersContainer = advancedFiltersRow;
      if (advancedFiltersContainer && !advancedFiltersContainer.contains(target)) {
        // Close radius dropdown
        if (isRadiusOpen) {
          isRadiusOpen = false;
          radiusPanel?.classList.add('hidden');
          radiusArrow?.classList.remove('rotate-180');
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(radiusDropdownId);
          }
        }

        // Close bathrooms dropdown
        if (isBathroomsOpen) {
          isBathroomsOpen = false;
          bathroomsPanel?.classList.add('hidden');
          bathroomsArrow?.classList.remove('rotate-180');
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(bathroomsDropdownId);
          }
        }

        // Close bedrooms dropdown
        if (isBedroomsOpen) {
          isBedroomsOpen = false;
          bedroomsPanel?.classList.add('hidden');
          bedroomsArrow?.classList.remove('rotate-180');
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(bedroomsDropdownId);
          }
        }
      }
    });

    // Load districts when input is focused or clicked
    function loadDistrictsOnDemand() {

      if (!currentProvinceNId) {
        return; // No province selected, nothing to show
      }

      // Notify dropdown manager to close other dropdowns before showing district dropdown
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.open(districtDropdownId);
      }

      // If districts already loaded, just show dropdown
      if (districtsLoaded) {
        districtDropdown?.classList.remove('hidden');
        // CRITICAL FIX: Hide empty state when opening dropdown with loaded data
        districtEmpty?.classList.add('hidden');
        return;
      }

      // First focus with province but districts not loaded yet - load them
      districtLoading?.classList.remove('hidden');
      districtEmpty?.classList.add('hidden');
      districtListContainer.innerHTML = '';
      districtDropdown?.classList.remove('hidden');

      const selectedSlugsSet = new Set(selectedDistricts.map(d => d.slug));
      const currentVersion = getVersion();
      console.log('[HorizontalSearchBar] Loading districts on focus from JSON, version:', currentVersion);

      getDistricts(currentProvinceNId, currentVersion)
        .then(districts => {
          districtLoading?.classList.add('hidden');

          // Render districts using client-side rendering
          const html = renderDistrictsHtml(districts, selectedSlugsSet, baseUrl);
          districtListContainer.innerHTML = html;
          districtsLoaded = true;

          // Update selectedDistricts names from loaded districts
          selectedDistricts.forEach(district => {
            const found = districts.find(d => d.slug === district.slug);
            if (found) {
              district.name = found.name;
            }
          });

          // Attach button handlers
          attachDistrictButtonHandlers(districtListContainer);

          // Re-render tags with proper names
          renderSelectedDistrictsTags();

          // Render top 5 most searched districts
          renderTopDistricts();

          // Check if any districts were loaded
          if (districts.length === 0) {
            districtEmpty?.classList.remove('hidden');
          } else {
            districtEmpty?.classList.add('hidden');
          }
        })
        .catch(error => {
          console.error('[HorizontalSearchBar] Failed to load districts on focus:', error);
          districtLoading?.classList.add('hidden');
          districtEmpty?.classList.remove('hidden');
          if (districtEmpty) {
            districtEmpty.textContent = 'Lỗi khi tải quận/huyện';
          }
        });
    }

    // Attach both focus and click events to ensure dropdown shows
    districtSearchInput?.addEventListener('focus', loadDistrictsOnDemand);
    districtSearchInput?.addEventListener('click', loadDistrictsOnDemand);

    // District search/filter functionality with Elasticsearch integration
    let searchTimeout: number | null = null;

    districtSearchInput?.addEventListener('input', () => {
      const query = districtSearchInput.value.trim();

      // Clear existing timeout
      if (searchTimeout) {
        clearTimeout(searchTimeout);
      }

      // If empty query, restore districts view
      if (!query) {
        districtEmpty?.classList.add('hidden');

        // Restore header for province mode
        if (currentProvinceName && searchBar) {
          const dropdownHeader = searchBar.parentElement?.querySelector('[data-district-dropdown] > div:first-child h5') as HTMLElement;
          if (dropdownHeader) {
            dropdownHeader.innerHTML = `Quận/Huyện tại <span data-province-name-display>${currentProvinceName}</span>`;
          }
        }

        // If province selected, reload and show districts from JSON
        if (currentProvinceNId) {
          districtLoading?.classList.remove('hidden');
          districtListContainer.innerHTML = '';

          const selectedSlugsSet = new Set(selectedDistricts.map(d => d.slug));
          const currentVersion = getVersion();
          console.log('[HorizontalSearchBar] Reloading districts from JSON after empty search, version:', currentVersion);

          getDistricts(currentProvinceNId, currentVersion)
            .then(districts => {
              districtLoading?.classList.add('hidden');

              // Render districts using client-side rendering
              const html = renderDistrictsHtml(districts, selectedSlugsSet, baseUrl);
              districtListContainer.innerHTML = html;
              districtsLoaded = true;

              // Update selectedDistricts names from loaded districts
              selectedDistricts.forEach(district => {
                const found = districts.find(d => d.slug === district.slug);
                if (found) {
                  district.name = found.name;
                }
              });

              // Attach button handlers
              attachDistrictButtonHandlers(districtListContainer);

              // Re-render tags with proper names
              renderSelectedDistrictsTags();

              // Render top 5 most searched districts
              renderTopDistricts();

              districtDropdown?.classList.remove('hidden');

              // Check if any districts were loaded
              if (districts.length === 0) {
                districtEmpty?.classList.remove('hidden');
              } else {
                districtEmpty?.classList.add('hidden');
              }
            })
            .catch(error => {
              console.error('[HorizontalSearchBar] Failed to reload districts:', error);
              districtLoading?.classList.add('hidden');
              districtDropdown?.classList.add('hidden');
            });
        } else {
          districtDropdown?.classList.add('hidden');
        }
        return;
      }

      // Debounce search - wait 300ms after user stops typing
      searchTimeout = window.setTimeout(() => {
        performLocationSearch(query);
      }, 300);
    });

    // Perform location search via Elasticsearch
    function performLocationSearch(query: string) {
      if (!query) return;

      // Update header for search mode
      if (searchBar) {
        const dropdownHeader = searchBar.parentElement?.querySelector('[data-district-dropdown] > div:first-child h5') as HTMLElement;
        if (dropdownHeader) {
          dropdownHeader.innerHTML = `Kết quả tìm kiếm "<span class="text-primary-600">${query}</span>"`;
        }
      }

      // Show loading
      districtLoading?.classList.remove('hidden');
      districtEmpty?.classList.add('hidden');
      districtListContainer.innerHTML = '';
      districtDropdown?.classList.remove('hidden');

      // Call location search API with province context
      const provinceNId = searchBar?.getAttribute('data-current-province-nid') || '';
      const provinceSlug = searchBar?.getAttribute('data-current-province-slug') || '';


      let searchUrl = `/api/location/search?q=${encodeURIComponent(query)}&base=${baseUrl}`;
      if (provinceNId && provinceSlug) {
        searchUrl += `&city_id=${encodeURIComponent(provinceNId)}&city_slug=${encodeURIComponent(provinceSlug)}`;
      } else {
      }

      fetch(searchUrl)
        .then(response => response.text())
        .then(html => {
          districtLoading?.classList.add('hidden');

          // Replace district list with search results
          districtListContainer.innerHTML = html;

          // Use flex column layout for search results
          districtListContainer.classList.remove('grid', 'grid-cols-3', 'gap-x-6', 'gap-y-2');
          districtListContainer.classList.add('flex', 'flex-col');

          // Check if any results (defer to next tick for DOM parsing)
          setTimeout(() => {
            const resultButtons = districtListContainer?.querySelectorAll('button, a');
            if (!resultButtons || resultButtons.length === 0) {
              districtEmpty?.classList.remove('hidden');
              districtEmpty.textContent = `Không tìm thấy "${query}"`;
            } else {
              districtEmpty?.classList.add('hidden');

              // Add click handlers for search result buttons
              resultButtons.forEach(btn => {
                btn.addEventListener('click', (e) => {
                  const href = btn.getAttribute('data-href') || btn.getAttribute('href');
                  if (href) {
                    e.preventDefault();
                    window.location.href = href;
                  }
                });
              });
            }
          }, 0);
        })
        .catch(error => {
          console.error('[HorizontalSearchBar] Location search failed:', error);
          districtLoading?.classList.add('hidden');
          districtEmpty?.classList.remove('hidden');
          districtEmpty.textContent = 'Lỗi khi tìm kiếm địa điểm';
        });
    }

    // Close district dropdown
    closeDistrictDropdownBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      districtDropdown?.classList.add('hidden');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(districtDropdownId);
      }
    });

    // Close dropdown on Escape key
    districtSearchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        districtDropdown?.classList.add('hidden');
        districtSearchInput.blur();
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(districtDropdownId);
        }
      }
    });

    // Search submit
    const searchSubmit = searchBar.querySelector('[data-search-submit]') as HTMLButtonElement;

    searchSubmit?.addEventListener('click', () => {
      // Read property types directly from checkboxes (don't rely on "Áp dụng" button)
      selectedPropertyTypeIds = Array.from(propertyTypeCheckboxes)
        .filter(cb => cb.checked)
        .map(cb => cb.value);

      console.log('[HorizontalSearchBar] Search clicked, property types:', selectedPropertyTypeIds);

      // Build property type slug map from checkboxes with data-slug attributes
      const propertyTypeSlugMap = buildPropertyTypeSlugMap();
      console.log('[HorizontalSearchBar] Property type slug map:', propertyTypeSlugMap);

      // Determine transaction type from baseUrl
      const transactionType = baseUrl.includes('cho-thue') ? '2' :
                              baseUrl.includes('du-an') ? '3' : '1';

      // Get current filter values
      const prices = getPriceValues();
      const areaInput = container?.querySelector('[name="area"]') as HTMLInputElement;
      const [minArea, maxArea] = areaInput?.value ? areaInput.value.split('-') : ['', ''];

      // Build location addresses
      const provinceSlug = searchBar?.getAttribute('data-current-province-slug') || '';
      const districtSlugs = selectedDistricts.map(d => d.slug);

      console.log('[HorizontalSearchBar] Building URL with districts:', districtSlugs);

      // Build selected_addresses: v1 logic
      // - If districts selected: use districts only (first district in path, rest in query param)
      // - If no districts: use province only
      const selectedAddresses = districtSlugs.length > 0
        ? districtSlugs.join(',')
        : provinceSlug;

      // Build filters object for buildSearchUrl
      const filters = {
        transaction_type: transactionType,
        selected_addresses: selectedAddresses,
        property_types: selectedPropertyTypeIds.join(','),

        // Convert price from triệu to VND
        min_price: prices.min ? String(Number(prices.min) * 1_000_000) : '',
        max_price: prices.max ? String(Number(prices.max) * 1_000_000) : '',

        // Area (already in m²)
        min_area: minArea || '',
        max_area: maxArea || '',

        // Other filters
        radius: selectedRadius || '',
        bathrooms: selectedBathrooms || '',
        bedrooms: selectedBedrooms || '',
        street_name: districtSearchInput?.value.trim() || '',
      };

      // Build URL using v1-compatible builder
      console.log('[HorizontalSearchBar] Filters:', filters);
      console.log('[HorizontalSearchBar] Slug map:', propertyTypeSlugMap);
      const url = buildSearchUrl(filters, propertyTypeSlugMap);

      console.log('[HorizontalSearchBar] Generated URL:', url);

      // Navigate to search results
      window.location.href = url;
    });

    // Enter key to search
    districtSearchInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        searchSubmit?.click();
      }
    });

    // Auto-search when preset buttons clicked (price/area)
    // Wait for dropdowns to initialize, then attach listeners
    setTimeout(() => {
      // Price preset buttons
      const pricePresetButtons = container?.querySelectorAll('[data-preset-button]') as NodeListOf<HTMLButtonElement>;
      pricePresetButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          console.log('[HorizontalSearchBar] Price preset clicked, auto-triggering search');
          // Small delay to let slider update first
          setTimeout(() => {
            searchSubmit?.click();
          }, 100);
        });
      });

      // Area preset buttons (quick picks in area dropdown)
      const areaDropdown = container?.querySelector('[data-type="area"]');
      const areaPresetButtons = areaDropdown?.querySelectorAll('.quick-pick') as NodeListOf<HTMLButtonElement>;
      areaPresetButtons?.forEach(btn => {
        btn.addEventListener('click', () => {
          console.log('[HorizontalSearchBar] Area preset clicked, auto-triggering search');
          setTimeout(() => {
            searchSubmit?.click();
          }, 100);
        });
      });
    }, 500);
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHorizontalSearchBar);
  } else {
    initHorizontalSearchBar();
  }

  // Run on Astro View Transitions
  document.addEventListener('astro:page-load', initHorizontalSearchBar);
</script>

<style>
  .horizontal-search-bar {
    backdrop-filter: blur(10px);
    /* Ensure dropdowns can escape container */
    isolation: auto;
  }

  /* Ensure dropdown panels are above all content */
  .horizontal-search-bar [data-district-dropdown],
  .horizontal-search-bar [data-property-type-panel],
  .horizontal-search-bar [data-radius-panel],
  .horizontal-search-bar [data-bathrooms-panel],
  .horizontal-search-bar [data-bedrooms-panel],
  .province-dropdown-panel {
    position: absolute;
    z-index: 99999 !important;
  }

  [data-advanced-filter-panel]:not(.hidden) {
    animation: slideDownFadeIn 0.2s ease-out;
  }

  @keyframes slideDownFadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .horizontal-search-bar .flex-wrap {
      gap: 0.5rem;
    }
  }
</style>
