---
/**
 * Horizontal Search Bar Component
 * Replaces sidebar filter with clean horizontal layout
 * Layout: Location | Search | Property Type | Price | Filter Icon | Search Button
 */
import ProvinceModal from './sidebar/province-selector-modal.astro';
import PriceRangeSliderDropdown from '@/components/ui/price-range-slider-dropdown.astro';
import RangeSliderDropdown from '@/components/ui/range-slider-dropdown.astro';
import type { Province } from '@/services/location/types';

interface PropertyType {
  id: number;
  title: string;
  slug: string;
  vietnamese?: string | null;
}

interface Props {
  /** Current transaction type (1=sale, 2=rent, 3=project) */
  transactionType: number;
  /** Available property types for this transaction */
  propertyTypes: PropertyType[];
  /** List of all provinces */
  provinces?: Province[];
  /** Current province slug from URL */
  currentProvince?: string;
  /** Current district slug from URL */
  currentDistrict?: string;
  /** Current filter values from URL */
  currentFilters: {
    propertyTypes?: number[];
    minPrice?: string;
    maxPrice?: string;
    keyword?: string;
    minArea?: string;
    maxArea?: string;
    radius?: string;
    bedrooms?: string;
    bathrooms?: string;
  };
  /** Current URL path */
  currentPath: string;
}

const {
  transactionType,
  propertyTypes,
  provinces = [],
  currentProvince,
  currentFilters,
} = Astro.props;

// Transaction type to base URL mapping
const TRANSACTION_BASE_URLS: Record<number, string> = {
  1: '/mua-ban',
  2: '/cho-thue',
  3: '/du-an',
};

const TRANSACTION_LABELS: Record<number, string> = {
  1: 'Mua bán',
  2: 'Cho thuê',
  3: 'Dự án',
};

const baseUrl = TRANSACTION_BASE_URLS[transactionType] || '/mua-ban';
const transactionLabel = TRANSACTION_LABELS[transactionType] || 'Loại BĐS';

// Find selected province - default to Hà Nội if no province in URL
const selectedProvince = currentProvince
  ? provinces.find(p => p.slug === currentProvince)
  : provinces.find(p => p.name === 'Hà Nội' || p.slug === 'ha-noi') || null;

// Debug: Log province selection

// Get featured provinces (top 5 with images)
const featuredProvinces = provinces.filter(p => p.cityImageWeb || p.cityImage).slice(0, 5);

// Convert price filters from VND to millions for display
const currentMinPrice = currentFilters.minPrice
  ? (Number(currentFilters.minPrice) / 1_000_000).toString()
  : undefined;
const currentMaxPrice = currentFilters.maxPrice
  ? (Number(currentFilters.maxPrice) / 1_000_000).toString()
  : undefined;
---

<div class="horizontal-search-bar relative py-4 top-0 z-[60]">
  <div class="">
    <div class="flex items-center gap-3 flex-wrap lg:flex-nowrap relative z-10" data-search-bar data-base-url={baseUrl} data-current-province-nid={selectedProvince?.nId || ''} data-current-province-slug={selectedProvince?.slug || ''}>
      <!-- Province Field (Field 1) -->
      <div class="relative flex-1 min-w-[200px]" data-province-field>
        <button
          type="button"
          class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:ring-2 focus:ring-primary-500"
          data-province-trigger
          data-location-trigger
        >
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-secondary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="truncate text-secondary-700 font-medium" data-province-label data-location-display>
              {selectedProvince ? selectedProvince.name : 'Hà Nội'}
            </span>
          </div>
          <svg class="w-4 h-4 text-secondary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Province Modal (with featured provinces) -->
        <ProvinceModal
          provinces={provinces}
          featuredProvinces={featuredProvinces}
          baseUrl={baseUrl}
          currentProvince={currentProvince}
        />
      </div>

      <!-- District Field (Field 2) -->
      <div class="flex-[2] min-w-[250px]" data-district-field>
        <div class="relative">
          <input
            type="text"
            placeholder="Tìm kiếm quận/huyện..."
            class="w-full px-4 py-2.5 pl-10 border border-secondary-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-400"
            data-district-search-input
            autocomplete="off"
          />
          <svg class="w-5 h-5 text-secondary-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>

          <!-- District Dropdown -->
          <div
            class="absolute top-full left-0 w-[900px] mt-2 bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden max-h-[420px] overflow-y-auto"
            data-district-dropdown
          >
            <!-- Header -->
            <div class="px-5 py-3 border-b border-secondary-100 flex items-center justify-between sticky top-0 bg-white z-10">
              <h5 class="text-sm font-semibold text-secondary-800">
                <span data-dropdown-header>Vui lòng chọn tỉnh</span>
              </h5>
              <div class="flex items-center gap-3">
                <button
                  type="button"
                  class="text-xs text-primary-600 hover:text-primary-700 font-medium hidden"
                  data-search-all-province
                >
                  Tìm toàn tỉnh
                </button>
                <button
                  type="button"
                  class="text-xs text-secondary-400 hover:text-secondary-600 transition-colors"
                  data-close-district-dropdown
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
            </div>

            <!-- District List -->
            <div
              data-district-list
              class="px-5 py-4"
            >
              <!-- District links will be loaded here -->
            </div>

            <!-- Loading State -->
            <div class="px-5 py-6 text-sm text-secondary-500 text-center hidden" data-district-loading>
              <div class="inline-block animate-spin rounded-full h-5 w-5 border-b-2 border-primary-500"></div>
              <span class="ml-2">Đang tải quận/huyện...</span>
            </div>

            <!-- Empty State -->
            <div class="px-5 py-6 text-sm text-secondary-500 text-center hidden" data-district-empty>
              Không tìm thấy quận/huyện
            </div>
          </div>
        </div>
      </div>

      <!-- Property Type Dropdown -->
      <div class="relative flex-1 min-w-[180px]" data-property-type-container data-transaction-type={transactionType}>
        <button
          type="button"
          class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:ring-2 focus:ring-primary-500"
          data-property-type-trigger
        >
          <span class="truncate text-secondary-700 font-medium" data-property-type-display>
            {(currentFilters.propertyTypes?.length ?? 0) > 0
              ? `Đã chọn ${currentFilters.propertyTypes?.length} loại`
              : transactionLabel}
          </span>
          <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-property-type-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Property Type Dropdown Panel -->
        <div
          class="absolute top-full left-0 mt-2 w-full min-w-[320px] bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden overflow-hidden"
          data-property-type-panel
        >
          <!-- Header -->
          <div class="px-4 py-3 border-b border-secondary-100 flex items-center justify-between">
            <h5 class="text-sm font-semibold text-secondary-800">Loại mua bán</h5>
            <button
              type="button"
              class="text-sm text-primary-600 hover:text-primary-700 font-medium"
              data-reset-property-types
            >
              Đặt lại
            </button>
          </div>

          <!-- Scrollable Content -->
          <div class="overflow-y-auto max-h-[280px] px-4 py-2">
            {propertyTypes.map((type) => {
              const isChecked = currentFilters.propertyTypes?.includes(type.id) ?? false;
              return (
                <label class="flex items-center justify-between gap-3 py-2.5 px-2 rounded-md hover:bg-secondary-50 cursor-pointer transition-colors group">
                  <div class="flex items-center gap-3 flex-1">
                    <span class="text-sm text-secondary-700 group-hover:text-secondary-900">
                      {type.title}
                    </span>
                  </div>
                  <input
                    type="checkbox"
                    class="w-4 h-4 rounded border-secondary-300 text-primary-600 focus:ring-primary-500 widget-type"
                    value={type.id}
                    checked={isChecked}
                    data-property-type-checkbox
                    data-slug={type.slug}
                  />
                </label>
              );
            })}
          </div>

          <!-- Actions -->
          <div class="px-4 py-3 border-t border-secondary-100 bg-secondary-50">
            <button
              type="button"
              class="w-full px-4 py-2 bg-primary-600 text-white text-sm font-medium rounded-lg hover:bg-primary-700 transition-colors"
              data-apply-property-types
            >
              Áp dụng
            </button>
          </div>
        </div>
      </div>

      <!-- Price Range Dropdown with Slider -->
      <div class="flex-1 min-w-[180px]">
        <PriceRangeSliderDropdown
          transactionType={transactionType}
          currentMin={currentMinPrice}
          currentMax={currentMaxPrice}
        />
      </div>

      <!-- Advanced Filters Toggle Button -->
      <button
        type="button"
        class="px-3 py-2.5 border border-secondary-300 rounded-lg bg-white hover:bg-secondary-50 transition-colors shrink-0"
        title="Bộ lọc nâng cao"
        data-advanced-filter-toggle
      >
        <svg class="w-5 h-5 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
      </button>

      <!-- Search Button -->
      <button
        type="button"
        class="px-6 py-2.5 bg-primary-500 hover:bg-primary-600 text-white font-medium rounded-lg transition-colors flex items-center gap-2 shrink-0"
        data-search-submit
      >
        <span>Tìm kiếm</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>
    </div>

    <!-- Advanced Filters Row (hidden by default) -->
    <div class="hidden pt-3 border-t border-secondary-100 mt-3" data-advanced-filters-row>
      <div class="flex items-center gap-3 flex-wrap">
        <!-- Area Filter with Slider -->
        <div class="flex-1 min-w-[180px]">
          <RangeSliderDropdown
            type="area"
            name="area"
            currentMin={currentFilters.minArea ? Number(currentFilters.minArea) : undefined}
            currentMax={currentFilters.maxArea ? Number(currentFilters.maxArea) : undefined}
          />
        </div>

        <!-- Radius Filter with Dropdown Panel -->
        <div class="flex-1 min-w-[150px] relative" data-filter-group="radius">
          <button
            type="button"
            class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:ring-2 focus:ring-primary-500"
            data-radius-trigger
          >
            <span class="text-secondary-700 font-medium" data-radius-display>Bán kính</span>
            <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-radius-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Radius Dropdown Panel -->
          <div
            class="absolute top-full left-0 mt-2 w-full min-w-[180px] bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden overflow-hidden"
            data-radius-panel
          >
            <!-- Options -->
            <div class="py-2">
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-radius-option
                data-value="5"
              >
                5km
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-radius-option
                data-value="10"
              >
                10km
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-radius-option
                data-value="50"
              >
                50km
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-radius-option
                data-value="100"
              >
                100km
              </button>
            </div>

            <!-- Reset Button -->
            <div class="px-3 py-3 border-t border-secondary-100">
              <button
                type="button"
                class="w-full px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors"
                data-reset-radius
              >
                Đặt lại
              </button>
            </div>
          </div>
        </div>

        <!-- Bathrooms Filter with Dropdown Panel -->
        <div class="flex-1 min-w-[150px] relative" data-filter-group="bathrooms">
          <button
            type="button"
            class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:ring-2 focus:ring-primary-500"
            data-bathrooms-trigger
          >
            <span class="text-secondary-700 font-medium" data-bathrooms-display>Phòng tắm</span>
            <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-bathrooms-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Bathrooms Dropdown Panel -->
          <div
            class="absolute top-full left-0 mt-2 w-full min-w-[180px] bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden overflow-hidden"
            data-bathrooms-panel
          >
            <!-- Options -->
            <div class="py-2">
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="1"
              >
                1 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="2"
              >
                2 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="3"
              >
                3 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="4"
              >
                4 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bathrooms-option
                data-value="5"
              >
                5+ phòng
              </button>
            </div>

            <!-- Reset Button -->
            <div class="px-3 py-3 border-t border-secondary-100">
              <button
                type="button"
                class="w-full px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors"
                data-reset-bathrooms
              >
                Đặt lại
              </button>
            </div>
          </div>
        </div>

        <!-- Bedrooms Filter with Dropdown Panel -->
        <div class="flex-1 min-w-[150px] relative" data-filter-group="bedrooms">
          <button
            type="button"
            class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white text-sm text-left flex items-center justify-between gap-2 hover:border-primary-400 transition-all focus:outline-none focus:ring-2 focus:ring-primary-500"
            data-bedrooms-trigger
          >
            <span class="text-secondary-700 font-medium" data-bedrooms-display>Phòng ngủ</span>
            <svg class="w-4 h-4 text-secondary-400 shrink-0 transition-transform" data-bedrooms-arrow fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Bedrooms Dropdown Panel -->
          <div
            class="absolute top-full left-0 mt-2 w-full min-w-[180px] bg-white rounded-lg shadow-xl border border-secondary-100 z-[99999] hidden overflow-hidden"
            data-bedrooms-panel
          >
            <!-- Options -->
            <div class="py-2">
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="1"
              >
                1 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="2"
              >
                2 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="3"
              >
                3 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="4"
              >
                4 phòng
              </button>
              <button
                type="button"
                class="w-full px-4 py-2.5 text-left text-sm text-secondary-700 hover:bg-secondary-50 transition-colors"
                data-bedrooms-option
                data-value="5"
              >
                5+ phòng
              </button>
            </div>

            <!-- Reset Button -->
            <div class="px-3 py-3 border-t border-secondary-100">
              <button
                type="button"
                class="w-full px-4 py-2 bg-red-500 text-white text-sm font-medium rounded-lg hover:bg-red-600 transition-colors"
                data-reset-bedrooms
              >
                Đặt lại
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  /**
   * Horizontal Search Bar Logic
   */
  function initHorizontalSearchBar() {
    const searchBar = document.querySelector('[data-search-bar]');
    if (!searchBar) {
      console.warn('[HorizontalSearchBar] Search bar element not found');
      return;
    }

    const baseUrl = searchBar.getAttribute('data-base-url') || '/mua-ban';

    // Province field elements
    const locationTrigger = searchBar.querySelector('[data-location-trigger]') as HTMLButtonElement;
    const provinceTrigger = searchBar.querySelector('[data-province-trigger]') as HTMLButtonElement;
    const provinceLabel = searchBar.querySelector('[data-province-label]') as HTMLSpanElement;

    locationTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (typeof (window as any).openProvinceDropdown === 'function') {
        (window as any).openProvinceDropdown();
      }
    });

    // District field elements
    const districtSearchInput = searchBar.querySelector('[data-district-search-input]') as HTMLInputElement;
    const districtDropdown = searchBar.querySelector('[data-district-dropdown]') as HTMLDivElement;
    const districtList = searchBar.querySelector('[data-district-list]') as HTMLDivElement;
    const dropdownHeader = searchBar.querySelector('[data-dropdown-header]') as HTMLSpanElement;
    const searchAllProvinceBtn = searchBar.querySelector('[data-search-all-province]') as HTMLButtonElement;
    const closeDistrictDropdownBtn = searchBar.querySelector('[data-close-district-dropdown]') as HTMLButtonElement;
    const districtLoading = searchBar.querySelector('[data-district-loading]') as HTMLDivElement;
    const districtEmpty = searchBar.querySelector('[data-district-empty]') as HTMLDivElement;

    // District dropdown - close function for dropdown manager
    const districtDropdownId = `district-${Math.random().toString(36).substr(2, 9)}`;

    function closeDistrictDropdown() {
      districtDropdown?.classList.add('hidden');
    }

    // Register with dropdown manager
    if (typeof (window as any).dropdownManager !== 'undefined') {
      (window as any).dropdownManager.register(districtDropdownId, closeDistrictDropdown);
    }

    // Track current province selection - initialize from data attributes (for page with province in URL)
    const initialProvinceNId = searchBar?.getAttribute('data-current-province-nid');
    const initialProvinceSlug = searchBar?.getAttribute('data-current-province-slug');
    let currentProvinceNId: string | null = (initialProvinceNId && initialProvinceNId.trim()) ? initialProvinceNId : null;
    let currentProvinceName: string | null = null;
    let districtsLoaded = false;
    let selectedProvinceSlug: string = (initialProvinceSlug && initialProvinceSlug.trim()) ? initialProvinceSlug : ''; // Track province selection for search URL


    // Listen for province selection and update display + load districts
    document.addEventListener('province-selected', ((e: CustomEvent) => {
      const { name, nId, slug } = e.detail;

      // Update province display and active state
      if (provinceLabel) {
        provinceLabel.textContent = name;
      }

      // Add active state to province button
      if (provinceTrigger) {
        provinceTrigger.classList.add('active', 'border-primary-500', 'bg-primary-50');
      }

      // Update province tracking
      currentProvinceNId = nId;
      currentProvinceName = name;
      districtsLoaded = false;
      selectedProvinceSlug = slug;

      // Update data attributes
      if (searchBar) {
        searchBar.setAttribute('data-current-province-nid', nId || '');
        searchBar.setAttribute('data-current-province-slug', slug || '');
      }

      // Clear district search input
      if (districtSearchInput) {
        districtSearchInput.value = '';
      }

      // Load districts via fetch
      loadDistricts(nId);
    }) as EventListener);

    // Function to load districts for selected province
    function loadDistricts(provinceNId: string) {
      if (!provinceNId || !districtList) return;

      // Show loading state
      districtDropdown?.classList.remove('hidden');
      districtLoading?.classList.remove('hidden');
      districtEmpty?.classList.add('hidden');
      districtList.innerHTML = '';

      // Update header
      if (dropdownHeader) {
        dropdownHeader.textContent = `Quận/Huyện tại ${currentProvinceName}`;
      }

      // Show "Tìm toàn tỉnh" button
      if (searchAllProvinceBtn) {
        searchAllProvinceBtn.classList.remove('hidden');
      }

      // Fetch districts (mode=links by default)
      const url = `/api/location/districts?province=${provinceNId}&base=${baseUrl}`;
      fetch(url)
        .then(response => response.text())
        .then(html => {
          districtLoading?.classList.add('hidden');
          districtList.innerHTML = html;
          districtsLoaded = true;

          // Apply grid layout for district links
          districtList.classList.remove('flex', 'flex-col');
          districtList.classList.add('grid', 'grid-cols-3', 'gap-2');

          // Focus district input
          districtSearchInput?.focus();

          // Check if any districts were loaded
          const districtLinks = districtList?.querySelectorAll('a');
          if (!districtLinks || districtLinks.length === 0) {
            districtEmpty?.classList.remove('hidden');
          }
        })
        .catch(error => {
          console.error('[HorizontalSearchBar] Failed to load districts:', error);
          districtLoading?.classList.add('hidden');
          districtEmpty?.classList.remove('hidden');
          if (districtEmpty) {
            districtEmpty.textContent = 'Lỗi khi tải quận/huyện';
          }
        });
    }

    // "Tìm toàn tỉnh" button handler
    searchAllProvinceBtn?.addEventListener('click', () => {
      if (selectedProvinceSlug) {
        window.location.href = `${baseUrl}/${selectedProvinceSlug}`;
      }
    });

    // Note: Multi-location selection removed - districts now navigate directly via links

    // Property Type dropdown
    const propertyTypeTrigger = searchBar.querySelector('[data-property-type-trigger]') as HTMLButtonElement;
    const propertyTypePanel = searchBar.querySelector('[data-property-type-panel]') as HTMLDivElement;
    const propertyTypeDisplay = searchBar.querySelector('[data-property-type-display]') as HTMLSpanElement;
    const propertyTypeArrow = searchBar.querySelector('[data-property-type-arrow]') as SVGElement;
    const propertyTypeCheckboxes = searchBar.querySelectorAll('[data-property-type-checkbox]') as NodeListOf<HTMLInputElement>;
    const resetPropertyTypesBtn = searchBar.querySelector('[data-reset-property-types]') as HTMLButtonElement;
    const applyPropertyTypesBtn = searchBar.querySelector('[data-apply-property-types]') as HTMLButtonElement;

    // Track selected property types - initialize from current checkboxes
    let selectedPropertyTypeIds: string[] = Array.from(propertyTypeCheckboxes)
      .filter(cb => cb.checked)
      .map(cb => cb.value);

    if (!propertyTypeTrigger || !propertyTypePanel) {
      console.warn('[HorizontalSearchBar] Property type elements not found');
    }

    // Property Type dropdown - close function for dropdown manager
    const propertyTypeDropdownId = `property-type-${Math.random().toString(36).substr(2, 9)}`;
    let isPropertyTypeOpen = false;

    function closePropertyTypeDropdown() {
      isPropertyTypeOpen = false;
      propertyTypePanel?.classList.add('hidden');
      propertyTypeArrow?.classList.remove('rotate-180');
    }

    // Register with dropdown manager
    if (typeof (window as any).dropdownManager !== 'undefined') {
      (window as any).dropdownManager.register(propertyTypeDropdownId, closePropertyTypeDropdown);
    }

    // Toggle dropdown
    propertyTypeTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isPropertyTypeOpen = !isPropertyTypeOpen;

      if (isPropertyTypeOpen) {
        // Notify dropdown manager to close other dropdowns
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.open(propertyTypeDropdownId);
        }
      } else {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(propertyTypeDropdownId);
        }
      }

      propertyTypePanel?.classList.toggle('hidden', !isPropertyTypeOpen);
      propertyTypeArrow?.classList.toggle('rotate-180', isPropertyTypeOpen);
    });

    // Update display count
    function updatePropertyTypeDisplay() {
      const checkedCount = Array.from(propertyTypeCheckboxes).filter(cb => cb.checked).length;
      if (propertyTypeDisplay) {
        propertyTypeDisplay.textContent = checkedCount > 0
          ? `Đã chọn ${checkedCount} loại`
          : 'Loại BĐS';
      }
    }

    // Update count on checkbox change
    propertyTypeCheckboxes.forEach(checkbox => {
      checkbox.addEventListener('change', updatePropertyTypeDisplay);
    });

    // Reset button
    resetPropertyTypesBtn?.addEventListener('click', () => {
      propertyTypeCheckboxes.forEach(cb => cb.checked = false);
      updatePropertyTypeDisplay();
    });

    // Apply button - close dropdown, update selected IDs, and trigger search
    applyPropertyTypesBtn?.addEventListener('click', () => {
      // Update selected property type IDs
      selectedPropertyTypeIds = Array.from(propertyTypeCheckboxes)
        .filter(cb => cb.checked)
        .map(cb => cb.value);

      // Close dropdown
      isPropertyTypeOpen = false;
      propertyTypePanel?.classList.add('hidden');
      propertyTypeArrow?.classList.remove('rotate-180');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(propertyTypeDropdownId);
      }

      // Auto-trigger search
      searchSubmit?.click();
    });

    // Price selection - read from hidden inputs (new PriceRangeDropdown component)
    const getPriceValues = () => {
      const priceMinInput = searchBar.querySelector('[name="price-min"]') as HTMLInputElement;
      const priceMaxInput = searchBar.querySelector('[name="price-max"]') as HTMLInputElement;
      return {
        min: priceMinInput?.value || '',
        max: priceMaxInput?.value || ''
      };
    };

    // Advanced Filters Row Toggle
    const advancedFilterToggle = searchBar?.querySelector('[data-advanced-filter-toggle]') as HTMLButtonElement;
    // advancedFiltersRow is a sibling of searchBar, not a child, so query from parent or document
    const container = searchBar?.parentElement;
    const advancedFiltersRow = container?.querySelector('[data-advanced-filters-row]') as HTMLDivElement;

    // Track advanced filter values (area values come from RangeSliderDropdown hidden input)
    let selectedRadius = '';
    let selectedBathrooms = '';
    let selectedBedrooms = '';

    // Initialize from URL params
    const urlParams = new URLSearchParams(window.location.search);
    const bathroomsParam = urlParams.get('bathrooms');
    const bedroomsParam = urlParams.get('bedrooms');
    const radiusParam = urlParams.get('radius');

    // Set initial values
    if (radiusParam) {
      selectedRadius = radiusParam;
    }
    if (bathroomsParam) {
      selectedBathrooms = bathroomsParam;
    }
    if (bedroomsParam) {
      selectedBedrooms = bedroomsParam;
    }

    // Toggle advanced filters row

    let isAdvancedFiltersVisible = false;
    advancedFilterToggle?.addEventListener('click', (e) => {
      e.stopPropagation();

      // Close all other dropdowns when toggling advanced filters
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.closeAll();
      }

      isAdvancedFiltersVisible = !isAdvancedFiltersVisible;

      if (advancedFiltersRow) {
        if (isAdvancedFiltersVisible) {
          advancedFiltersRow.classList.remove('hidden');
        } else {
          advancedFiltersRow.classList.add('hidden');
        }
      }
    });

    // Radius dropdown
    const radiusTrigger = advancedFiltersRow?.querySelector('[data-radius-trigger]') as HTMLButtonElement;
    const radiusPanel = advancedFiltersRow?.querySelector('[data-radius-panel]') as HTMLDivElement;
    const radiusDisplay = advancedFiltersRow?.querySelector('[data-radius-display]') as HTMLSpanElement;
    const radiusArrow = advancedFiltersRow?.querySelector('[data-radius-arrow]') as SVGElement;
    const radiusOptions = advancedFiltersRow?.querySelectorAll('[data-radius-option]') as NodeListOf<HTMLButtonElement>;
    const resetRadiusBtn = advancedFiltersRow?.querySelector('[data-reset-radius]') as HTMLButtonElement;

    // Bathrooms dropdown
    const bathroomsTrigger = advancedFiltersRow?.querySelector('[data-bathrooms-trigger]') as HTMLButtonElement;
    const bathroomsPanel = advancedFiltersRow?.querySelector('[data-bathrooms-panel]') as HTMLDivElement;
    const bathroomsDisplay = advancedFiltersRow?.querySelector('[data-bathrooms-display]') as HTMLSpanElement;
    const bathroomsArrow = advancedFiltersRow?.querySelector('[data-bathrooms-arrow]') as SVGElement;
    const bathroomsOptions = advancedFiltersRow?.querySelectorAll('[data-bathrooms-option]') as NodeListOf<HTMLButtonElement>;
    const resetBathroomsBtn = advancedFiltersRow?.querySelector('[data-reset-bathrooms]') as HTMLButtonElement;

    // Bedrooms dropdown
    const bedroomsTrigger = advancedFiltersRow?.querySelector('[data-bedrooms-trigger]') as HTMLButtonElement;
    const bedroomsPanel = advancedFiltersRow?.querySelector('[data-bedrooms-panel]') as HTMLDivElement;
    const bedroomsDisplay = advancedFiltersRow?.querySelector('[data-bedrooms-display]') as HTMLSpanElement;
    const bedroomsArrow = advancedFiltersRow?.querySelector('[data-bedrooms-arrow]') as SVGElement;
    const bedroomsOptions = advancedFiltersRow?.querySelectorAll('[data-bedrooms-option]') as NodeListOf<HTMLButtonElement>;
    const resetBedroomsBtn = advancedFiltersRow?.querySelector('[data-reset-bedrooms]') as HTMLButtonElement;

    // Dropdown states
    let isRadiusOpen = false;
    let isBathroomsOpen = false;
    let isBedroomsOpen = false;

    // Register dropdowns with dropdown manager
    const radiusDropdownId = `radius-${Math.random().toString(36).substr(2, 9)}`;
    const bathroomsDropdownId = `bathrooms-${Math.random().toString(36).substr(2, 9)}`;
    const bedroomsDropdownId = `bedrooms-${Math.random().toString(36).substr(2, 9)}`;

    if (typeof (window as any).dropdownManager !== 'undefined') {
      (window as any).dropdownManager.register(radiusDropdownId, () => {
        isRadiusOpen = false;
        radiusPanel?.classList.add('hidden');
        radiusArrow?.classList.remove('rotate-180');
      });
      (window as any).dropdownManager.register(bathroomsDropdownId, () => {
        isBathroomsOpen = false;
        bathroomsPanel?.classList.add('hidden');
        bathroomsArrow?.classList.remove('rotate-180');
      });
      (window as any).dropdownManager.register(bedroomsDropdownId, () => {
        isBedroomsOpen = false;
        bedroomsPanel?.classList.add('hidden');
        bedroomsArrow?.classList.remove('rotate-180');
      });
    }

    // Helper to update display text
    function updateRadiusDisplay() {
      if (radiusDisplay) {
        radiusDisplay.textContent = selectedRadius ? `${selectedRadius} km` : 'Bán kính';
      }
    }
    function updateBathroomsDisplay() {
      if (bathroomsDisplay) {
        bathroomsDisplay.textContent = selectedBathrooms ? `${selectedBathrooms} phòng` : 'Phòng tắm';
      }
    }
    function updateBedroomsDisplay() {
      if (bedroomsDisplay) {
        bedroomsDisplay.textContent = selectedBedrooms ? `${selectedBedrooms} phòng` : 'Phòng ngủ';
      }
    }

    // Initialize display from URL params
    updateRadiusDisplay();
    updateBathroomsDisplay();
    updateBedroomsDisplay();

    // Radius dropdown toggle
    radiusTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isRadiusOpen = !isRadiusOpen;

      if (isRadiusOpen) {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.open(radiusDropdownId);
        }
      } else {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(radiusDropdownId);
        }
      }

      radiusPanel?.classList.toggle('hidden', !isRadiusOpen);
      radiusArrow?.classList.toggle('rotate-180', isRadiusOpen);
    });

    // Radius option selection
    radiusOptions?.forEach(option => {
      option.addEventListener('click', () => {
        selectedRadius = option.getAttribute('data-value') || '';
        updateRadiusDisplay();
        isRadiusOpen = false;
        radiusPanel?.classList.add('hidden');
        radiusArrow?.classList.remove('rotate-180');
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(radiusDropdownId);
        }
        // Auto-trigger search
        searchSubmit?.click();
      });
    });

    // Radius reset
    resetRadiusBtn?.addEventListener('click', () => {
      selectedRadius = '';
      updateRadiusDisplay();
      isRadiusOpen = false;
      radiusPanel?.classList.add('hidden');
      radiusArrow?.classList.remove('rotate-180');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(radiusDropdownId);
      }
    });

    // Bathrooms dropdown toggle
    bathroomsTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isBathroomsOpen = !isBathroomsOpen;

      if (isBathroomsOpen) {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.open(bathroomsDropdownId);
        }
      } else {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(bathroomsDropdownId);
        }
      }

      bathroomsPanel?.classList.toggle('hidden', !isBathroomsOpen);
      bathroomsArrow?.classList.toggle('rotate-180', isBathroomsOpen);
    });

    // Bathrooms option selection
    bathroomsOptions?.forEach(option => {
      option.addEventListener('click', () => {
        selectedBathrooms = option.getAttribute('data-value') || '';
        updateBathroomsDisplay();
        isBathroomsOpen = false;
        bathroomsPanel?.classList.add('hidden');
        bathroomsArrow?.classList.remove('rotate-180');
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(bathroomsDropdownId);
        }
        // Auto-trigger search
        searchSubmit?.click();
      });
    });

    // Bathrooms reset
    resetBathroomsBtn?.addEventListener('click', () => {
      selectedBathrooms = '';
      updateBathroomsDisplay();
      isBathroomsOpen = false;
      bathroomsPanel?.classList.add('hidden');
      bathroomsArrow?.classList.remove('rotate-180');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(bathroomsDropdownId);
      }
    });

    // Bedrooms dropdown toggle
    bedroomsTrigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      isBedroomsOpen = !isBedroomsOpen;

      if (isBedroomsOpen) {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.open(bedroomsDropdownId);
        }
      } else {
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(bedroomsDropdownId);
        }
      }

      bedroomsPanel?.classList.toggle('hidden', !isBedroomsOpen);
      bedroomsArrow?.classList.toggle('rotate-180', isBedroomsOpen);
    });

    // Bedrooms option selection
    bedroomsOptions?.forEach(option => {
      option.addEventListener('click', () => {
        selectedBedrooms = option.getAttribute('data-value') || '';
        updateBedroomsDisplay();
        isBedroomsOpen = false;
        bedroomsPanel?.classList.add('hidden');
        bedroomsArrow?.classList.remove('rotate-180');
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(bedroomsDropdownId);
        }
        // Auto-trigger search
        searchSubmit?.click();
      });
    });

    // Bedrooms reset
    resetBedroomsBtn?.addEventListener('click', () => {
      selectedBedrooms = '';
      updateBedroomsDisplay();
      isBedroomsOpen = false;
      bedroomsPanel?.classList.add('hidden');
      bedroomsArrow?.classList.remove('rotate-180');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(bedroomsDropdownId);
      }
    });

    // Close dropdowns on outside click
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Close main search bar dropdowns if clicking outside
      if (!searchBar.contains(target)) {
        if (isPropertyTypeOpen) {
          propertyTypePanel?.classList.add('hidden');
          propertyTypeArrow?.classList.remove('rotate-180');
          isPropertyTypeOpen = false;
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(propertyTypeDropdownId);
          }
        }

        // Don't close district dropdown if clicking inside it
        if (!districtDropdown?.contains(target)) {
          districtDropdown?.classList.add('hidden');
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(districtDropdownId);
          }
        }
      }

      // Close advanced filter dropdowns if clicking outside the advanced filters row
      const advancedFiltersContainer = advancedFiltersRow;
      if (advancedFiltersContainer && !advancedFiltersContainer.contains(target)) {
        // Close radius dropdown
        if (isRadiusOpen) {
          isRadiusOpen = false;
          radiusPanel?.classList.add('hidden');
          radiusArrow?.classList.remove('rotate-180');
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(radiusDropdownId);
          }
        }

        // Close bathrooms dropdown
        if (isBathroomsOpen) {
          isBathroomsOpen = false;
          bathroomsPanel?.classList.add('hidden');
          bathroomsArrow?.classList.remove('rotate-180');
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(bathroomsDropdownId);
          }
        }

        // Close bedrooms dropdown
        if (isBedroomsOpen) {
          isBedroomsOpen = false;
          bedroomsPanel?.classList.add('hidden');
          bedroomsArrow?.classList.remove('rotate-180');
          if (typeof (window as any).dropdownManager !== 'undefined') {
            (window as any).dropdownManager.close(bedroomsDropdownId);
          }
        }
      }
    });

    // Load districts when input is focused or clicked
    function loadDistrictsOnDemand() {
      if (!currentProvinceNId) {
        return; // No province selected, nothing to show
      }

      // Notify dropdown manager to close other dropdowns before showing district dropdown
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.open(districtDropdownId);
      }

      // If districts already loaded, just show dropdown
      if (districtsLoaded) {
        districtDropdown?.classList.remove('hidden');
        return;
      }

      // Load districts (reuse loadDistricts function)
      loadDistricts(currentProvinceNId);
    }

    // Attach both focus and click events to ensure dropdown shows
    districtSearchInput?.addEventListener('focus', loadDistrictsOnDemand);
    districtSearchInput?.addEventListener('click', loadDistrictsOnDemand);

    // District search/filter functionality with Elasticsearch integration
    let searchTimeout: number | null = null;

    districtSearchInput?.addEventListener('input', () => {
      const query = districtSearchInput.value.trim();

      // Clear existing timeout
      if (searchTimeout) {
        clearTimeout(searchTimeout);
      }

      // If empty query, restore districts view
      if (!query) {
        districtEmpty?.classList.add('hidden');

        // Restore header for province mode
        if (dropdownHeader && currentProvinceName) {
          dropdownHeader.textContent = `Quận/Huyện tại ${currentProvinceName}`;
        }

        // If province selected, reload and show districts
        if (currentProvinceNId) {
          loadDistricts(currentProvinceNId);
        } else {
          districtDropdown?.classList.add('hidden');
        }
        return;
      }

      // Debounce search - wait 300ms after user stops typing
      searchTimeout = window.setTimeout(() => {
        performLocationSearch(query);
      }, 300);
    });

    // Perform location search via Elasticsearch
    function performLocationSearch(query: string) {
      if (!query) return;

      // Update header for search mode
      if (dropdownHeader) {
        dropdownHeader.innerHTML = `Kết quả tìm kiếm "<span class="text-primary-600">${query}</span>"`;
      }

      // Show loading
      districtLoading?.classList.remove('hidden');
      districtEmpty?.classList.add('hidden');
      districtList.innerHTML = '';
      districtDropdown?.classList.remove('hidden');

      // Hide "Tìm toàn tỉnh" button in search mode
      if (searchAllProvinceBtn) {
        searchAllProvinceBtn.classList.add('hidden');
      }

      // Call location search API with province context
      const provinceNId = searchBar?.getAttribute('data-current-province-nid') || '';

      let searchUrl = `/api/location/search?q=${encodeURIComponent(query)}&base=${baseUrl}`;
      if (provinceNId) {
        searchUrl += `&city_id=${encodeURIComponent(provinceNId)}`;
      }

      fetch(searchUrl)
        .then(response => response.text())
        .then(html => {
          districtLoading?.classList.add('hidden');

          // Replace district list with search results
          districtList.innerHTML = html;

          // Use flex column layout for search results
          districtList.classList.remove('grid', 'grid-cols-3', 'gap-2');
          districtList.classList.add('flex', 'flex-col');

          // Check if any results
          const resultButtons = districtList?.querySelectorAll('button, a');
          if (!resultButtons || resultButtons.length === 0) {
            districtEmpty?.classList.remove('hidden');
            districtEmpty.textContent = `Không tìm thấy "${query}"`;
          } else {
            districtEmpty?.classList.add('hidden');
          }
        })
        .catch(error => {
          console.error('[HorizontalSearchBar] Location search failed:', error);
          districtLoading?.classList.add('hidden');
          districtEmpty?.classList.remove('hidden');
          districtEmpty.textContent = 'Lỗi khi tìm kiếm địa điểm';
        });
    }

    // Close district dropdown
    closeDistrictDropdownBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      districtDropdown?.classList.add('hidden');
      if (typeof (window as any).dropdownManager !== 'undefined') {
        (window as any).dropdownManager.close(districtDropdownId);
      }
    });

    // Close dropdown on Escape key
    districtSearchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        districtDropdown?.classList.add('hidden');
        districtSearchInput.blur();
        if (typeof (window as any).dropdownManager !== 'undefined') {
          (window as any).dropdownManager.close(districtDropdownId);
        }
      }
    });

    // Utility: Extract current location slug from URL
    const getCurrentLocationSlug = (): string => {
      const pathname = window.location.pathname;
      const parts = pathname.split('/').filter(p => p);

      // URL pattern: /[transaction]/[location?]/[price-slug?]
      // If parts[1] exists and is not a price slug, it's a location
      if (parts.length > 1) {
        const arg1 = parts[1];
        // Skip if it's a price slug (starts with "gia-")
        if (!arg1.startsWith('gia-') && arg1 !== 'toan-quoc') {
          return arg1;
        }
      }

      return '';
    };

    // Search submit
    const searchSubmit = searchBar.querySelector('[data-search-submit]') as HTMLButtonElement;

    searchSubmit?.addEventListener('click', () => {
      // Get transaction type from data attribute
      const transactionTypeAttr = searchBar.querySelector('[data-property-type-container]')?.getAttribute('data-transaction-type');
      const transactionType = transactionTypeAttr || '1';

      // Use selected province or fall back to URL
      // Note: Districts navigate directly via links, so search only uses province-level filter
      let locationSlugs = '';
      if (selectedProvinceSlug) {
        locationSlugs = selectedProvinceSlug;
      } else {
        // Fall back to current location from URL
        locationSlugs = getCurrentLocationSlug();
      }

      // Get property type slug map
      const propertyTypeSlugMap = (window as any).buildPropertyTypeSlugMap?.() || {};

      // Get price values (already in millions)
      const prices = getPriceValues();
      const minPriceVnd = prices.min ? Number(prices.min) * 1_000_000 : 0;
      const maxPriceVnd = prices.max ? Number(prices.max) * 1_000_000 : 0;

      // Get area values
      const areaInput = container?.querySelector('[name="area"]') as HTMLInputElement;
      let minArea = '';
      let maxArea = '';
      if (areaInput?.value) {
        const [min, max] = areaInput.value.split('-');
        minArea = min || '';
        maxArea = max || '';
      }

      // Build search filters
      const filters: any = {
        transaction_type: transactionType,
        selected_addresses: locationSlugs, // Single or multiple locations
        property_types: selectedPropertyTypeIds.join(','),
        min_price: minPriceVnd.toString(),
        max_price: maxPriceVnd.toString(),
        min_area: minArea,
        max_area: maxArea,
      };

      // Add keyword as street_name if provided
      const keyword = districtSearchInput?.value.trim();
      if (keyword) {
        filters.street_name = keyword;
      }

      // Add other advanced filters
      if (selectedRadius) filters.radius = selectedRadius;
      if (selectedBathrooms) filters.bathrooms = selectedBathrooms;
      if (selectedBedrooms) filters.bedrooms = selectedBedrooms;

      // Build URL using v1 format
      const url = (window as any).buildSearchUrl?.(filters, propertyTypeSlugMap) || baseUrl;

      // Navigate
      window.location.href = url;
    });

    // Enter key to search
    districtSearchInput?.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        searchSubmit?.click();
      }
    });

    // Listen for price filter changes (from preset selection)
    document.addEventListener('price-filter-changed', () => {
      searchSubmit?.click();
    });

    // Listen for area filter changes (from quick pick selection)
    document.addEventListener('area-filter-changed', () => {
      searchSubmit?.click();
    });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHorizontalSearchBar);
  } else {
    initHorizontalSearchBar();
  }

  // Run on Astro View Transitions
  document.addEventListener('astro:page-load', initHorizontalSearchBar);
</script>

