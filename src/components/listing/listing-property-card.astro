---
/**
 * Listing Property Card
 * Optimized card for listing grid - uses ES document directly
 */
import type { PropertyDocument } from '@/services/elasticsearch/types';
import { formatRelativeTime } from '@/utils/format';
import ShareButtons from '@/components/ui/share-buttons.astro';

interface Props {
  property: PropertyDocument;
}

const { property } = Astro.props;

// Base URL for images
const UPLOADS_BASE_URL = 'https://quanly.tongkhobds.com';

// Get image URL
function getImageUrl(path?: string): string {
  if (!path) return '/images/placeholder-property.jpg';
  if (path.startsWith('http')) return path;
  return `${UPLOADS_BASE_URL}${path}`;
}

// Parse price from ES document
function parsePriceDisplay(price: number, priceDescription?: string): string {
  if (priceDescription) {
    // Use price_description if available (e.g., "7.3 tỷ")
    if (priceDescription.toLowerCase().includes('thỏa thuận') ||
        priceDescription.toLowerCase().includes('liên hệ')) {
      return 'Thỏa thuận';
    }
    return priceDescription;
  }

  // Fallback: format price number
  if (price <= 0) return 'Thỏa thuận';
  if (price >= 1_000_000_000) {
    const ty = price / 1_000_000_000;
    return `${ty.toFixed(1).replace(/\.0$/, '')} tỷ`;
  }
  const trieu = price / 1_000_000;
  return `${trieu.toFixed(0)} triệu`;
}

const imageUrl = getImageUrl(property.main_image || property.thumbnail);
const priceDisplay = parsePriceDisplay(property.price, property.price_description);
const location = [property.district, property.city || property.city_name].filter(Boolean).join(', ');
---

<a href={`/bds/${property.slug}`} class="block bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-shadow group">
  <!-- Image -->
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={imageUrl}
      alt={property.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />

    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>

    <!-- Badges -->
    <div class="absolute top-2 left-2 flex gap-1.5">
      {property.is_verified && (
        <span class="px-2 py-0.5 bg-red-500 text-white text-xs font-medium rounded">
          HOT
        </span>
      )}
      {property.is_featured && (
        <span class="px-2 py-0.5 bg-orange-500 text-white text-xs font-medium rounded">
          Nổi bật
        </span>
      )}
    </div>

    <!-- Price -->
    <div class="absolute bottom-2 left-2">
      <span class="px-3 py-1.5 bg-orange-500 text-white font-semibold rounded-lg text-sm">
        {priceDisplay}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-4">
    <h3 class="font-medium text-slate-800 line-clamp-2 group-hover:text-orange-500 transition-colors mb-2">
      {property.title}
    </h3>

    <!-- Location -->
    {location && (
      <p class="flex items-center gap-1.5 text-sm text-slate-500 mb-2">
        <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="truncate">{location}</span>
      </p>
    )}

    <!-- Posted time -->
    <p class="flex items-center gap-1 text-xs text-slate-400 mb-3">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      {formatRelativeTime(property.created_on)}
    </p>

    <!-- Features -->
    <div class="flex items-center gap-3 text-slate-600 text-sm pt-3 border-t border-slate-100">
      {property.area && (
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
          </svg>
          <span class="font-medium">{property.area}</span> m²
        </span>
      )}
      {property.bedrooms && (
        <>
          <span class="w-1 h-1 rounded-full bg-slate-300"></span>
          <span>{property.bedrooms} PN</span>
        </>
      )}
      {property.bathrooms && (
        <>
          <span class="w-1 h-1 rounded-full bg-slate-300"></span>
          <span>{property.bathrooms} WC</span>
        </>
      )}
    </div>

    <!-- Action Buttons Row -->
    <div class="flex items-center justify-between pt-3 border-t border-slate-100 mt-3">
      <div class="flex items-center gap-2">
        <div onclick="event.stopPropagation()">
          <ShareButtons
            url={`/bds/${property.slug}`}
            title={property.title}
            variant="popup"
            size="sm"
          />
        </div>
        <!-- Compare and Favorite buttons (Phase 2) -->
        <button
          class="btn-compare w-7 h-7 flex items-center justify-center text-secondary-400 hover:text-blue-500 hover:bg-secondary-50 rounded-full transition-all duration-200 cursor-pointer"
          data-estate-id={property.id}
          data-transaction-type={String(property.transaction_type)}
          data-url={`/bds/${property.slug}`}
          data-image={property.main_image || property.thumbnail}
          data-title={property.title}
          aria-label="So sánh"
          title="So sánh"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </button>
        <button
          class="w-7 h-7 flex items-center justify-center text-secondary-400 hover:text-red-500 hover:bg-secondary-50 rounded-full transition-all duration-200 cursor-pointer"
          aria-label="Yêu thích"
          title="Yêu thích"
          onclick="event.stopPropagation()"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</a>
