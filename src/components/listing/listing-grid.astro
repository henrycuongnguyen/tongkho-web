---
/**
 * Listing Grid
 * Displays property cards in responsive grid with animations (matching home page style)
 * Supports fallback messaging for zero results relaxation
 */
import type { PropertyDocument } from '@/services/elasticsearch/types';
import type { RelaxationLevel } from '@/services/search-relaxation/types';
import PropertyCard from '@/components/cards/property-card.astro';
import { mapPropertyDocumentsToProperties } from '@/utils/property-mapper';

interface Props {
  properties: PropertyDocument[];
  isFallback?: boolean;
  relaxationMetadata?: RelaxationLevel | null;
}

const { properties: propertyDocs, isFallback = false, relaxationMetadata = null } = Astro.props;

// Convert PropertyDocuments to Property type for PropertyCard
const properties = mapPropertyDocumentsToProperties(propertyDocs);
---

{/* Fallback messaging - show when results are from relaxed search */}
{isFallback && relaxationMetadata && (
  <div class={`border rounded-lg p-3 md:p-4 mb-4 md:mb-6 ${
    relaxationMetadata.level === 1 ? 'bg-blue-50 border-blue-200' :
    relaxationMetadata.level === 2 ? 'bg-yellow-50 border-yellow-200' :
    'bg-orange-50 border-orange-200'
  }`}>
    <div class="flex flex-col sm:flex-row items-start gap-2 sm:gap-3">
      <svg class="w-5 h-5 flex-shrink-0 hidden sm:block text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div class="flex-1">
        <p class={`text-xs sm:text-sm font-medium mb-1 ${
          relaxationMetadata.level === 1 ? 'text-blue-900' :
          relaxationMetadata.level === 2 ? 'text-yellow-900' :
          'text-orange-900'
        }`}>
          {relaxationMetadata.level === 1 && 'Kết quả gợi ý'}
          {relaxationMetadata.level === 2 && 'Mở rộng tìm kiếm'}
          {relaxationMetadata.level === 3 && 'Kết quả từ toàn quốc'}
        </p>
        <p class={`text-xs sm:text-sm ${
          relaxationMetadata.level === 1 ? 'text-blue-800' :
          relaxationMetadata.level === 2 ? 'text-yellow-800' :
          'text-orange-800'
        }`}>
          {relaxationMetadata.description}.
          {relaxationMetadata.expandedLocation && (
            <span>
              {' '}
              Tìm thấy <strong>{properties.length}</strong> BĐS tại{' '}
              <strong>{relaxationMetadata.expandedLocation.to}</strong>.
            </span>
          )}
        </p>
      </div>
    </div>
  </div>
)}

{properties.length > 0 ? (
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-6">
    {properties.map((property, index) => (
      <div
        class="opacity-0 animate-fade-in-up"
        style={`animation-delay: ${index * 100}ms; animation-fill-mode: forwards;`}
      >
        <PropertyCard property={property} />
      </div>
    ))}
  </div>
) : (
  <div class="bg-white rounded-lg shadow-sm p-8 text-center">
    <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <h3 class="text-lg font-medium text-slate-700 mb-2">Không tìm thấy kết quả</h3>
    <p class="text-slate-500">
      Thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác.
    </p>
  </div>
)}
