---
/**
 * Contact Card Component
 * Reusable contact card with logo, info, and action buttons
 * Used in both property detail sidebar and listing sidebar
 * Mobile: adapts to fixed bottom bar on property detail pages
 */

interface Props {
  /** Show mobile bottom bar (only for property detail pages) */
  showMobileBar?: boolean;
  /** Custom phone number */
  phone?: string;
  /** Custom email */
  email?: string;
  /** Custom Zalo URL or ID */
  zaloUrl?: string;
}

const {
  showMobileBar = false,
  phone = "1900 98 89 98",
  email = "cskh@tongkhobds.com",
  zaloUrl = "https://zalo.me/743507688581290959",
} = Astro.props;

// Format phone for tel: link (remove spaces/dashes)
const telLink = `tel:${phone.replace(/\s|-/g, "")}`;
---

<!-- Desktop/Tablet Card -->
<div class={showMobileBar ? "hidden lg:block" : ""}>
  <div class="bg-white rounded-lg shadow-sm p-6 border border-slate-100">
    <!-- Header with logo and branding -->
    <div class="flex items-center gap-3 mb-6">
      <div class="w-14 h-14 rounded-full flex-shrink-0">
        <img
          src="/images/tongkho-logo.jpg"
          alt="TongkhoBDS"
          class="w-14 h-14 rounded-full object-cover"
        />
      </div>
      <div>
        <h3 class="font-bold text-slate-800 text-lg">TongkhoBDS.com</h3>
      </div>
    </div>

    <!-- Contact info -->
    <div class="space-y-3 mb-6">
      <!-- Phone -->
      <div class="flex items-center gap-3 text-slate-700">
        <svg
          class="w-5 h-5 text-slate-400 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          ></path>
        </svg>
        <span class="font-medium">{phone}</span>
      </div>

      <!-- Email -->
      <div class="flex items-center gap-3 text-slate-700">
        <svg
          class="w-5 h-5 text-slate-400 flex-shrink-0"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
        <span class="font-medium text-sm">{email}</span>
      </div>
    </div>

    <!-- Action buttons -->
    <div class="flex gap-3">
      <!-- Call button -->
      <a
        href={telLink}
        class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-orange-500 hover:bg-orange-600 text-white rounded-lg font-medium transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          ></path>
        </svg>
        <span>Gọi ngay</span>
      </a>

      <!-- Message button (Zalo) -->
      <a
        href={zaloUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 2C6.48 2 2 6.48 2 12c0 1.54.36 3 .97 4.29L2 22l5.71-.97C9 21.64 10.46 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-1.4 0-2.74-.35-3.9-1.01l-.28-.16-2.91.62.62-2.91-.16-.28C4.35 14.74 4 13.4 4 12c0-4.41 3.59-8 8-8s8 3.59 8 8-3.59 8-8 8z"
          ></path>
        </svg>
        <span>Nhắn tin</span>
      </a>
    </div>
  </div>
</div>

{
  showMobileBar && (
    <!-- Mobile Bottom Bar (only for property detail pages) -->
    <div class="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 shadow-xl z-50">
      <div class="container-custom py-3">
        <div class="grid grid-cols-2 gap-3">
          <!-- Call Button -->
          <a
            href={telLink}
            class="flex items-center justify-center gap-2 px-4 py-3 bg-orange-500 hover:bg-orange-600 text-white rounded-lg font-medium transition-colors"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              />
            </svg>
            <span>Gọi ngay</span>
          </a>

          <!-- Zalo Button -->
          <a
            href={zaloUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 1.54.36 3 .97 4.29L2 22l5.71-.97C9 21.64 10.46 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-1.4 0-2.74-.35-3.9-1.01l-.28-.16-2.91.62.62-2.91-.16-.28C4.35 14.74 4 13.4 4 12c0-4.41 3.59-8 8-8s8 3.59 8 8-3.59 8-8 8z" />
            </svg>
            <span>Nhắn tin</span>
          </a>
        </div>
      </div>
    </div>
  )
}
