---
/**
 * Area Slider Inline Component
 * Inline dual-handle slider for area filtering (no dropdown wrapper)
 * Designed to be embedded in advanced filter panels
 */

interface Props {
  currentMin?: number;
  currentMax?: number;
}

const { currentMin, currentMax } = Astro.props;

// Area configuration
const AREA_CONFIG = {
  min: 0,
  max: 1000,
  step: 5,
  unit: 'm²',
  presets: [
    { label: 'Dưới 30 m²', min: 0, max: 30 },
    { label: '30 - 50 m²', min: 30, max: 50 },
    { label: '50 - 80 m²', min: 50, max: 80 },
    { label: '80 - 100 m²', min: 80, max: 100 },
    { label: '100 - 150 m²', min: 100, max: 150 },
    { label: '150 - 200 m²', min: 150, max: 200 },
    { label: '200 - 250 m²', min: 200, max: 250 },
    { label: '250 - 300 m²', min: 250, max: 300 },
    { label: '300 - 500 m²', min: 300, max: 500 },
    { label: 'Trên 500 m²', min: 500, max: 1000 },
  ]
};

// Parse current values
const parsedMin = currentMin ?? AREA_CONFIG.min;
const parsedMax = currentMax ?? AREA_CONFIG.max;
---

<div class="area-slider-inline" data-area-slider data-config={JSON.stringify(AREA_CONFIG)}>
  <!-- Range Display -->
  <div class="flex justify-between mb-3 text-sm">
    <span class="text-secondary-600">
      từ <span class="text-primary-500 font-semibold" data-min-display>{parsedMin} m²</span>
    </span>
    <span class="text-secondary-600">
      đến <span class="text-primary-500 font-semibold" data-max-display>{parsedMax} m²</span>
    </span>
  </div>

  <!-- Input Fields -->
  <div class="grid grid-cols-2 gap-2 mb-3">
    <input
      type="number"
      placeholder="Từ"
      min={AREA_CONFIG.min}
      max={AREA_CONFIG.max}
      step={AREA_CONFIG.step}
      class="w-full px-3 py-2 border border-secondary-200 rounded-lg text-sm text-secondary-700 focus:outline-none focus:ring-2 focus:ring-primary-500"
      data-area-min-input
      value={parsedMin === AREA_CONFIG.min ? '' : parsedMin}
    />
    <input
      type="number"
      placeholder="Đến"
      min={AREA_CONFIG.min}
      max={AREA_CONFIG.max}
      step={AREA_CONFIG.step}
      class="w-full px-3 py-2 border border-secondary-200 rounded-lg text-sm text-secondary-700 focus:outline-none focus:ring-2 focus:ring-primary-500"
      data-area-max-input
      value={parsedMax === AREA_CONFIG.max ? '' : parsedMax}
    />
  </div>

  <!-- Dual Range Slider -->
  <div class="relative h-8 mb-4 flex items-center" data-area-slider-container>
    <!-- Background track -->
    <div class="absolute left-0 right-0 h-2 bg-secondary-200 rounded-full"></div>
    <!-- Active track -->
    <div class="absolute h-2 bg-primary-500 rounded-full" data-area-track></div>
    <!-- Min thumb -->
    <input
      type="range"
      min={AREA_CONFIG.min}
      max={AREA_CONFIG.max}
      step={AREA_CONFIG.step}
      value={parsedMin}
      class="absolute w-full h-2 appearance-none bg-transparent pointer-events-none z-20"
      data-area-range-min
      style="z-index: 3;"
    />
    <!-- Max thumb -->
    <input
      type="range"
      min={AREA_CONFIG.min}
      max={AREA_CONFIG.max}
      step={AREA_CONFIG.step}
      value={parsedMax}
      class="absolute w-full h-2 appearance-none bg-transparent pointer-events-none z-10"
      data-area-range-max
      style="z-index: 4;"
    />
  </div>

  <!-- Preset Quick Picks -->
  <div class="max-h-48 overflow-y-auto space-y-1 mb-3">
    {AREA_CONFIG.presets.map((preset) => (
      <button
        type="button"
        class="area-preset-btn w-full flex items-center justify-between px-3 py-2 rounded-lg hover:bg-secondary-50 transition-colors text-secondary-700 text-sm"
        data-area-preset
        data-min={preset.min}
        data-max={preset.max}
      >
        <span>{preset.label}</span>
        <div class="w-4 h-4 rounded-full border-2 border-secondary-300 flex items-center justify-center">
          <svg class="w-2.5 h-2.5 text-white hidden" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"
            />
          </svg>
        </div>
      </button>
    ))}
  </div>

  <!-- Reset Button -->
  <button
    type="button"
    class="w-full px-4 py-2 bg-red-500 text-white text-sm rounded-lg hover:bg-red-600 transition-colors font-medium"
    data-area-reset
  >
    Đặt lại
  </button>
</div>

<style>
  /* Range slider styling */
  [data-area-range-min]::-webkit-slider-thumb,
  [data-area-range-max]::-webkit-slider-thumb {
    appearance: none;
    width: 20px;
    height: 20px;
    background: #3b82f6;
    border: 3px solid white;
    border-radius: 50%;
    cursor: pointer;
    pointer-events: all;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  [data-area-range-min]::-moz-range-thumb,
  [data-area-range-max]::-moz-range-thumb {
    width: 20px;
    height: 20px;
    background: #3b82f6;
    border: 3px solid white;
    border-radius: 50%;
    cursor: pointer;
    pointer-events: all;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  /* Active preset button */
  .area-preset-btn.active {
    background-color: #eff6ff;
    color: #3b82f6;
  }

  .area-preset-btn.active .w-4 {
    border-color: #3b82f6;
    background-color: #3b82f6;
  }

  .area-preset-btn.active svg {
    display: block !important;
  }
</style>

<script>
  /**
   * Area Slider Inline Logic
   */
  function initAreaSliders() {
    document.querySelectorAll('[data-area-slider]').forEach((slider) => {
      const htmlSlider = slider as HTMLElement;
      // Skip if already initialized
      if (htmlSlider.dataset.initialized) return;
      htmlSlider.dataset.initialized = 'true';

      const config = JSON.parse(htmlSlider.dataset.config || '{}');
      const MIN = config.min || 0;
      const MAX = config.max || 1000;
      const STEP = config.step || 5;

      const minInput = slider.querySelector('[data-area-min-input]') as HTMLInputElement;
      const maxInput = slider.querySelector('[data-area-max-input]') as HTMLInputElement;
      const minDisplay = slider.querySelector('[data-min-display]') as HTMLSpanElement;
      const maxDisplay = slider.querySelector('[data-max-display]') as HTMLSpanElement;
      const track = slider.querySelector('[data-area-track]') as HTMLDivElement;
      const rangeMin = slider.querySelector('[data-area-range-min]') as HTMLInputElement;
      const rangeMax = slider.querySelector('[data-area-range-max]') as HTMLInputElement;
      const presetBtns = slider.querySelectorAll('[data-area-preset]') as NodeListOf<HTMLButtonElement>;
      const resetBtn = slider.querySelector('[data-area-reset]') as HTMLButtonElement;

      // Initialize values
      let minVal = Number(rangeMin.value);
      let maxVal = Number(rangeMax.value);

      // Format value
      function formatValue(value: number): string {
        return `${value} m²`;
      }

      // Update UI
      function updateUI() {
        minDisplay.textContent = formatValue(minVal);
        maxDisplay.textContent = formatValue(maxVal);

        // Update input fields
        if (minInput.value !== String(minVal)) minInput.value = minVal === MIN ? '' : String(minVal);
        if (maxInput.value !== String(maxVal)) maxInput.value = maxVal === MAX ? '' : String(maxVal);

        // Update slider positions
        rangeMin.value = String(minVal);
        rangeMax.value = String(maxVal);

        // Update track position
        const minPercent = ((minVal - MIN) / (MAX - MIN)) * 100;
        const maxPercent = ((maxVal - MIN) / (MAX - MIN)) * 100;
        track.style.left = `${minPercent}%`;
        track.style.right = `${100 - maxPercent}%`;

        // Update preset buttons
        presetBtns.forEach((btn) => {
          const presetMin = Number(btn.dataset.min);
          const presetMax = Number(btn.dataset.max);
          const isActive = minVal === presetMin && maxVal === presetMax;
          btn.classList.toggle('active', isActive);
        });

        // Dispatch change event for parent components
        slider.dispatchEvent(new CustomEvent('area-change', {
          detail: { min: minVal === MIN ? null : minVal, max: maxVal === MAX ? null : maxVal },
          bubbles: true
        }));
      }

      // Range slider input handlers
      rangeMin.addEventListener('input', () => {
        const value = Number(rangeMin.value);
        minVal = Math.min(value, maxVal - STEP);
        rangeMin.value = String(minVal);
        updateUI();
      });

      rangeMax.addEventListener('input', () => {
        const value = Number(rangeMax.value);
        maxVal = Math.max(value, minVal + STEP);
        rangeMax.value = String(maxVal);
        updateUI();
      });

      // Manual input handlers
      minInput.addEventListener('change', () => {
        const value = minInput.value === '' ? MIN : Number(minInput.value);
        minVal = Math.max(MIN, Math.min(value, maxVal - STEP));
        updateUI();
      });

      maxInput.addEventListener('change', () => {
        const value = maxInput.value === '' ? MAX : Number(maxInput.value);
        maxVal = Math.min(MAX, Math.max(value, minVal + STEP));
        updateUI();
      });

      // Preset buttons
      presetBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          minVal = Number(btn.dataset.min);
          maxVal = Number(btn.dataset.max);
          updateUI();
        });
      });

      // Reset button
      resetBtn?.addEventListener('click', () => {
        minVal = MIN;
        maxVal = MAX;
        updateUI();
      });

      // Initial UI update
      updateUI();
    });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAreaSliders);
  } else {
    initAreaSliders();
  }

  // Run on Astro View Transitions
  document.addEventListener('astro:page-load', initAreaSliders);
</script>
