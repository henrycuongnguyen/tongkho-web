---
/**
 * Simple Price Range Dropdown (v1 Style)
 * Predefined price options without slider
 */

interface Props {
  transactionType: number;
  currentMin?: string;
  currentMax?: string;
}

const { transactionType, currentMin, currentMax } = Astro.props;

// Price ranges based on transaction type (v1 format)
const SALE_PRICE_RANGES = [
  { label: 'Tất cả', min: '', max: '' },
  { label: '800 triệu - 1 tỷ', min: '800', max: '1000' },
  { label: '1 tỷ - 2 tỷ', min: '1000', max: '2000' },
  { label: '2 tỷ - 3 tỷ', min: '2000', max: '3000' },
  { label: '3 tỷ - 5 tỷ', min: '3000', max: '5000' },
  { label: '5 tỷ - 7 tỷ', min: '5000', max: '7000' },
  { label: '7 tỷ - 10 tỷ', min: '7000', max: '10000' },
  { label: '10 tỷ - 20 tỷ', min: '10000', max: '20000' },
  { label: '20 tỷ - 30 tỷ', min: '20000', max: '30000' },
  { label: '30 tỷ - 40 tỷ', min: '30000', max: '40000' },
  { label: '40 tỷ - 60 tỷ', min: '40000', max: '60000' },
  { label: 'Trên 60 tỷ', min: '60000', max: '' },
  { label: 'Thương lượng', min: '0', max: '0' },
];

const RENT_PRICE_RANGES = [
  { label: 'Tất cả', min: '', max: '' },
  { label: 'Dưới 1 triệu', min: '', max: '1' },
  { label: '1 - 3 triệu', min: '1', max: '3' },
  { label: '3 - 5 triệu', min: '3', max: '5' },
  { label: '5 - 10 triệu', min: '5', max: '10' },
  { label: '10 - 40 triệu', min: '10', max: '40' },
  { label: '40 - 70 triệu', min: '40', max: '70' },
  { label: '70 - 100 triệu', min: '70', max: '100' },
  { label: 'Trên 100 triệu', min: '100', max: '' },
];

// Select price ranges based on transaction type
const priceRanges = transactionType === 2 ? RENT_PRICE_RANGES : SALE_PRICE_RANGES;

// Find current selection
function getCurrentLabel(): string {
  if (!currentMin && !currentMax) return 'Khoảng giá';

  const range = priceRanges.find(r => r.min === currentMin && r.max === currentMax);
  return range?.label || 'Khoảng giá';
}

const selectedLabel = getCurrentLabel();
---

<div class="price-dropdown relative">
  <!-- Trigger Button -->
  <button
    type="button"
    class="w-full px-4 py-2.5 border border-secondary-300 rounded-lg bg-white hover:border-primary-400 focus:outline-none focus:ring-2 focus:ring-primary-500 text-secondary-700 text-sm text-left flex items-center justify-between transition-all"
    data-price-trigger
  >
    <span class="font-medium">{selectedLabel}</span>
    <svg
      class="w-4 h-4 text-secondary-400 shrink-0 transition-transform"
      data-arrow
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <!-- Hidden inputs for form submission -->
  <input type="hidden" name="price-min" data-price-min value={currentMin || ''} />
  <input type="hidden" name="price-max" data-price-max value={currentMax || ''} />

  <!-- Dropdown Panel -->
  <div
    class="absolute top-full left-0 mt-2 bg-white rounded-lg shadow-xl border border-secondary-100 w-full min-w-[220px] max-h-[500px] overflow-hidden hidden z-[9999]"
    data-price-panel
  >
    <!-- Options List -->
    <div class="overflow-y-auto max-h-[500px]">
      {priceRanges.map((range) => {
        const isActive = range.min === (currentMin || '') && range.max === (currentMax || '');

        return (
          <button
            type="button"
            class:list={[
              'w-full px-4 py-2.5 text-sm text-left hover:bg-secondary-50 transition-colors',
              isActive
                ? 'bg-primary-50 text-primary-600 font-medium'
                : 'text-secondary-700'
            ]}
            data-price-option
            data-min={range.min}
            data-max={range.max}
            data-label={range.label}
          >
            {range.label}
          </button>
        );
      })}
    </div>
  </div>
</div>

<script>
  /**
   * Price Dropdown Logic
   */
  function initPriceDropdowns() {
    document.querySelectorAll('[data-price-trigger]').forEach((trigger) => {
      const container = trigger.closest('.price-dropdown') as HTMLElement;
      if (!container || container.dataset.initialized) return;

      container.dataset.initialized = 'true';

      const panel = container.querySelector('[data-price-panel]') as HTMLElement;
      const arrow = container.querySelector('[data-arrow]') as SVGElement;
      const triggerText = trigger.querySelector('span') as HTMLElement;
      const minInput = container.querySelector('[data-price-min]') as HTMLInputElement;
      const maxInput = container.querySelector('[data-price-max]') as HTMLInputElement;
      const options = container.querySelectorAll('[data-price-option]') as NodeListOf<HTMLButtonElement>;

      let isOpen = false;

      // Toggle dropdown
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        isOpen = !isOpen;
        panel?.classList.toggle('hidden', !isOpen);
        arrow?.classList.toggle('rotate-180', isOpen);
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!container.contains(e.target as Node)) {
          isOpen = false;
          panel?.classList.add('hidden');
          arrow?.classList.remove('rotate-180');
        }
      });

      // Handle option selection
      options.forEach(option => {
        option.addEventListener('click', () => {
          const min = option.dataset.min || '';
          const max = option.dataset.max || '';
          const label = option.dataset.label || 'Khoảng giá';

          // Update hidden inputs
          minInput.value = min;
          maxInput.value = max;

          // Update trigger text
          triggerText.textContent = label;

          // Update active state
          options.forEach(opt => {
            opt.classList.remove('bg-primary-50', 'text-primary-600', 'font-medium');
            opt.classList.add('text-secondary-700');
          });

          option.classList.add('bg-primary-50', 'text-primary-600', 'font-medium');
          option.classList.remove('text-secondary-700');

          // Close dropdown
          isOpen = false;
          panel?.classList.add('hidden');
          arrow?.classList.remove('rotate-180');
        });
      });
    });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPriceDropdowns);
  } else {
    initPriceDropdowns();
  }

  // Run on Astro View Transitions
  document.addEventListener('astro:page-load', initPriceDropdowns);
</script>

<style>
  /* Smooth scrollbar */
  [data-price-panel] {
    scrollbar-width: thin;
    scrollbar-color: rgb(var(--color-secondary-300)) transparent;
  }

  [data-price-panel]::-webkit-scrollbar {
    width: 6px;
  }

  [data-price-panel]::-webkit-scrollbar-track {
    background: transparent;
  }

  [data-price-panel]::-webkit-scrollbar-thumb {
    background-color: rgb(var(--color-secondary-300));
    border-radius: 3px;
  }
</style>
