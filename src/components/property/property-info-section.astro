---
/**
 * Property Info Section
 * Displays property details in v1-compatible layout
 * Order: Title+Price, Address+Time, Actions, Info Grid, Description, Contact
 */
import type { Property, PropertyType } from '@/types/property';
import { formatPrice, formatRelativeTime } from '@/utils/format';
import ShareButtonPopup from '@/components/ui/share-button-popup.astro';

interface Props {
  property: Property;
}

const { property } = Astro.props;

// Property type labels
const propertyTypeLabels: Record<PropertyType, string> = {
  apartment: 'Căn hộ',
  house: 'Nhà phố',
  villa: 'Biệt thự',
  land: 'Đất nền',
  office: 'Văn phòng',
  shophouse: 'Shophouse',
  warehouse: 'Kho xưởng',
};

// Calculate price per m2
const pricePerM2 = property.area > 0 && property.price > 0
  ? property.priceUnit === 'billion'
    ? (property.price * 1000000000 / property.area).toFixed(0)
    : property.priceUnit === 'million'
    ? (property.price * 1000000 / property.area).toFixed(0)
    : null
  : null;

// Get property type display name (prefer DB value, fallback to mapped)
const propertyTypeName = property.propertyTypeName || propertyTypeLabels[property.type] || 'Bất động sản';

// Build full address
const fullAddress = [property.ward, property.district, property.city].filter(Boolean).join(', ');

// Check if has HTML content
const hasHtmlContent = property.htmlContent && property.htmlContent.trim().length > 0;
const isLongDescription = property.description.length > 300;
---

<section class="bg-white rounded-xl shadow-md p-6 md:p-8">
  <!-- Title + Price Row -->
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
    <!-- Title -->
    <h1
      class="text-2xl md:text-3xl font-bold text-secondary-800 flex-1"
      id="property-title"
      data-estate-id={property.id}
      data-transaction-type={property.transactionType === 'sale' ? '1' : '2'}
      data-title={property.title}
      data-url={`/bds/${property.slug}`}
      data-image={property.thumbnail}
    >
      {property.title}
    </h1>

    <!-- Price (orange color) -->
    <div class="shrink-0 text-right" id="property-price">
      <div class="text-2xl font-bold text-center text-orange-500">
        {formatPrice(property.price, property.priceUnit)}
      </div>
      <div class="text-base font-bold text-orange-500">
        {property.area > 0 && (
          <span>{property.area} m²</span>
        )}
        {pricePerM2 && (
          <span> - {(parseInt(pricePerM2) / 1000000).toFixed(0)} triệu/m²</span>
        )}
      </div>
    </div>
  </div>

  <!-- Address + Time + Actions Row (v1 style) -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4 pb-4 border-b border-secondary-100">
    <div class="flex flex-col sm:flex-row sm:items-center gap-3 flex-1">
      <p class="flex items-center gap-2 text-secondary-600">
        <svg class="w-4 h-4 text-primary-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span id="property-address">{fullAddress || property.address}</span>
      </p>
      <p class="flex items-center gap-2 text-secondary-500 text-sm">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span id="property-time-ago">{formatRelativeTime(property.createdAt)}</span>
      </p>
    </div>

    <!-- Action Buttons (same row, right side) -->
    <div class="flex items-center gap-2 shrink-0">
      <!-- Favorite -->
      <button
        class="favourite-button w-9 h-9 flex items-center justify-center rounded-lg bg-secondary-100 hover:bg-red-50 hover:text-red-500 text-secondary-500 transition-all duration-200 cursor-pointer"
        title="Thêm vào quan tâm"
        data-property-id={property.id}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </button>
      <!-- Compare -->
      <button
        class="btn-compare w-9 h-9 flex items-center justify-center rounded-lg bg-secondary-100 hover:bg-blue-50 hover:text-blue-500 text-secondary-500 transition-all duration-200 cursor-pointer"
        title="So sánh"
        data-estate-id={property.id}
        data-transaction-type={property.transactionType}
        data-image={property.thumbnail}
        data-title={property.title}
        data-url={`/bds/${property.slug}`}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
        </svg>
      </button>
      <!-- Share -->
      <div onclick="event.preventDefault(); event.stopPropagation();">
        <ShareButtonPopup url={`/bds/${property.slug}`} title={property.title} variant="detail" />
      </div>
    </div>
  </div>

  <!-- Property Info Boxes (simplified: Type + Area only) -->
  <div class="grid grid-cols-2 gap-4 mb-6">
    <!-- Property Type Box -->
    <div class="flex items-center gap-3 p-4 bg-secondary-50 rounded-lg">
      <div class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
      </div>
      <div>
        <div class="text-xs text-secondary-500">Loại</div>
        <div class="font-semibold text-secondary-800" id="property-type">{propertyTypeName}</div>
      </div>
    </div>

    <!-- Area Box -->
    <div class="flex items-center gap-3 p-4 bg-secondary-50 rounded-lg">
      <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
        </svg>
      </div>
      <div>
        <div class="text-xs text-secondary-500">Diện tích</div>
        <div class="font-semibold text-secondary-800">{property.area > 0 ? `${property.area} m²` : 'N/A'}</div>
      </div>
    </div>
  </div>


  <!-- Description Section -->
  <div class="mb-6">
    <div class="wg-content prose prose-sm max-w-none text-secondary-600" id="property-description">
      {hasHtmlContent ? (
        <div set:html={property.htmlContent} />
      ) : isLongDescription ? (
        <div>
          <div class="description-content" data-full-text={property.description}>
            {property.description.slice(0, 300)}...
          </div>
          <button
            class="text-primary-500 hover:text-primary-600 font-medium mt-2 transition-colors toggle-description cursor-pointer"
            data-action="expand"
          >
            Xem thêm →
          </button>
        </div>
      ) : (
        <p>{property.description || 'Thông tin chi tiết đang được cập nhật'}</p>
      )}
    </div>
  </div>

  <!-- Section Header: Detailed Information -->
  <div class="mb-4">
    <h2 class="text-[20px] leading-[50px] font-bold text-secondary-800">Thông tin chi tiết:</h2>
  </div>

  <!-- Contact Info Section (v1 style) -->
  <div class="bg-secondary-50 rounded-xl p-5 contact-info">
    <p class="text-secondary-700 mb-2">
      Tổng Kho BĐS luôn sẵn sàng đồng hành cùng bạn trên hành trình tìm kiếm bất động sản phù hợp nhất.
    </p>
    <p class="text-secondary-700 font-medium mb-4">
      Liên hệ ngay để được chuyên viên tư vấn và hỗ trợ nhanh nhất!
    </p>
    <p class="mb-2">
      <a href="https://tongkhobds.com" class="text-primary-500 hover:text-primary-600 font-medium transition-colors" target="_blank">TongkhoBDS.com</a>
      <span class="text-secondary-600"> – Kho dữ liệu Bất động sản lớn nhất Việt Nam</span>
    </p>
    <p class="text-secondary-700 mb-1">
      <span class="font-medium">Địa chỉ:</span> 51 Kim Mã, Ba Đình, Hà Nội
    </p>
    <p class="text-secondary-700 mb-1">
      <span class="font-medium">Hotline:</span> 1900.988.998
    </p>
    <p class="text-secondary-700">
      <span class="font-medium">Email:</span>
      <a href="mailto:cskh@tongkhobds.com" class="text-primary-500 hover:text-primary-600 transition-colors">cskh@tongkhobds.com</a>
    </p>
  </div>
</section>

<script>
  // Toggle description expand/collapse
  document.querySelectorAll('.toggle-description').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.target as HTMLButtonElement;
      const content = target.previousElementSibling as HTMLElement;
      const full = content.dataset.fullText || '';
      const isExpanded = target.dataset.action === 'collapse';
      content.textContent = isExpanded ? full.slice(0, 300) + '...' : full;
      target.textContent = isExpanded ? 'Xem thêm →' : '← Thu gọn';
      target.dataset.action = isExpanded ? 'expand' : 'collapse';
    });
  });
</script>
