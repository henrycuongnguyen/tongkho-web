---
/**
 * Project Detail Content Component
 * Shared content component for project detail pages
 * Used by both [...slug].astro and du-an/[slug].astro
 */
import ImageGalleryCarousel from '@/components/property/property-detail-image-gallery-carousel.astro';
import PropertyCard from '@/components/cards/property-card.astro';
import type { ProjectDetail, ProjectProperties } from '@/services/project-detail-service';
import { mapPropertyDocumentsToProperties } from '@/utils/property-mapper';

interface Props {
  project: ProjectDetail;
  projectProperties: ProjectProperties;
}

const { project, projectProperties } = Astro.props;

// Map ES documents to Property types for PropertyCard
const sellPropertiesMapped = mapPropertyDocumentsToProperties(projectProperties.sellProperties);
const rentPropertiesMapped = mapPropertyDocumentsToProperties(projectProperties.rentProperties);

// Check if we should show each section
const hasProperties = projectProperties.sellProperties.length > 0 || projectProperties.rentProperties.length > 0;
const hasFloorPlans = project.masterPlanImages.length > 0;
const hasMap = project.lat !== null && project.lng !== null;
---

<div class="space-y-6">
  <!-- 1. Image Gallery -->
  <ImageGalleryCarousel
    images={project.galleryImages}
    realEstateCode={project.projectCode || undefined}
  />

  <!-- 2. Breadcrumb -->
  <nav class="text-sm text-secondary-500">
    <ol class="flex flex-wrap items-center gap-2">
      <li><a href="/" class="hover:text-primary-500 transition-colors">Trang chủ</a></li>
      <li class="text-secondary-300">&gt;</li>
      <li><a href="/du-an" class="hover:text-primary-500 transition-colors">Dự án</a></li>
      <li class="text-secondary-300">&gt;</li>
      <li class="text-secondary-700 font-medium line-clamp-1">{project.projectName}</li>
    </ol>
  </nav>

  <!-- 3. Project Header -->
  <section class="flex items-start gap-4">
    {project.developerLogo && (
      <div class="flex-shrink-0 w-16 h-16 bg-white rounded-lg shadow-sm border border-secondary-100 overflow-hidden">
        <img
          src={project.developerLogo}
          alt={project.developerName || 'Developer'}
          class="w-full h-full object-contain p-2"
        />
      </div>
    )}
    <div class="flex-1">
      <h1 class="text-2xl font-bold text-secondary-900">{project.projectName}</h1>
      {project.fullAddress && (
        <p class="text-secondary-600 mt-1 flex items-center gap-1">
          <svg class="w-4 h-4 text-secondary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          {project.fullAddress}
        </p>
      )}
    </div>
  </section>

  <!-- 4. Project Tabs -->
  <div class="border-b border-secondary-200 overflow-x-auto">
    <nav class="flex gap-4 min-w-max" aria-label="Project tabs">
      <a href="#section-overview" class="project-tab py-3 px-4 border-b-2 border-primary-500 text-primary-600 font-medium text-sm whitespace-nowrap">
        Tổng quan
        <span class="block text-xs text-secondary-400 font-normal">Giới thiệu về dự án</span>
      </a>
      {hasProperties && (
        <a href="#section-properties" class="project-tab py-3 px-4 border-b-2 border-transparent text-secondary-600 hover:text-secondary-900 font-medium text-sm whitespace-nowrap">
          Tin đăng
          <span class="block text-xs text-secondary-400 font-normal">Tin đăng tại dự án</span>
        </a>
      )}
      {hasFloorPlans && (
        <a href="#section-floor-plans" class="project-tab py-3 px-4 border-b-2 border-transparent text-secondary-600 hover:text-secondary-900 font-medium text-sm whitespace-nowrap">
          Mặt bằng dự án
          <span class="block text-xs text-secondary-400 font-normal">Tổng thể hạ tầng</span>
        </a>
      )}
      {hasMap && (
        <a href="#section-map" class="project-tab py-3 px-4 border-b-2 border-transparent text-secondary-600 hover:text-secondary-900 font-medium text-sm whitespace-nowrap">
          Vị trí
          <span class="block text-xs text-secondary-400 font-normal">Bản đồ dự án</span>
        </a>
      )}
    </nav>
  </div>

  <!-- 5. Overview Section -->
  <section id="section-overview" class="bg-white rounded-xl p-6 shadow-sm border border-secondary-100">
    <h2 class="text-xl font-semibold text-secondary-800 mb-4">Tổng quan dự án</h2>

    <!-- Project Info Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      {project.projectStatus && (
        <div class="bg-secondary-50 rounded-lg p-3">
          <span class="block text-xs text-secondary-500">Trạng thái</span>
          <span class="font-medium text-secondary-800">{project.projectStatus}</span>
        </div>
      )}
      {project.projectArea && (
        <div class="bg-secondary-50 rounded-lg p-3">
          <span class="block text-xs text-secondary-500">Diện tích</span>
          <span class="font-medium text-secondary-800">{project.projectArea.toLocaleString('vi-VN')} {project.areaUnit}</span>
        </div>
      )}
      {project.totalUnits && (
        <div class="bg-secondary-50 rounded-lg p-3">
          <span class="block text-xs text-secondary-500">Số căn hộ</span>
          <span class="font-medium text-secondary-800">{project.totalUnits.toLocaleString('vi-VN')}</span>
        </div>
      )}
      {project.totalTowers && (
        <div class="bg-secondary-50 rounded-lg p-3">
          <span class="block text-xs text-secondary-500">Số tòa</span>
          <span class="font-medium text-secondary-800">{project.totalTowers}</span>
        </div>
      )}
      {project.legalStatus && (
        <div class="bg-secondary-50 rounded-lg p-3">
          <span class="block text-xs text-secondary-500">Pháp lý</span>
          <span class="font-medium text-secondary-800">{project.legalStatus}</span>
        </div>
      )}
      {project.priceDescription && (
        <div class="bg-secondary-50 rounded-lg p-3">
          <span class="block text-xs text-secondary-500">Giá bán</span>
          <span class="font-medium text-secondary-800">{project.priceDescription}</span>
        </div>
      )}
      {project.developerName && (
        <div class="bg-secondary-50 rounded-lg p-3 col-span-2">
          <span class="block text-xs text-secondary-500">Chủ đầu tư</span>
          <span class="font-medium text-secondary-800">{project.developerName}</span>
        </div>
      )}
    </div>

    <!-- Description -->
    {project.description && (
      <div class="prose prose-secondary max-w-none">
        <Fragment set:html={project.description} />
      </div>
    )}

    <!-- Utilities -->
    {project.utilities.length > 0 && (
      <div class="mt-6">
        <h3 class="text-lg font-medium text-secondary-800 mb-3">Tiện ích</h3>
        <div class="flex flex-wrap gap-2">
          {project.utilities.map((utility) => (
            <span class="px-3 py-1 bg-primary-50 text-primary-700 rounded-full text-sm">
              {utility}
            </span>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- 6. Properties Section -->
  {hasProperties && (
    <section id="section-properties" class="bg-white rounded-xl p-6 shadow-sm border border-secondary-100">
      <!-- Sell Properties -->
      {projectProperties.sellProperties.length > 0 && (
        <div class="mb-8">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold text-secondary-800">Tin mua bán tại dự án</h2>
            {projectProperties.seeAllSellUrl && (
              <a href={projectProperties.seeAllSellUrl} class="text-primary-600 hover:text-primary-700 text-sm font-medium flex items-center gap-1">
                Xem tất cả
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            )}
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {sellPropertiesMapped.map((property) => (
              <PropertyCard property={property} />
            ))}
          </div>
        </div>
      )}

      <!-- Rent Properties -->
      {projectProperties.rentProperties.length > 0 && (
        <div>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-semibold text-secondary-800">Tin cho thuê tại dự án</h2>
            {projectProperties.seeAllRentUrl && (
              <a href={projectProperties.seeAllRentUrl} class="text-primary-600 hover:text-primary-700 text-sm font-medium flex items-center gap-1">
                Xem tất cả
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            )}
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {rentPropertiesMapped.map((property) => (
              <PropertyCard property={property} />
            ))}
          </div>
        </div>
      )}
    </section>
  )}

  <!-- 7. Floor Plan Section -->
  {hasFloorPlans && (
    <section id="section-floor-plans" class="bg-white rounded-xl p-6 shadow-sm border border-secondary-100">
      <h2 class="text-xl font-semibold text-secondary-800 mb-4">Mặt bằng dự án</h2>
      <div class="space-y-4">
        {project.masterPlanImages.map((image, index) => (
          <details class="group border border-secondary-200 rounded-lg overflow-hidden" open={index === 0}>
            <summary class="flex items-center justify-between p-4 bg-secondary-50 cursor-pointer hover:bg-secondary-100 transition-colors">
              <span class="font-medium text-secondary-800">Mặt bằng thứ {index + 1}</span>
              <svg class="w-5 h-5 text-secondary-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="p-4">
              <img
                src={image}
                alt={`Mặt bằng ${index + 1}`}
                class="w-full rounded-lg"
                loading="lazy"
              />
            </div>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- 8. Map Section -->
  {hasMap && (
    <section id="section-map" class="bg-white rounded-xl p-6 shadow-sm border border-secondary-100">
      <h2 class="text-xl font-semibold text-secondary-800 mb-4">Vị trí</h2>
      <div class="aspect-video rounded-lg overflow-hidden mb-4">
        <iframe
          width="100%"
          height="100%"
          style="border:0;"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          src={`https://www.google.com/maps?q=${project.lat},${project.lng}&z=15&output=embed`}
        ></iframe>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        {project.streetAddress && (
          <div class="flex items-start gap-2">
            <span class="text-secondary-500">Địa chỉ:</span>
            <span class="text-secondary-800">{project.streetAddress}</span>
          </div>
        )}
        {project.city && (
          <div class="flex items-start gap-2">
            <span class="text-secondary-500">Tỉnh/Thành:</span>
            <span class="text-secondary-800">{project.city}</span>
          </div>
        )}
        {project.district && (
          <div class="flex items-start gap-2">
            <span class="text-secondary-500">Quận/Huyện:</span>
            <span class="text-secondary-800">{project.district}</span>
          </div>
        )}
        {project.ward && (
          <div class="flex items-start gap-2">
            <span class="text-secondary-500">Phường/Xã:</span>
            <span class="text-secondary-800">{project.ward}</span>
          </div>
        )}
      </div>
    </section>
  )}
</div>

<script>
  // Tab active state on scroll
  const tabs = document.querySelectorAll('.project-tab');
  const sections = document.querySelectorAll('section[id^="section-"]');

  function updateActiveTab() {
    const scrollPosition = window.scrollY + 150;

    sections.forEach((section) => {
      const sectionTop = (section as HTMLElement).offsetTop;
      const sectionHeight = section.clientHeight;
      const sectionId = section.getAttribute('id');

      if (scrollPosition >= sectionTop && scrollPosition < sectionTop + sectionHeight) {
        tabs.forEach((tab) => {
          const href = tab.getAttribute('href');
          if (href === `#${sectionId}`) {
            tab.classList.add('border-primary-500', 'text-primary-600');
            tab.classList.remove('border-transparent', 'text-secondary-600');
          } else {
            tab.classList.remove('border-primary-500', 'text-primary-600');
            tab.classList.add('border-transparent', 'text-secondary-600');
          }
        });
      }
    });
  }

  // Smooth scroll to section on tab click
  tabs.forEach((tab) => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      const href = tab.getAttribute('href');
      if (href) {
        const target = document.querySelector(href);
        if (target) {
          const offsetTop = (target as HTMLElement).offsetTop - 100;
          window.scrollTo({
            top: offsetTop,
            behavior: 'smooth'
          });
        }
      }
    });
  });

  window.addEventListener('scroll', updateActiveTab);
  updateActiveTab();
</script>
