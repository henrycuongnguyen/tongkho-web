# Server configuration
HOST=0.0.0.0
PORT=4321

# Public variables (available in client-side)
PUBLIC_SITE_URL=https://tongkhobds.com
PUBLIC_API_URL=
PUBLIC_IMAGE_SERVER_URL=https://quanly.tongkhobds.com

# Google Maps JavaScript API Key (for /maps page)
# Get from: https://console.cloud.google.com/google/maps-apis
# Restrict to: tongkhobds.com, *.tongkhobds.com, localhost:*
PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Elasticsearch configuration (server-only)
ES_URL=https://elastic.tongkhobds.com
ES_INDEX=real_estate
ES_API_KEY=your_api_key_here

# SEO Metadata ElasticSearch (optional - uses same ES_URL/ES_API_KEY)
SEO_ES_INDEX=seo_meta_data

# PostgreSQL configuration (server-only)
DATABASE_URL=postgres://username:password@host:5432/database
